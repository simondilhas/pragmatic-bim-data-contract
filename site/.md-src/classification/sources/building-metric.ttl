  skos:broader met:total_exterior_door_area ;
  pbs:quantityType "area_net_vertical" ;
  pbs:defaultUnit "m2" ;
  pbs:measurementKind "area" ;
  pbs:spatialScope "above_ground" ;
  dcterms:identifier "total_exterior_door_area_above_ground" .

met:total_exterior_door_area_below_ground a skos:Concept ;
  skos:inScheme met:scheme ;
  skos:notation "total_exterior_door_area_below_ground" ;
  skos:prefLabel "Total exterior door area below ground"@en ;
  skos:broader met:total_exterior_door_area ;
  pbs:quantityType "area_net_vertical" ;
  pbs:defaultUnit "m2" ;
  pbs:measurementKind "area" ;
  pbs:spatialScope "below_ground" ;
  dcterms:identifier "total_exterior_door_area_below_ground" .

met:total_roof_area a skos:Concept ;
  skos:inScheme met:scheme ;
  skos:topConceptOf met:scheme ;
  skos:notation "total_roof_area" ;
  skos:prefLabel "Total roof area"@en ;
  skos:definition "Horizontal projection or net area of roof surfaces."@en ;
  skos:narrower met:total_roof_area_above_ground, met:total_roof_area_below_ground ;
  pbs:quantityType "area_gross_horizontal" ;
  pbs:defaultUnit "m2" ;
  pbs:measurementKind "area" ;
  dcterms:identifier "total_roof_area" .

met:total_roof_area_above_ground a skos:Concept ;
  skos:inScheme met:scheme ;
  skos:notation "total_roof_area_above_ground" ;
  skos:prefLabel "Total roof area above ground"@en ;
  skos:broader met:total_roof_area ;
  pbs:quantityType "area_gross_horizontal" ;
  pbs:defaultUnit "m2" ;
  pbs:measurementKind "area" ;
  pbs:spatialScope "above_ground" ;
  dcterms:identifier "total_roof_area_above_ground" .

met:total_roof_area_below_ground a skos:Concept ;
  skos:inScheme met:scheme ;
  skos:notation "total_roof_area_below_ground" ;
  skos:prefLabel "Total roof area below ground"@en ;
  skos:broader met:total_roof_area ;
