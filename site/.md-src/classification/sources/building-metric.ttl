  skos:broader met:total_exterior_window_area ;
  pbs:quantityType "area_net_vertical" ;
  pbs:defaultUnit "m2" ;
  pbs:measurementKind "area" ;
  pbs:spatialScope "above_ground" ;
  dcterms:identifier "total_exterior_window_area_above_ground" .

met:total_exterior_window_area_below_ground a skos:Concept ;
  skos:inScheme met:scheme ;
  skos:notation "total_exterior_window_area_below_ground" ;
