@prefix met: <https://example.org/abstract/building-metric-definition/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix pbs: <https://schema.pragmaticbim.ch/> .

met:scheme a skos:ConceptScheme ;
  skos:prefLabel "Abstract building metrics"@en ;
  skos:prefLabel "Abstrakte Gebaeudemetriken"@de ;
  dcterms:title "Abstract building metrics"@en ;
  dcterms:identifier "AbstractBuildingMetric" ;
  dcterms:creator "abstract" ;
  dcterms:issued "2026-06-29" ;
  dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
  dcterms:source <https://github.com/simondilhas/pragmatic-bim-data-contract> ;
  skos:definition "Semantic definitions for building-level area, volume, and count metrics. Scope variants (above/below ground) are narrower concepts; calculation logic lives in application pipelines."@en ;
  skos:hasTopConcept
    met:total_gross_floor_area,
    met:total_net_floor_area,
    met:total_construction_floor_area,
    met:total_exterior_floor_area,
    met:total_gross_building_volume,
    met:total_net_building_volume,
    met:total_vertical_facade_area,
    met:total_exterior_window_area,
    met:total_exterior_door_area,
    met:total_roof_area,
    met:total_soffit_area,
    met:total_envelope_area,
    met:total_storey_count .

# --- Floor area ---

met:total_gross_floor_area a skos:Concept ;
  skos:inScheme met:scheme ;
  skos:topConceptOf met:scheme ;
  skos:notation "total_gross_floor_area" ;
  skos:prefLabel "Total gross floor area"@en ;
  skos:prefLabel "Gesamte Bruttogeschossflaeche"@de ;
  skos:definition "All-side enclosed and covered floor area of accessible storeys including construction areas, measured to outer boundaries."@en ;
  dcterms:description "Close to SIA 416 GF (Geschossflaeche) and DIN 277 BGF."@en ;
  skos:narrower met:total_gross_floor_area_above_ground, met:total_gross_floor_area_below_ground ;
  pbs:quantityType "area_gross_horizontal" ;
  pbs:defaultUnit "m2" ;
  pbs:measurementKind "area" ;
  dcterms:identifier "total_gross_floor_area" .

met:total_gross_floor_area_above_ground a skos:Concept ;
  skos:inScheme met:scheme ;
  skos:notation "total_gross_floor_area_above_ground" ;
  skos:prefLabel "Total gross floor area above ground"@en ;
  skos:definition "Gross floor area of storeys above ground level."@en ;
  skos:broader met:total_gross_floor_area ;
  pbs:quantityType "area_gross_horizontal" ;
  pbs:defaultUnit "m2" ;
  pbs:measurementKind "area" ;
  pbs:spatialScope "above_ground" ;
  dcterms:identifier "total_gross_floor_area_above_ground" .

met:total_gross_floor_area_below_ground a skos:Concept ;
  skos:inScheme met:scheme ;
  skos:notation "total_gross_floor_area_below_ground" ;
  skos:prefLabel "Total gross floor area below ground"@en ;
  skos:definition "Gross floor area of storeys below ground level."@en ;
  skos:broader met:total_gross_floor_area ;
  pbs:quantityType "area_gross_horizontal" ;
  pbs:defaultUnit "m2" ;
  pbs:measurementKind "area" ;
  pbs:spatialScope "below_ground" ;
  dcterms:identifier "total_gross_floor_area_below_ground" .

met:total_net_floor_area a skos:Concept ;
  skos:inScheme met:scheme ;
  skos:topConceptOf met:scheme ;
  skos:notation "total_net_floor_area" ;
  skos:prefLabel "Total net floor area"@en ;
  skos:prefLabel "Gesamte Nettogeschossflaeche"@de ;
  skos:definition "Net floor area between enclosing construction elements, excluding construction thickness."@en ;
  dcterms:description "Close to SIA 416 NGF and DIN 277 NRF."@en ;
  skos:narrower met:total_net_floor_area_above_ground, met:total_net_floor_area_below_ground ;
  pbs:quantityType "area_net_horizontal" ;
  pbs:defaultUnit "m2" ;
  pbs:measurementKind "area" ;
  dcterms:identifier "total_net_floor_area" .

met:total_net_floor_area_above_ground a skos:Concept ;
  skos:inScheme met:scheme ;
  skos:notation "total_net_floor_area_above_ground" ;
  skos:prefLabel "Total net floor area above ground"@en ;
  skos:definition "Net floor area above ground level."@en ;
  skos:broader met:total_net_floor_area ;
  pbs:quantityType "area_net_horizontal" ;
  pbs:defaultUnit "m2" ;
  pbs:measurementKind "area" ;
  pbs:spatialScope "above_ground" ;
  dcterms:identifier "total_net_floor_area_above_ground" .

met:total_net_floor_area_below_ground a skos:Concept ;
  skos:inScheme met:scheme ;
  skos:notation "total_net_floor_area_below_ground" ;
  skos:prefLabel "Total net floor area below ground"@en ;
  skos:definition "Net floor area below ground level."@en ;
  skos:broader met:total_net_floor_area ;
  pbs:quantityType "area_net_horizontal" ;
  pbs:defaultUnit "m2" ;
  pbs:measurementKind "area" ;
  pbs:spatialScope "below_ground" ;
  dcterms:identifier "total_net_floor_area_below_ground" .

met:total_construction_floor_area a skos:Concept ;
  skos:inScheme met:scheme ;
  skos:topConceptOf met:scheme ;
  skos:notation "total_construction_floor_area" ;
  skos:prefLabel "Total construction floor area"@en ;
  skos:definition "Floor area occupied by enclosing and internal construction elements (shell zone between gross and net)."@en ;
  dcterms:description "Semantic composite; close to SIA 416 KF (Konstruktionsflaeche) and DIN 277 KGF."@en ;
  skos:narrower met:total_construction_floor_area_above_ground, met:total_construction_floor_area_below_ground ;
  pbs:quantityType "area_gross_horizontal" ;
  pbs:defaultUnit "m2" ;
  pbs:measurementKind "area" ;
  dcterms:identifier "total_construction_floor_area" .

met:total_construction_floor_area_above_ground a skos:Concept ;
  skos:inScheme met:scheme ;
  skos:notation "total_construction_floor_area_above_ground" ;
  skos:prefLabel "Total construction floor area above ground"@en ;
  skos:broader met:total_construction_floor_area ;
  pbs:quantityType "area_gross_horizontal" ;
  pbs:defaultUnit "m2" ;
  pbs:measurementKind "area" ;
  pbs:spatialScope "above_ground" ;
  dcterms:identifier "total_construction_floor_area_above_ground" .

met:total_construction_floor_area_below_ground a skos:Concept ;
  skos:inScheme met:scheme ;
  skos:notation "total_construction_floor_area_below_ground" ;
  skos:prefLabel "Total construction floor area below ground"@en ;
  skos:broader met:total_construction_floor_area ;
  pbs:quantityType "area_gross_horizontal" ;
  pbs:defaultUnit "m2" ;
  pbs:measurementKind "area" ;
  pbs:spatialScope "below_ground" ;
  dcterms:identifier "total_construction_floor_area_below_ground" .

met:total_exterior_floor_area a skos:Concept ;
  skos:inScheme met:scheme ;
  skos:topConceptOf met:scheme ;
  skos:notation "total_exterior_floor_area" ;
  skos:prefLabel "Total exterior floor area"@en ;
  skos:definition "Horizontal floor area of exterior or open covered spaces."@en ;
  dcterms:description "Close to SIA 416 AGF (Aussen-Geschossflaeche)."@en ;
  pbs:quantityType "area_gross_horizontal" ;
  pbs:defaultUnit "m2" ;
  pbs:measurementKind "area" ;
  dcterms:identifier "total_exterior_floor_area" .

# --- Volume ---

met:total_gross_building_volume a skos:Concept ;
  skos:inScheme met:scheme ;
  skos:topConceptOf met:scheme ;
  skos:notation "total_gross_building_volume" ;
  skos:prefLabel "Total gross building volume"@en ;
  skos:prefLabel "Gesamtes Gebaeudevolumen"@de ;
  skos:definition "Gross enclosed building volume measured to outer boundaries of enclosing elements."@en ;
  dcterms:description "Close to SIA 416 GV (Gebaeudevolumen)."@en ;
  skos:narrower met:total_gross_building_volume_above_ground, met:total_gross_building_volume_below_ground ;
  pbs:quantityType "volume_gross" ;
  pbs:defaultUnit "m3" ;
  pbs:measurementKind "volume" ;
  dcterms:identifier "total_gross_building_volume" .

met:total_gross_building_volume_above_ground a skos:Concept ;
  skos:inScheme met:scheme ;
  skos:notation "total_gross_building_volume_above_ground" ;
  skos:prefLabel "Total gross building volume above ground"@en ;
  skos:broader met:total_gross_building_volume ;
  pbs:quantityType "volume_gross" ;
  pbs:defaultUnit "m3" ;
  pbs:measurementKind "volume" ;
  pbs:spatialScope "above_ground" ;
  dcterms:identifier "total_gross_building_volume_above_ground" .

met:total_gross_building_volume_below_ground a skos:Concept ;
  skos:inScheme met:scheme ;
  skos:notation "total_gross_building_volume_below_ground" ;
  skos:prefLabel "Total gross building volume below ground"@en ;
  skos:broader met:total_gross_building_volume ;
  pbs:quantityType "volume_gross" ;
  pbs:defaultUnit "m3" ;
  pbs:measurementKind "volume" ;
  pbs:spatialScope "below_ground" ;
  dcterms:identifier "total_gross_building_volume_below_ground" .

met:total_net_building_volume a skos:Concept ;
  skos:inScheme met:scheme ;
  skos:topConceptOf met:scheme ;
  skos:notation "total_net_building_volume" ;
  skos:prefLabel "Total net building volume"@en ;
  skos:definition "Net enclosed volume between internal faces of enclosing construction elements."@en ;
  dcterms:description "Close to DIN 277 net volume / ISO 9836 net volume concepts."@en ;
  skos:narrower met:total_net_building_volume_above_ground, met:total_net_building_volume_below_ground ;
  pbs:quantityType "volume_net" ;
  pbs:defaultUnit "m3" ;
  pbs:measurementKind "volume" ;
  dcterms:identifier "total_net_building_volume" .

met:total_net_building_volume_above_ground a skos:Concept ;
  skos:inScheme met:scheme ;
  skos:notation "total_net_building_volume_above_ground" ;
  skos:prefLabel "Total net building volume above ground"@en ;
  skos:broader met:total_net_building_volume ;
  pbs:quantityType "volume_net" ;
  pbs:defaultUnit "m3" ;
  pbs:measurementKind "volume" ;
  pbs:spatialScope "above_ground" ;
  dcterms:identifier "total_net_building_volume_above_ground" .

met:total_net_building_volume_below_ground a skos:Concept ;
  skos:inScheme met:scheme ;
  skos:notation "total_net_building_volume_below_ground" ;
  skos:prefLabel "Total net building volume below ground"@en ;
  skos:broader met:total_net_building_volume ;
  pbs:quantityType "volume_net" ;
  pbs:defaultUnit "m3" ;
  pbs:measurementKind "volume" ;
  pbs:spatialScope "below_ground" ;
  dcterms:identifier "total_net_building_volume_below_ground" .

