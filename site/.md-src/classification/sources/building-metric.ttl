  skos:inScheme met:scheme ;
  skos:topConceptOf met:scheme ;
  skos:notation "total_envelope_area" ;
  skos:prefLabel "Total envelope area"@en ;
  skos:definition "Semantic composite of opaque facade, windows, doors, roof, and soffit areas forming the thermal envelope."@en ;
  pbs:quantityType "area_gross_vertical" ;
  pbs:defaultUnit "m2" ;
  pbs:measurementKind "area" ;
