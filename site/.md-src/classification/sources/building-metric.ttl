  skos:inScheme met:scheme ;
  skos:notation "total_soffit_area_above_ground" ;
  skos:prefLabel "Total soffit area above ground"@en ;
  skos:broader met:total_soffit_area ;
  pbs:quantityType "area_gross_horizontal" ;
