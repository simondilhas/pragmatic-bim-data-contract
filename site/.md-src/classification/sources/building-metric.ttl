# --- Counts ---

met:total_storey_count a skos:Concept ;
  skos:inScheme met:scheme ;
  skos:topConceptOf met:scheme ;
  skos:notation "total_storey_count" ;
  skos:prefLabel "Total storey count"@en ;
  skos:definition "Count of building storeys included in the measured scope."@en ;
  skos:narrower met:total_storey_count_above_ground, met:total_storey_count_below_ground ;
  pbs:quantityType "count" ;
  pbs:defaultUnit "1" ;
  pbs:measurementKind "count" ;
  dcterms:identifier "total_storey_count" .

met:total_storey_count_above_ground a skos:Concept ;
  skos:inScheme met:scheme ;
  skos:notation "total_storey_count_above_ground" ;
  skos:prefLabel "Total storey count above ground"@en ;
  skos:broader met:total_storey_count ;
  pbs:quantityType "count" ;
  pbs:defaultUnit "1" ;
  pbs:measurementKind "count" ;
  pbs:spatialScope "above_ground" ;
  dcterms:identifier "total_storey_count_above_ground" .

met:total_storey_count_below_ground a skos:Concept ;
  skos:inScheme met:scheme ;
  skos:notation "total_storey_count_below_ground" ;
  skos:prefLabel "Total storey count below ground"@en ;
  skos:broader met:total_storey_count ;
  pbs:quantityType "count" ;
  pbs:defaultUnit "1" ;
  pbs:measurementKind "count" ;
  pbs:spatialScope "below_ground" ;
  dcterms:identifier "total_storey_count_below_ground" .
