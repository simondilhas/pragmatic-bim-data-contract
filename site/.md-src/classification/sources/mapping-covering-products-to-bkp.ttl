@prefix fcp: <https://example.org/abstract/floor-covering-product/> .
@prefix wcp: <https://example.org/abstract/wall-covering-product/> .
@prefix ccp: <https://example.org/abstract/ceiling-covering-product/> .
@prefix facp: <https://example.org/abstract/facade-covering-product/> .
@prefix bkp: <https://example.org/ch/bkp/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix map: <https://example.org/mapping/> .

map:abstractCoveringProductsToBkpMapping a dcterms:Dataset ;
  dcterms:title "Abstract covering products to BKP mapping"@en ;
  dcterms:title "Mapping abstrakter Bekleidungsprodukte nach BKP"@de ;
  dcterms:references fcp:scheme, wcp:scheme, ccp:scheme, facp:scheme, bkp:scheme ;
  dcterms:issued "2026-06-30" ;
  dcterms:description "Maps abstract covering product concepts to BKP cost lines: Ausbau 2 (281 Bodenbelaege, 282 Wandbelaege, 283 Deckenverkleidungen) and Rohbau 2 facade cladding (215.5 Aeuessere Verkleidungen, 226 Fassadenputze, 227 Aeuessere Oberflaechenbehandlungen). BKP subcodes use underscore notation (e.g. bkp:281_7 for BKP 281.7). Full BKP vocabulary is external; only referenced IRIs are used."@en ;
  dcterms:description "Ordnet abstrakte Bekleidungsprodukte BKP-Positionen zu: Ausbau 2 (281 Bodenbelaege, 282 Wandbelaege, 283 Deckenverkleidungen) und Rohbau 2 Fassadenbekleidungen (215.5 Aeuessere Verkleidungen, 226 Fassadenputze, 227 Aeuessere Oberflaechenbehandlungen). BKP-Untercodes mit Unterstrich (z. B. bkp:281_7 fuer BKP 281.7). Vollstaendiges BKP-Vokabular extern."@de .

# --- Floor covering products (BKP 281.x) ---

fcp:FCP-SUBFLOOR skos:closeMatch bkp:281_0 .

fcp:FCP-SEAMLESS-RESIN skos:closeMatch bkp:281_1 .

fcp:FCP-CARPET skos:closeMatch bkp:281_2 .

fcp:FCP-LVT skos:closeMatch bkp:281_2 .

fcp:FCP-LINOLIUM skos:closeMatch bkp:281_2 .

fcp:FCP-NATURAL-STONE skos:closeMatch bkp:281_4 .

fcp:FCP-ARTIFICIAL-STONE skos:closeMatch bkp:281_5 .

fcp:FCP-CERAMIC-TILE skos:closeMatch bkp:281_6 .

fcp:FCP-PARQUET skos:closeMatch bkp:281_7 .

fcp:FCP-LAMINATE skos:closeMatch bkp:281_7 .

fcp:FCP-RAISED-FLOOR skos:closeMatch bkp:281_8 .

# --- Wall covering products (BKP 282.x) ---

wcp:WCP-SEAMLESS-COATING skos:closeMatch bkp:282_0 .

wcp:WCP-WALLPAPER skos:closeMatch bkp:282_1 .

wcp:WCP-NATURAL-STONE skos:closeMatch bkp:282_2 .

wcp:WCP-ARTIFICIAL-STONE skos:closeMatch bkp:282_3 .

wcp:WCP-CERAMIC-TILE skos:closeMatch bkp:282_4 .

wcp:WCP-WOOD-PANEL skos:closeMatch bkp:282_5 .

wcp:WCP-TEXTILE skos:closeMatch bkp:282_6 .

wcp:WCP-SYNTHETIC-PANEL skos:closeMatch bkp:282_6 .

wcp:WCP-PAINT skos:relatedMatch bkp:285 .

# --- Ceiling covering products (BKP 283.x) ---

ccp:CCP-METAL-SHEET skos:closeMatch bkp:283_1 .

ccp:CCP-GYPSUM-BOARD skos:closeMatch bkp:283_2 .

ccp:CCP-MINERAL-FIBRE skos:closeMatch bkp:283_3 .

ccp:CCP-WOOD skos:closeMatch bkp:283_4 .

ccp:CCP-SYNTHETIC skos:closeMatch bkp:283_5 .

ccp:CCP-METAL-PANEL skos:closeMatch bkp:283_6 .

ccp:CCP-METAL-GRID skos:closeMatch bkp:283_7 .

# --- Facade covering products (BKP 215.5 / 226.x / 227.x, Rohbau 2) ---

facp:FaCP-METAL-SHEET skos:closeMatch bkp:215_5 ;
  skos:relatedMatch bkp:215_2 .

facp:FaCP-METAL-PANEL skos:closeMatch bkp:215_5 ;
  skos:relatedMatch bkp:215_2 .

facp:FaCP-FIBRE-CEMENT skos:closeMatch bkp:215_5 .

facp:FaCP-NATURAL-STONE skos:closeMatch bkp:215_5 .

facp:FaCP-CERAMIC-TILE skos:closeMatch bkp:215_5 .

facp:FaCP-WOOD skos:closeMatch bkp:215_5 .

facp:FaCP-SYNTHETIC skos:closeMatch bkp:215_5 .

facp:FaCP-RENDER skos:closeMatch bkp:226_2 ;
  skos:relatedMatch bkp:226_1 .

facp:FaCP-EXTERIOR-PAINT skos:closeMatch bkp:227_1 .

facp:FaCP-HPL-PANEL skos:closeMatch bkp:215_5 ;
  skos:relatedMatch bkp:215_2 .

facp:FaCP-BRICK-SLIP skos:closeMatch bkp:215_5 ;
  skos:relatedMatch bkp:211 .
