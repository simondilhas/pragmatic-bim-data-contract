@prefix : <https://example.org/abstract/separator-wall-role-classification/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

:scheme a skos:ConceptScheme ;
  skos:prefLabel "Building Separator Wall Role Classification"@en ;
  skos:prefLabel "Klassifikation der Trennwandrollen"@de ;
  dcterms:title "Building Separator Wall Role Classification"@en ;
  dcterms:identifier "BuildingSeparatorWallRoleClassification" ;
  dcterms:creator "abstract" ;
  dcterms:issued "2026-06-02" ;
  dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
  skos:definition "Topological role classification for wall-based separating elements (SeparatorWall), derived from adjacent space relationships."@en ;
  skos:definition "Topologische Rollenklassifikation fuer wandbasierte Trennelemente (SeparatorWall), abgeleitet aus den angrenzenden Raumbeziehungen."@de ;
  skos:hasTopConcept :W_EXT, :W_INT .

:W_EXT a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "W-EXT" ;
  skos:prefLabel "Exterior wall"@en ;
  skos:prefLabel "Aussenwand"@de ;
  skos:definition "Wall separating conditioned or occupied space from the exterior environment."@en ;
  skos:definition "Wand, die konditionierten oder nutzbaren Raum von der Aussenumgebung trennt."@de ;
  skos:narrower :W_EXT_ABG, :W_EXT_BLG ;
  dcterms:description "Including facade and envelope walls where exterior separation drives requirements; subdivided by above- and below-ground position."@en ;
  dcterms:description "Einschliesslich Fassaden- und Huellenwaende, wenn die Aussenabgrenzung die Anforderungen bestimmt; unterteilt nach ober- und unterirdischer Lage."@de ;
  dcterms:subject "IfcWall" ;
  dcterms:identifier "W-EXT" .

:W_EXT_ABG a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "W-ABG" ;
  skos:prefLabel "Above ground wall"@en ;
  skos:prefLabel "Oberirdische Wand"@de ;
  skos:definition "Exterior wall above ground level separating conditioned or occupied space from the exterior environment."@en ;
  skos:definition "Aussenwand oberhalb der Gelaendehoehe, die konditionierten oder nutzbaren Raum von der Aussenumgebung trennt."@de ;
  dcterms:description "Including facade walls, curtain walls, parapet walls, and other above-grade envelope walls."@en ;
  dcterms:description "Einschliesslich Fassadenwaende, Vorhangfassaden, Attikawaende und andere oberirdische Huellenwaende."@de ;
  skos:broader :W_EXT ;
  dcterms:subject "IfcWall" ;
  dcterms:identifier "W-ABG" .

:W_EXT_BLG a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "W-BLG" ;
  skos:prefLabel "Below ground wall"@en ;
  skos:prefLabel "Unterirdische Wand"@de ;
  skos:definition "Exterior wall below ground level separating interior from earth or exterior below-grade conditions."@en ;
  skos:definition "Aussenwand unterhalb der Gelaendehoehe, die Innenraum von Erdreich oder aussenseitigen Untergeschossbedingungen trennt."@de ;
  dcterms:description "Including basement perimeter walls, retaining walls, and other below-grade envelope walls."@en ;
  dcterms:description "Einschliesslich Kellerumfassungswaende, Stuetzwaende und andere unterirdische Huellenwaende."@de ;
  skos:broader :W_EXT ;
  dcterms:subject "IfcWall" ;
  dcterms:identifier "W-BLG" .

:W_INT a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "W-INT" ;
  skos:prefLabel "Interior wall"@en ;
  skos:prefLabel "Innenwand"@de ;
  skos:definition "Interior wall whose primary role is defined by adjacent space topology."@en ;
  skos:definition "Innenwand, deren primaere Rolle durch die topologische Lage zu angrenzenden Raeumen bestimmt wird."@de ;
  skos:narrower :W_INT_CIR_VRT, :W_INT_CIR_HOR, :W_INT_UNT, :W_INT_SVC, :W_INT_GRD, :W_INT_PAR, :W_INT_PRT ;
  dcterms:subject "IfcWall" ;
  dcterms:identifier "W-INT" .

:W_INT_CIR_VRT a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "W-CIR-VRT" ;
  skos:prefLabel "Vertical circulation enclosure wall"@en ;
  skos:prefLabel "Treppenhauswand / Aufzugwand"@de ;
  skos:definition "Wall bounding a vertical circulation space."@en ;
  skos:definition "Wand, die einen vertikalen Erschliessungsraum begrenzt."@de ;
  dcterms:description "Including walls around staircases, elevator lobbies, escalator spaces, and ramps."@en ;
  dcterms:description "Einschliesslich Waende um Treppenhaeuser, Aufzugsfoyers, Rolltreppen und Rampen."@de ;
  skos:broader :W_INT ;
  dcterms:subject "IfcWall" ;
  dcterms:identifier "W-CIR-VRT" .

:W_INT_CIR_HOR a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "W-CIR-HOR" ;
  skos:prefLabel "Horizontal circulation enclosure wall"@en ;
  skos:prefLabel "Wand an horizontaler Erschliessung"@de ;
  skos:definition "Wall bounding a horizontal circulation space."@en ;
  skos:definition "Wand, die einen horizontalen Erschliessungsraum begrenzt."@de ;
  dcterms:description "Including corridor, hallway, bridge, and emergency exit route walls that are not primarily unit boundaries."@en ;
  dcterms:description "Einschliesslich Waende an Korridoren, Durchgaengen, Bruecken und Fluchtwegen, die nicht primaer Nutzungseinheitstrennwaende sind."@de ;
  skos:broader :W_INT ;
  dcterms:subject "IfcWall" ;
  dcterms:identifier "W-CIR-HOR" .

:W_INT_UNT a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "W-UNT" ;
  skos:prefLabel "Unit boundary wall"@en ;
  skos:prefLabel "Wohnungstrennwand"@de ;
  skos:definition "Wall separating independent occupancy or fire-compartment units."@en ;
  skos:definition "Wand, die selbstaendige Nutzungs- oder Brandabschnittseinheiten voneinander trennt."@de ;
  dcterms:description "Including walls between dwellings, between tenant units, or between a unit and common circulation where the unit boundary drives requirements."@en ;
  dcterms:description "Einschliesslich Waende zwischen Wohnungen, Mieteinheiten oder zwischen Einheit und gemeinsamer Erschliessung, wenn die Einheitstrennung die Anforderungen bestimmt."@de ;
  skos:broader :W_INT ;
  dcterms:subject "IfcWall" ;
  dcterms:identifier "W-UNT" .

:W_INT_SVC a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "W-SVC" ;
  skos:prefLabel "Service and shaft enclosure wall"@en ;
  skos:prefLabel "Technik- und Schachtwand"@de ;
  skos:definition "Wall bounding technical, utility, or void spaces."@en ;
  skos:definition "Wand, die Technik-, Versorgungs- oder Hohlraeume begrenzt."@de ;
  dcterms:description "Including walls around mechanical rooms, shafts, risers, and other support or void spaces."@en ;
  dcterms:description "Einschliesslich Waende um Technikraeume, Schaechte, Steigzonen und andere Unterstuetzungs- oder Hohlraeume."@de ;
  skos:broader :W_INT ;
  dcterms:subject "IfcWall" ;
  dcterms:identifier "W-SVC" .

:W_INT_GRD a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "W-GRD" ;
  skos:prefLabel "Below-grade enclosure wall"@en ;
  skos:prefLabel "Keller-Umfassungswand"@de ;
  skos:definition "Interior wall associated with below-grade or cellar perimeter conditions."@en ;
  skos:definition "Innenwand mit Bezug zu Keller- oder unterirdischen Randbedingungen."@de ;
  dcterms:description "Including cellar perimeter walls and retaining-related interior separations where below-grade context drives requirements."@en ;
  dcterms:description "Einschliesslich Kellerumfassungswaende und erdberuehrte Innentrennungen, wenn der Untergeschosskontext die Anforderungen bestimmt."@de ;
  skos:broader :W_INT ;
  dcterms:subject "IfcWall" ;
  dcterms:identifier "W-GRD" .

:W_INT_PAR a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "W-PAR" ;
  skos:prefLabel "Party wall"@en ;
  skos:prefLabel "Brandwand / Grenzwand"@de ;
  skos:definition "Wall separating this building from an adjacent building or legal plot boundary."@en ;
  skos:definition "Wand, die dieses Gebaeude von einem Nachbargebaeude oder einer rechtlichen Grundstuecksgrenze trennt."@de ;
  skos:broader :W_INT ;
  dcterms:subject "IfcWall" ;
  dcterms:identifier "W-PAR" .

:W_INT_PRT a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "W-PRT" ;
  skos:prefLabel "Internal partition wall"@en ;
  skos:prefLabel "Innere Trennwand"@de ;
  skos:definition "Wall separating spaces within the same occupancy unit."@en ;
  skos:definition "Wand, die Raeume innerhalb derselben Nutzungseinheit voneinander trennt."@de ;
  dcterms:description "Including room-to-room partitions where neither side is circulation, service, unit boundary, or exterior."@en ;
  dcterms:description "Einschliesslich Raum-zu-Raum-Trennwaende, wenn keine Seite Erschliessung, Technik, Einheitstrennung oder Aussenbereich ist."@de ;
  skos:broader :W_INT ;
  dcterms:subject "IfcWall" ;
  dcterms:identifier "W-PRT" .
