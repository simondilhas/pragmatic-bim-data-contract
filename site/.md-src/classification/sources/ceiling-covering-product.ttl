@prefix : <https://example.org/abstract/ceiling-covering-product/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

:scheme a skos:ConceptScheme ;
  skos:prefLabel "Abstract ceiling covering products"@en ;
  skos:prefLabel "Abstrakte Deckenbekleidungsprodukte"@de ;
  dcterms:title "Abstract ceiling covering products"@en ;
  dcterms:identifier "AbstractCeilingCoveringProduct" ;
  dcterms:creator "abstract" ;
  dcterms:issued "2026-06-30" ;
  dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
  dcterms:source <https://github.com/simondilhas/pragmatic-bim-data-contract> ;
  skos:definition "Product-type classification for ceiling linings and suspended ceiling systems. For catalog, specification, and cost workflows; pair with abstract material classification for dominant substance."@en ;
  skos:definition "Produkttyp-Klassifikation fuer Deckenbekleidungen und abgehaengte Deckensysteme. Fuer Katalog-, Spezifikations- und Kostenworkflows; mit abstrakter Materialklassifikation fuer dominante Substanz kombinieren."@de ;
  skos:scopeNote "Default PBS entity is Boundary with boundary_type ceiling (IfcCovering CEILING). Tags product or system type, not dominant substance alone."@en ;
  skos:scopeNote "Standard-PBS-Entitaet ist Boundary mit boundary_type ceiling (IfcCovering CEILING). Kennzeichnet Produkt- oder Systemtyp, nicht allein dominante Substanz."@de ;
  skos:hasTopConcept
    :CCP-METAL-SHEET,
    :CCP-GYPSUM-BOARD,
    :CCP-MINERAL-FIBRE,
    :CCP-WOOD,
    :CCP-SYNTHETIC,
    :CCP-METAL-PANEL,
    :CCP-METAL-GRID,
    :CCP-OTH .

:CCP-METAL-SHEET a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "CCP-METAL-SHEET" ;
  skos:prefLabel "Metal sheet ceiling"@en ;
  skos:prefLabel "Metallblech-Deckenbekleidung"@de ;
  skos:definition "Metal sheet or strip ceiling lining."@en ;
  skos:definition "Metallblech- oder -streifen-Deckenbekleidung."@de ;
  dcterms:subject "IfcCovering" ;
  dcterms:identifier "metal-sheet-ceiling" .

:CCP-GYPSUM-BOARD a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "CCP-GYPSUM-BOARD" ;
  skos:prefLabel "Gypsum board ceiling"@en ;
  skos:prefLabel "Gipskarton-Decke"@de ;
  skos:definition "Gypsum board or plasterboard ceiling lining or suspended ceiling."@en ;
  skos:definition "Gipskarton-Deckenbekleidung oder abgehaengte GK-Decke."@de ;
  dcterms:subject "IfcCovering" ;
  dcterms:identifier "gypsum-board-ceiling" .

:CCP-MINERAL-FIBRE a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "CCP-MINERAL-FIBRE" ;
  skos:prefLabel "Mineral-fibre acoustic ceiling"@en ;
  skos:prefLabel "Mineralfaser-Akustikdecke"@de ;
  skos:definition "Mineral-fibre acoustic ceiling tile or board system."@en ;
  skos:definition "Mineralfaser-Akustikplatten- oder -paneelsystem."@de ;
  dcterms:subject "IfcCovering" ;
  dcterms:identifier "mineral-fibre-ceiling" .

:CCP-WOOD a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "CCP-WOOD" ;
  skos:prefLabel "Wood ceiling lining"@en ;
  skos:prefLabel "Holz-Deckenbekleidung"@de ;
  skos:definition "Wood or wood-composite ceiling lining or panel system."@en ;
  skos:definition "Holz- oder Holzwerkstoff-Deckenbekleidung oder Paneelsystem."@de ;
  dcterms:subject "IfcCovering" ;
  dcterms:identifier "wood-ceiling" .

:CCP-SYNTHETIC a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "CCP-SYNTHETIC" ;
  skos:prefLabel "Synthetic ceiling lining"@en ;
  skos:prefLabel "Kunststoff-Deckenbekleidung"@de ;
  skos:definition "Plastic, textile, or synthetic ceiling lining or membrane."@en ;
  skos:definition "Kunststoff-, Textil- oder synthetische Deckenbekleidung oder Membran."@de ;
  dcterms:subject "IfcCovering" ;
  dcterms:identifier "synthetic-ceiling" .

:CCP-METAL-PANEL a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "CCP-METAL-PANEL" ;
  skos:prefLabel "Metal panel ceiling"@en ;
  skos:prefLabel "Metallpaneel-Decke"@de ;
  skos:definition "Metal panel or lamella ceiling system."@en ;
  skos:definition "Metallpaneel- oder Lamellendekensystem."@de ;
  dcterms:subject "IfcCovering" ;
  dcterms:identifier "metal-panel-ceiling" .

:CCP-METAL-GRID a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "CCP-METAL-GRID" ;
  skos:prefLabel "Metal grid ceiling"@en ;
  skos:prefLabel "Metallraster-Decke"@de ;
  skos:definition "Metal grid or lay-in suspended ceiling with removable tiles."@en ;
  skos:definition "Metallraster- oder Einlege-Decke mit abnehmbaren Platten."@de ;
  dcterms:subject "IfcCovering" ;
  dcterms:identifier "metal-grid-ceiling" .

:CCP-OTH a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "CCP-OTH" ;
  skos:prefLabel "Other / unknown ceiling covering"@en ;
  skos:prefLabel "Sonstige / unbekannte Deckenbekleidung"@de ;
  skos:definition "Ceiling covering product not classified or not yet known."@en ;
  skos:definition "Deckenbekleidungsprodukt nicht klassifiziert oder noch unbekannt."@de ;
  skos:scopeNote "Fallback for early design stages or missing data."@en ;
  skos:scopeNote "Fallback fuer fruehe Entwurfsstufen oder fehlende Daten."@de ;
  dcterms:subject "IfcCovering" ;
  dcterms:identifier "other" .
