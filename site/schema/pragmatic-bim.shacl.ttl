pbs:Project a sh:NodeShape ;
    rdfs:comment "Business delivery scope for spatial context, systems, and workflow entities." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class pbs:LocalizedText ;
            sh:description "Localized variants of description." ;
