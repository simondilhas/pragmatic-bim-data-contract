pbs:Task a sh:NodeShape ;
    rdfs:comment """Task entity for implementation and follow-up workflows. Entity.status covers lifecycle; task_status uses action status vocabulary URIs. Links to related entities via applies_to_entities.
""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Unique local identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path pbs:id ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp for this entity record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path pbs:created_at ],
        [ sh:datatype xsd:string ;
            sh:description "Entity type discriminator for adapter projection and querying. Must be a ContentKind value." ;
            sh:in ( "task" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path pbs:content_kind ],
        [ sh:datatype xsd:integer ;
            sh:description "Integer revision counter for change tracking." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path pbs:revision ],
        [ sh:class pbs:LocalizedText ;
            sh:description "Localized variants of name." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path pbs:localized_names ],
        [ sh:description "Lifecycle or QA status." ;
            sh:in ( pbs:status_draft pbs:status_submitted pbs:status_reviewed pbs:status_approved pbs:status_rejected pbs:status_archived ) ;
            sh:maxCount 1 ;
            sh:order 24 ;
            sh:path pbs:status ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Last modification timestamp for this entity record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path pbs:modified_at ],
        [ sh:class pbs:PerformanceProperty ;
            sh:description """Normalized, strongly typed domain properties (fire/acoustic/thermal/structural/ security/material) extracted from raw IFC PropertySet values.
""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path pbs:performance_properties ],
        [ sh:class pbs:LocalizedText ;
            sh:description "Localized variants of description." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path pbs:localized_descriptions ],
        [ sh:datatype xsd:string ;
            sh:description "Additional notes or implementation details for the task." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path rdfs:comment ],
        [ sh:description "Task status URI/CURIE aligned with action status vocabularies." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path schema:actionStatus ],
        [ sh:class pbs:QuantityValue ;
            sh:description "Quantities associated with the entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path pbs:quantity_values ],
        [ sh:class pbs:MetadataEntry ;
            sh:description "Generic metadata container for IFC attributes/properties and project-specific extensions." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path pbs:metadata ],
        [ sh:class pbs:Classification ;
            sh:description "Classification entries from IFC and other schemes." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path pbs:classifications ],
        [ sh:datatype xsd:string ;
            sh:description "Default display name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path pbs:name ],
        [ sh:description "Task type expressed as a URI/CURIE from a controlled vocabulary." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path dcterms:type ],
        [ sh:class pbs:Decision ;
            sh:description "Optional reference to a decision that informs or drives this task." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path prov:used ],
        [ sh:class pbs:Entity ;
            sh:description "Model entities this record applies to (requirements, cost items, schedule items, etc.)." ;
            sh:nodeKind sh:IRI ;
            sh:order 20 ;
            sh:path pbs:applies_to_entities ],
