pbs:TimeLink a sh:NodeShape ;
    rdfs:comment "Inline typed precedence link from a TimeRecord to one successor. Not a VirtualEntity — no id, no mixin. Owned by the predecessor record." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:integer ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path pbs:lag_days ],
        [ sh:class pbs:TimeRecord ;
            sh:description "The successor TimeRecord." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path pbs:target_item ],
        [ sh:defaultValue "FS" ;
            sh:description "FS | SS | FF | SF" ;
            sh:in ( pbs:dependency_type_finish_to_start pbs:dependency_type_start_to_start pbs:dependency_type_finish_to_finish pbs:dependency_type_start_to_finish ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path pbs:dependency_type ] ;
    sh:targetClass pbs:TimeLink .

