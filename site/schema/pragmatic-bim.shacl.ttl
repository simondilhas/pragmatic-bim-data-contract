            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path pbs:id ],
        [ sh:class pbs:Material ;
            sh:description "Material of the opening infill within the frame (for example glazing for windows, door leaf or panel for doors). Applies to opening-type connectors (door, window)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path pbs:infill_material ],
        [ sh:class pbs:Material ;
            sh:description "Material of the frame or casing surrounding the opening. Applies to opening-type connectors (door, window)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
