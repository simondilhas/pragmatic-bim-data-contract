            sh:pattern "^[0-3][0-9A-Za-z_$]{21}$" ],
        [ sh:description "Classification of physical connector type (for example door, window, duct, pipe, cable)." ;
            sh:in ( ifcowl:IfcDoor ifcowl:IfcWindow ifcowl:IfcDuctSegment ifcowl:IfcPipeSegment ifcowl:IfcCableSegment ifcowl:IfcConduitSegment ifcowl:IfcOpeningElement ifcowl:IfcFlowSegment ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path pbs:connection_physical_type ],
        [ sh:class pbs:LevelContext ;
            sh:description "Parent level/storey context reference." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path pbs:parent_level ] ;
    sh:targetClass pbs:ConnectionPhysical .

