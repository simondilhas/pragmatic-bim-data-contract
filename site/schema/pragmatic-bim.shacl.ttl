        [ sh:class pbs:MetadataEntry ;
            sh:description "Generic metadata container for IFC attributes/properties and project-specific extensions." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path pbs:metadata ],
        [ sh:datatype xsd:string ;
            sh:description "Criteria that define when the deliverable is accepted." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path pbs:acceptance_criteria ],
        [ sh:class pbs:Artifact ;
            sh:description "Optional source artifact backing this requirement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path pbs:source_artifact ],
        [ sh:datatype xsd:integer ;
            sh:description "Integer revision counter for change tracking." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path pbs:revision ],
        [ sh:class pbs:PerformanceProperty ;
            sh:description """Normalized, strongly typed domain properties (fire/acoustic/thermal/structural/ security/material) extracted from raw IFC PropertySet values.
""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path pbs:performance_properties ],
        [ sh:datatype xsd:string ;
            sh:description "IFC GlobalId of the mapped entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path pbs:ifc_global_id ;
            sh:pattern "^[0-3][0-9A-Za-z_$]{21}$" ],
        [ sh:class pbs:Classification ;
            sh:description "Classification entries from IFC and other schemes." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path pbs:classifications ],
        [ sh:datatype xsd:string ;
            sh:description "Default display name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path pbs:name ],
        [ sh:class pbs:LocalizedText ;
            sh:description "Localized variants of name." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path pbs:localized_names ],
        [ sh:datatype xsd:string ;
            sh:description "Required deliverable format or encoding (for example IFC4, PDF, COBie)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path pbs:deliverable_format ],
        [ sh:class pbs:LocalizedText ;
            sh:description "Localized variants of description." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path pbs:localized_descriptions ],
        [ sh:datatype xsd:string ;
            sh:description "Deliverable type label (for example coordination model, O&M manual, as-built record)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path pbs:deliverable_kind ],
        [ sh:description "Optional semantic URI for linking the entity instance to an external ontology concept." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path pbs:meaning_uri ],
        [ sh:class pbs:QuantityValue ;
            sh:description "Quantities associated with the entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path pbs:quantity_values ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Last modification timestamp for this entity record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path pbs:modified_at ],
        [ sh:datatype xsd:string ;
            sh:description "Default description text." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path pbs:description ] ;
    sh:targetClass pbs:DeliverableRequirement .

pbs:Equipment a sh:NodeShape ;
    rdfs:comment "Endpoint or device element (for example terminal, unit, control device, sensor) located in a space and assigned to a system." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class pbs:Classification ;
            sh:description "Classification entries from IFC and other schemes." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path pbs:classifications ],
        [ sh:class pbs:QuantityValue ;
            sh:description "Quantities associated with the entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path pbs:quantity_values ],
        [ sh:class pbs:LocalizedText ;
            sh:description "Localized variants of description." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path pbs:localized_descriptions ],
        [ sh:class pbs:MetadataEntry ;
            sh:description "Generic metadata container for IFC attributes/properties and project-specific extensions." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path pbs:metadata ],
        [ sh:datatype xsd:string ;
            sh:description "Default description text." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path pbs:description ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Last modification timestamp for this entity record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path pbs:modified_at ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp for this entity record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path pbs:created_at ],
        [ sh:class pbs:PerformanceProperty ;
            sh:description """Normalized, strongly typed domain properties (fire/acoustic/thermal/structural/ security/material) extracted from raw IFC PropertySet values.
""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path pbs:performance_properties ],
        [ sh:datatype xsd:string ;
            sh:description "Entity type discriminator for adapter projection and querying. Must be a ContentKind value." ;
            sh:in ( "physical" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path pbs:content_kind ],
        [ sh:class pbs:GeometryRepresentation ;
            sh:description """Geometry references associated with the entity. A single element may link to multiple geometry representations to serve different intents (authoring, coordination, analysis, visualization) without duplicating the element itself.
""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path pbs:geometry_representations ],
        [ sh:description "Classification of equipment (for example HVAC, electrical, plumbing)." ;
            sh:in ( ifcowl:IfcDistributionElement ifcowl:IfcElectricalElement ifcowl:IfcFlowTerminal ifcowl:IfcFireSuppressionTerminal ifcowl:IfcDistributionControlElement ifcowl:IfcFurniture ifcowl:IfcElement ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path pbs:equipment_type ],
        [ sh:class pbs:LocalizedText ;
            sh:description "Localized variants of name." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path pbs:localized_names ],
        [ sh:datatype xsd:string ;
            sh:description "IFC GlobalId of the mapped entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path pbs:ifc_global_id ;
            sh:pattern "^[0-3][0-9A-Za-z_$]{21}$" ],
        [ sh:datatype xsd:integer ;
            sh:description "Integer revision counter for change tracking." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path pbs:revision ],
        [ sh:class pbs:BuiltAssetContext ;
            sh:description "Parent building context reference." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path pbs:parent_building ],
        [ sh:description "Optional semantic URI for linking the entity instance to an external ontology concept." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path pbs:meaning_uri ],
        [ sh:class pbs:Space ;
            sh:description "Parent space where the equipment is located." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path pbs:parent_space ],
        [ sh:class pbs:Entity ;
            sh:description "Model entities this record applies to (requirements, cost items, schedule items, etc.)." ;
            sh:nodeKind sh:IRI ;
            sh:order 18 ;
            sh:path pbs:applies_to_entities ],
        [ sh:datatype xsd:string ;
            sh:description "Default display name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path pbs:name ],
        [ sh:class pbs:LevelContext ;
            sh:description "Parent level/storey context reference." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path pbs:parent_level ],
        [ sh:datatype xsd:string ;
            sh:description "Unique local identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path pbs:id ],
        [ sh:description "Lifecycle or QA status." ;
            sh:in ( pbs:status_draft pbs:status_submitted pbs:status_reviewed pbs:status_approved pbs:status_rejected pbs:status_archived ) ;
            sh:maxCount 1 ;
            sh:order 22 ;
            sh:path pbs:status ],
        [ sh:class pbs:System ;
            sh:description "Parent systems that the equipment belongs to." ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path pbs:parent_system ] ;
    sh:targetClass pbs:Equipment .

pbs:FireProperty a sh:NodeShape ;
    rdfs:comment "Normalized fire-related property." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Normalized unit where applicable (for example min, dB, W/m2K)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path pbs:property_unit ],
        [ sh:datatype xsd:string ;
            sh:description "Original IFC PropertySet name (for example Pset_WallCommon)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path pbs:source_pset ],
        [ sh:datatype xsd:boolean ;
            sh:description "Boolean value when property_value_type is boolean." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path pbs:property_value_boolean ],
        [ sh:datatype xsd:string ;
            sh:description "Mapping specification version used to derive the normalized property." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path pbs:mapping_version ],
        [ sh:datatype xsd:string ;
            sh:description "String value when property_value_type is string." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path pbs:property_value_string ],
        [ sh:datatype xsd:string ;
            sh:description "Raw source value before normalization." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path pbs:source_value_raw ],
        [ sh:description "Optional URI that identifies the normalized property unit in an external vocabulary such as QUDT." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path pbs:property_unit_uri ],
        [ sh:datatype xsd:double ;
            sh:description "Numeric value when property_value_type is number." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path pbs:property_value_number ],
        [ sh:description "Value type discriminator for normalized storage (for example string, number, boolean)." ;
            sh:in ( pbs:performance_property_value_type_string pbs:performance_property_value_type_number pbs:performance_property_value_type_boolean ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path pbs:property_value_type ],
        [ sh:description "Canonical key inside the domain; constrained via subclass slot_usage to a domain-specific enum." ;
            sh:in ( pbs:fire_property_resistance_rating pbs:fire_property_smoke_rating pbs:fire_property_reaction_to_fire ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path pbs:property_key ],
        [ sh:datatype xsd:string ;
            sh:description "Original property name inside the source PropertySet (for example FireRating)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path pbs:source_property ] ;
    sh:targetClass pbs:FireProperty .

pbs:GeometryChange a sh:NodeShape ;
    rdfs:comment "Geometry or representation change for a subject." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class pbs:Process ;
            sh:description "BPMN process instance that this change triggered or should trigger." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 14 ;
            sh:path pbs:triggered_process ],
        [ sh:datatype xsd:string ;
            sh:description """LinkML class name of the changed subject (for example Space, SeparatorWall, Artifact).
""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path pbs:affected_subject_type ],
        [ sh:datatype xsd:integer ;
            sh:description "Target revision number for this change." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path pbs:to_revision ],
        [ sh:datatype xsd:string ;
            sh:description "Unique local identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path pbs:id ],
        [ sh:description "Optional severity independent of change type." ;
            sh:in ( pbs:change_severity_unchanged pbs:change_severity_minor pbs:change_severity_major pbs:change_severity_rewritten ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path pbs:change_severity ],
        [ sh:class pbs:Task ;
            sh:description "Task entity that this change triggered or should trigger." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 13 ;
            sh:path pbs:triggered_task ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Timestamp when this change was detected." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path dcterms:created ],
        [ sh:description "URI identifying the tool or pipeline that produced this change record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 16 ;
            sh:path pbs:change_source ],
        [ sh:description "Geometry role affected for GeometryChange records." ;
            sh:in ( "axis" "body_3d" "footprint_2d" "point" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path pbs:affected_geometry_role ],
        [ sh:datatype xsd:string ;
            sh:description "Identifier of the changed subject (entity id, document id, or external key)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path pbs:affected_subject_id ],
        [ sh:datatype xsd:string ;
            sh:description "IFC GlobalId of the mapped entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path pbs:ifc_global_id ;
            sh:pattern "^[0-3][0-9A-Za-z_$]{21}$" ],
        [ sh:datatype xsd:integer ;
            sh:description "Source revision number for this change." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path pbs:from_revision ],
        [ sh:class pbs:Entity ;
            sh:description "Optional typed reference to the changed graph entity when the subject is in the project graph." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path pbs:affected_subject ],
        [ sh:description "Intent stability verdict from an automated judge (for example iterthink STABLE/NEW)." ;
            sh:in ( pbs:change_intent_verdict_stable pbs:change_intent_verdict_new_intent ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path pbs:intent_verdict ],
        [ sh:description "Category of change detected between two revisions." ;
            sh:in ( pbs:change_type_geometry_change pbs:change_type_property_change pbs:change_type_requirement_change pbs:change_type_match_change pbs:change_type_addition pbs:change_type_deletion ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path pbs:change_type ],
        [ sh:description "Artifact location when the subject is an Artifact entity or embedded field diff." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path pbs:artifact_storage_link ],
        [ sh:datatype xsd:string ;
            sh:description """Optional JSON-pointer-style path for nested targets (for example localized_descriptions[de], section.4.2.paragraph_1).
""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path pbs:affected_subject_path ] ;
    sh:targetClass pbs:GeometryChange .

pbs:MatchChange a sh:NodeShape ;
    rdfs:comment """Entity match status against a requirement changed (previously met / no longer meets).
""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "URI identifying the tool or pipeline that produced this change record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 17 ;
            sh:path pbs:change_source ],
        [ sh:description "Whether the subject met the requirement at the target revision." ;
            sh:in ( pbs:match_status_met pbs:match_status_unmet pbs:match_status_unknown ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path pbs:match_status ],
        [ sh:class pbs:Requirement ;
            sh:description "Requirement entity for match_change records." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path pbs:related_requirement ],
        [ sh:datatype xsd:string ;
            sh:description "Identifier of the changed subject (entity id, document id, or external key)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path pbs:affected_subject_id ],
        [ sh:datatype xsd:string ;
            sh:description """LinkML class name of the changed subject (for example Space, SeparatorWall, Artifact).
""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path pbs:affected_subject_type ],
        [ sh:datatype xsd:integer ;
            sh:description "Target revision number for this change." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path pbs:to_revision ],
        [ sh:description "Intent stability verdict from an automated judge (for example iterthink STABLE/NEW)." ;
            sh:in ( pbs:change_intent_verdict_stable pbs:change_intent_verdict_new_intent ) ;
            sh:maxCount 1 ;
            sh:order 5 ;
            sh:path pbs:intent_verdict ],
        [ sh:datatype xsd:string ;
            sh:description "Unique local identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path pbs:id ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Timestamp when this change was detected." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path dcterms:created ],
        [ sh:description "Category of change detected between two revisions." ;
            sh:in ( pbs:change_type_geometry_change pbs:change_type_property_change pbs:change_type_requirement_change pbs:change_type_match_change pbs:change_type_addition pbs:change_type_deletion ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 3 ;
            sh:path pbs:change_type ],
        [ sh:datatype xsd:integer ;
            sh:description "Source revision number for this change." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path pbs:from_revision ],
        [ sh:datatype xsd:string ;
            sh:description """Optional JSON-pointer-style path for nested targets (for example localized_descriptions[de], section.4.2.paragraph_1).
""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path pbs:affected_subject_path ],
        [ sh:datatype xsd:string ;
            sh:description "IFC GlobalId of the mapped entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path pbs:ifc_global_id ;
            sh:pattern "^[0-3][0-9A-Za-z_$]{21}$" ],
        [ sh:class pbs:Entity ;
            sh:description "Optional typed reference to the changed graph entity when the subject is in the project graph." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path pbs:affected_subject ],
        [ sh:class pbs:Task ;
            sh:description "Task entity that this change triggered or should trigger." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 14 ;
            sh:path pbs:triggered_task ],
        [ sh:description "Artifact location when the subject is an Artifact entity or embedded field diff." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 11 ;
            sh:path pbs:artifact_storage_link ],
        [ sh:description "Optional severity independent of change type." ;
            sh:in ( pbs:change_severity_unchanged pbs:change_severity_minor pbs:change_severity_major pbs:change_severity_rewritten ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path pbs:change_severity ],
        [ sh:class pbs:Process ;
            sh:description "BPMN process instance that this change triggered or should trigger." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 15 ;
            sh:path pbs:triggered_process ] ;
    sh:targetClass pbs:MatchChange .

pbs:MaterialProperty a sh:NodeShape ;
    rdfs:comment "Normalized material-related property." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Raw source value before normalization." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path pbs:source_value_raw ],
        [ sh:datatype xsd:double ;
            sh:description "Numeric value when property_value_type is number." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path pbs:property_value_number ],
        [ sh:description "Value type discriminator for normalized storage (for example string, number, boolean)." ;
            sh:in ( pbs:performance_property_value_type_string pbs:performance_property_value_type_number pbs:performance_property_value_type_boolean ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path pbs:property_value_type ],
        [ sh:datatype xsd:boolean ;
            sh:description "Boolean value when property_value_type is boolean." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path pbs:property_value_boolean ],
        [ sh:datatype xsd:string ;
            sh:description "String value when property_value_type is string." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path pbs:property_value_string ],
        [ sh:datatype xsd:string ;
            sh:description "Mapping specification version used to derive the normalized property." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path pbs:mapping_version ],
        [ sh:description "Optional URI that identifies the normalized property unit in an external vocabulary such as QUDT." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path pbs:property_unit_uri ],
        [ sh:datatype xsd:string ;
            sh:description "Original IFC PropertySet name (for example Pset_WallCommon)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path pbs:source_pset ],
        [ sh:datatype xsd:string ;
            sh:description "Normalized unit where applicable (for example min, dB, W/m2K)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path pbs:property_unit ],
        [ sh:description "Canonical key inside the domain; constrained via subclass slot_usage to a domain-specific enum." ;
            sh:in ( pbs:material_property_name pbs:material_property_class pbs:material_property_density pbs:material_property_thermal_conductivity ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path pbs:property_key ],
        [ sh:datatype xsd:string ;
            sh:description "Original property name inside the source PropertySet (for example FireRating)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path pbs:source_property ] ;
    sh:targetClass pbs:MaterialProperty .

pbs:MaterialRequirement a sh:NodeShape ;
    rdfs:comment "Material or product specification requirement for matching against assigned materials." ;
    sh:closed true ;
