        [ sh:datatype xsd:string ;
            sh:description "String value when property_value_type is string." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path pbs:property_value_string ] ;
    sh:targetClass pbs:ThermalProperty .

pbs:VirtualEntity a sh:NodeShape ;
    rdfs:comment "Abstract base class for non-physical, conceptual, or informational entities." ;
    sh:closed false ;
    sh:ignoredProperties ( pbs:currency pbs:priced_for_customer pbs:actual_finish_at pbs:material_specification pbs:context_type pbs:system_type pbs:parent_zone pbs:is_above_ground pbs:component_cost_items rdf:type pbs:related_product pbs:planned_start_at pbs:is_heated pbs:milestone_at pbs:parent_perimeter pbs:actual_start_at pbs:bounded_by pbs:time_plan pbs:parent_project pbs:serves_spaces pbs:system_discipline pbs:connects_spaces pbs:planned_finish_at pbs:is_cooled pbs:zone_type pbs:parent_level pbs:connection_virtual_type pbs:serves_zones pbs:material_category pbs:space_type pbs:contained_entities pbs:elevation pbs:cost_quantity_type pbs:parent_legal_site pbs:elevation_unit pbs:connection_virtual_requirement_drivers pbs:successors pbs:cost_record_role pbs:component_time_items pbs:cost_category pbs:group_members pbs:space_name_type pbs:connects_physical_elements pbs:unit_cost pbs:cost_quantity_unit pbs:parent_building pbs:cost_quantity_value ) ;
