pbs:ConsentRecord a sh:NodeShape ;
    rdfs:comment "Record of lawful basis, scope, and lifecycle for processing personal data on a Person." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Lawful basis for processing the scoped personal data categories." ;
            sh:in ( pbs:lawful_basis_consent pbs:lawful_basis_contract pbs:lawful_basis_legal_obligation pbs:lawful_basis_vital_interest pbs:lawful_basis_public_task pbs:lawful_basis_legitimate_interest ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path pbs:lawful_basis ],
        [ sh:description "Personal data categories covered by this consent or processing record." ;
            sh:in ( pbs:personal_data_category_identity pbs:personal_data_category_contact pbs:personal_data_category_address pbs:personal_data_category_affiliation ) ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path pbs:data_categories ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Timestamp when consent was withdrawn, if applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path pbs:withdrawn_at ],
        [ sh:datatype xsd:string ;
            sh:description "Human-readable purpose for which the personal data categories are processed." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path pbs:processing_purpose ],
        [ sh:description "URI of the current or default privacy policy or notice applicable to this person record." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path pbs:privacy_policy_uri ],
        [ sh:datatype xsd:string ;
