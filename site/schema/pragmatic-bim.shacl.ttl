            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path pbs:modified_at ] ;
    sh:targetClass pbs:Material .

pbs:TimeRecord a sh:NodeShape ;
    rdfs:comment "Planned work record with baseline and actual dates, optionally linked to model entities and a time plan. — Set milestone_at to mark as a zero-duration checkpoint. — Populate component_time_items to act as a plan container." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:dateTime ;
            sh:description "Actual start timestamp for the time record where known." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path pbs:actual_start_at ],
        [ sh:class pbs:TimeLink ;
            sh:description "Forward precedence links to successor records. Reverse lookup (find all predecessors of X) requires scanning all TimeRecord.successors — acceptable for document exchange, not for live graph queries." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path pbs:successors ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Planned finish timestamp for the time record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path pbs:planned_finish_at ],
        [ sh:class pbs:Classification ;
            sh:description "Classification entries from IFC and other schemes." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 20 ;
            sh:path pbs:classifications ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Planned start timestamp for the time record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path pbs:planned_start_at ],
        [ sh:class pbs:Entity ;
            sh:description "Model entities this record applies to (requirements, cost items, schedule items, etc.)." ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path pbs:applies_to_entities ],
        [ sh:class pbs:GeometryRepresentation ;
            sh:description """Geometry references associated with the entity. A single element may link to multiple geometry representations to serve different intents (authoring, coordination, analysis, visualization) without duplicating the element itself.
""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path pbs:geometry_representations ],
        [ sh:class pbs:LocalizedText ;
            sh:description "Localized variants of name." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path pbs:localized_names ],
        [ sh:description "Optional semantic URI for linking the entity instance to an external ontology concept." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 17 ;
            sh:path pbs:meaning_uri ],
        [ sh:class pbs:LocalizedText ;
            sh:description "Localized variants of description." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path pbs:localized_descriptions ],
        [ sh:datatype xsd:string ;
            sh:description "Unique local identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path pbs:id ],
        [ sh:class pbs:QuantityValue ;
            sh:description "Quantities associated with the entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 22 ;
            sh:path pbs:quantity_values ],
        [ sh:datatype xsd:string ;
            sh:description "IFC GlobalId of the mapped entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path pbs:ifc_global_id ;
            sh:pattern "^[0-3][0-9A-Za-z_$]{21}$" ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Actual finish timestamp for the time record where known." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path pbs:actual_finish_at ],
        [ sh:class pbs:TimeRecord ;
            sh:description "Time records associated with this entity." ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path pbs:time_records ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Last modification timestamp for this entity record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 26 ;
            sh:path pbs:modified_at ],
        [ sh:class pbs:MetadataEntry ;
            sh:description "Generic metadata container for IFC attributes/properties and project-specific extensions." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 23 ;
            sh:path pbs:metadata ],
        [ sh:datatype xsd:string ;
            sh:description "Default description text." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path pbs:description ],
        [ sh:class pbs:PerformanceProperty ;
            sh:description """Normalized, strongly typed domain properties (fire/acoustic/thermal/structural/ security/material) extracted from raw IFC PropertySet values.
""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 24 ;
            sh:path pbs:performance_properties ],
        [ sh:datatype xsd:string ;
            sh:description "Entity type discriminator for adapter projection and querying. Must be a ContentKind value." ;
            sh:in ( "virtual" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path pbs:content_kind ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp for this entity record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 25 ;
            sh:path pbs:created_at ],
        [ sh:class pbs:CostRecord ;
            sh:description "Cost records associated with this entity." ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path pbs:cost_records ],
        [ sh:description "Lifecycle or QA status." ;
            sh:in ( pbs:status_draft pbs:status_submitted pbs:status_reviewed pbs:status_approved pbs:status_rejected pbs:status_archived ) ;
            sh:maxCount 1 ;
            sh:order 28 ;
            sh:path pbs:status ],
        [ sh:datatype xsd:integer ;
            sh:description "Integer revision counter for change tracking." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 27 ;
            sh:path pbs:revision ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Target timestamp for a zero-duration milestone checkpoint." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path pbs:milestone_at ],
        [ sh:class pbs:TimeRecord ;
            sh:description "Time records contained in this plan; set milestone_at on a record to mark it as a checkpoint." ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path pbs:component_time_items ],
        [ sh:class pbs:Material ;
            sh:description "Material definitions associated with this entity." ;
            sh:nodeKind sh:IRI ;
            sh:order 11 ;
            sh:path pbs:materials ],
        [ sh:datatype xsd:string ;
            sh:description "Default display name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path pbs:name ],
        [ sh:class pbs:TimeRecord ;
            sh:description "Parent time plan this record belongs to." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path pbs:time_plan ] ;
    sh:targetClass pbs:TimeRecord .

pbs:Classification a sh:NodeShape ;
    rdfs:comment "Generic classification entry from any scheme (for example IFC, Uniclass, OmniClass, custom)." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Name of the classification scheme (for example ifc, uniclass, omniclass, custom)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path pbs:classification_scheme ],
        [ sh:datatype xsd:string ;
            sh:description "Classification code inside the scheme." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path pbs:classification_code ],
        [ sh:datatype xsd:string ;
            sh:description "Optional scheme/version identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path pbs:classification_version ],
        [ sh:datatype xsd:string ;
            sh:description "Source authority or dataset for this classification." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path pbs:classification_source ],
        [ sh:datatype xsd:string ;
            sh:description "Optional human-readable classification label." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path pbs:classification_label ],
        [ sh:description "Optional URI/CURIE that identifies the classification concept in an external registry." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path pbs:classification_uri ] ;
    sh:targetClass pbs:Classification .

pbs:GeometryRepresentation a sh:NodeShape ;
    rdfs:comment "Minimal geometry reference for an entity, separating representation from encoding format." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Representation kind/dimension (for example body_3d, footprint_2d, point), independent of file format." ;
            sh:in ( "axis" "body_3d" "footprint_2d" "point" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path pbs:geometry_representation ],
        [ sh:datatype xsd:string ;
            sh:description "URI/path/hash/pointer to geometry payload." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path pbs:geometry_reference ],
        [ sh:datatype xsd:string ;
            sh:description "Optional serialization/encoding format (for example ifc, gltf, wkt, geojson), independent of representation kind." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path pbs:geometry_format ] ;
    sh:targetClass pbs:GeometryRepresentation .

pbs:MetadataEntry a sh:NodeShape ;
    rdfs:comment "Generic metadata entry for storing IFC attributes, PropertySet fields, or project-specific key-value data." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Metadata value serialized as text." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path pbs:metadata_value ],
        [ sh:datatype xsd:string ;
            sh:description "Metadata key, for example IfcWall.FireRating or Pset_WallCommon.Reference." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path pbs:metadata_key ] ;
    sh:targetClass pbs:MetadataEntry .

pbs:PerformanceProperty a sh:NodeShape ;
    rdfs:comment """Normalized performance/property record derived from raw IFC PropertySet values with source traceability and strong typing through domain-specific subclasses.
""" ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:double ;
            sh:description "Numeric value when property_value_type is number." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path pbs:property_value_number ],
        [ sh:datatype xsd:string ;
            sh:description "Original property name inside the source PropertySet (for example FireRating)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path pbs:source_property ],
        [ sh:datatype xsd:string ;
            sh:description "Canonical key inside the domain; constrained via subclass slot_usage to a domain-specific enum." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path pbs:property_key ],
        [ sh:datatype xsd:string ;
            sh:description "String value when property_value_type is string." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path pbs:property_value_string ],
        [ sh:description "Value type discriminator for normalized storage (for example string, number, boolean)." ;
            sh:in ( pbs:performance_property_value_type_string pbs:performance_property_value_type_number pbs:performance_property_value_type_boolean ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path pbs:property_value_type ],
        [ sh:datatype xsd:boolean ;
            sh:description "Boolean value when property_value_type is boolean." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path pbs:property_value_boolean ],
        [ sh:datatype xsd:string ;
            sh:description "Normalized unit where applicable (for example min, dB, W/m2K)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path pbs:property_unit ],
        [ sh:datatype xsd:string ;
            sh:description "Original IFC PropertySet name (for example Pset_WallCommon)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path pbs:source_pset ],
        [ sh:datatype xsd:string ;
            sh:description "Mapping specification version used to derive the normalized property." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path pbs:mapping_version ],
        [ sh:description "Optional URI that identifies the normalized property unit in an external vocabulary such as QUDT." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path pbs:property_unit_uri ],
        [ sh:datatype xsd:string ;
            sh:description "Raw source value before normalization." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path pbs:source_value_raw ] ;
    sh:targetClass pbs:PerformanceProperty .

pbs:QuantityValue a sh:NodeShape ;
    rdfs:comment "Minimal quantity record for costing and analysis." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Vocabulary scheme identifier for the measured concept: AbstractBuildingMetric or AbstractBuildingRatio." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path pbs:metric_scheme ],
        [ sh:description "Concept URI from building-metrics.skos.ttl or building-ratios.skos.ttl." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path pbs:metric_uri ],
        [ sh:description "Controlled quantity type." ;
            sh:in ( ifcowl:IfcQuantityArea ifcowl:IfcQuantityArea ifcowl:IfcQuantityArea ifcowl:IfcQuantityArea ifcowl:IfcQuantityVolume ifcowl:IfcQuantityVolume ifcowl:IfcQuantityLength ifcowl:IfcQuantityLength ifcowl:IfcQuantityLength ifcowl:IfcQuantityLength pbs:quantity_type_count pbs:quantity_type_ratio ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path pbs:quantity_type ],
        [ sh:description "Optional URI that identifies the quantity unit in an external vocabulary such as QUDT." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path pbs:quantity_unit_uri ],
        [ sh:datatype xsd:double ;
            sh:description "Numeric quantity value." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path pbs:quantity_value ],
        [ sh:datatype xsd:string ;
            sh:description "Unit of the quantity value." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path pbs:quantity_unit ],
        [ sh:datatype xsd:string ;
            sh:description "skos:notation of the concept in the matching abstract metric or ratio scheme." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path pbs:metric_code ] ;
    sh:targetClass pbs:QuantityValue .

pbs:Entity a sh:NodeShape ;
    rdfs:comment "Common base class for everything in the project graph. Has identity, lifecycle, and status." ;
    sh:closed false ;
    sh:ignoredProperties ( pbs:project_code pbs:actual_finish_at pbs:equipment_type pbs:process_participants pbs:parent_program pbs:time_records pbs:infill_material pbs:planned_start_at pbs:storage_link pbs:redacted_at pbs:milestone_at pbs:statement pbs:parent_process pbs:source_artifact pbs:connection_physical_type pbs:media_format pbs:program_code pbs:signed_artifact pbs:process_definition_uri pbs:substitutes_allowed pbs:target_value_boolean pbs:parent_level pbs:zone_type pbs:connection_virtual_type pbs:related_entity dcterms:description pbs:postal_addresses pbs:cost_quantity_type pbs:elevation pbs:separates_levels pbs:contained_entities schema:actionStatus pbs:component_time_items pbs:boundary_type pbs:min_height pbs:cost_category pbs:group_members pbs:separator_requirement_drivers pbs:target_value_string rdfs:comment pbs:parent_building schema:text schema:agent pbs:currency pbs:material_specification pbs:transport_medium <http://www.w3.org/ns/adms#status> pbs:is_above_ground pbs:component_cost_items pbs:target_unit rdf:type pbs:signed_at pbs:retain_until pbs:bounded_space pbs:actual_start_at pbs:bounded_by pbs:product_code pbs:parent_project pbs:frame_material pbs:min_area pbs:serves_spaces pbs:connects_spaces pbs:adjacency_kind pbs:belongs_to_company pbs:data_controller pbs:space_type pbs:min_clear_distance pbs:clause_ref pbs:parent_legal_site dcterms:created pbs:successors pbs:operated_by pbs:external_instance_uri pbs:programme_ref pbs:cost_record_role pbs:contract_reference pbs:connects_physical_elements pbs:separates_spaces pbs:connection_physical_requirement_drivers pbs:jurisdiction pbs:related_time_record pbs:separator_slab_type schema:deadline pbs:deliverable_format pbs:system_type pbs:parent_zone pbs:related_product pbs:acceptance_criteria pbs:is_heated pbs:service_endpoint pbs:parent_perimeter pbs:time_plan pbs:materials schema:recipient pbs:target_operator pbs:cost_quantity_unit pbs:is_cooled pbs:separator_wall_type pbs:privacy_policy_uri pbs:software_version pbs:serves_zones pbs:artifact_kind pbs:material_category pbs:effective_until pbs:connection_virtual_requirement_drivers pbs:target_unit_uri pbs:deliverable_code pbs:unit_cost pbs:consent_records pbs:norm_uri pbs:earliest_start_at pbs:parent_space schema:headline prov:wasAttributedTo pbs:completed_at pbs:target_value_number pbs:processing_purposes schema:sender pbs:vendor pbs:effective_from pbs:redaction_reason pbs:catalog_cost_records pbs:contact_points pbs:system_discipline pbs:planned_finish_at pbs:client dcterms:type prov:used pbs:cost_records schema:dateSent pbs:related_material pbs:parent_system pbs:deliverable_kind pbs:elevation_unit pbs:personal_data_processing_state pbs:requirement_property_key pbs:space_name_type pbs:contract_parties pbs:priced_for_customer pbs:context_type pbs:cost_quantity_value ) ;
    sh:property [ sh:class pbs:MetadataEntry ;
            sh:description "Generic metadata container for IFC attributes/properties and project-specific extensions." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path pbs:metadata ],
        [ sh:description "Optional semantic URI for linking the entity instance to an external ontology concept." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path pbs:meaning_uri ],
        [ sh:datatype xsd:string ;
            sh:description "Unique local identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path pbs:id ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp for this entity record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path pbs:created_at ],
        [ sh:class pbs:GeometryRepresentation ;
            sh:description """Geometry references associated with the entity. A single element may link to multiple geometry representations to serve different intents (authoring, coordination, analysis, visualization) without duplicating the element itself.
""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path pbs:geometry_representations ],
        [ sh:description "Lifecycle or QA status." ;
            sh:in ( pbs:status_draft pbs:status_submitted pbs:status_reviewed pbs:status_approved pbs:status_rejected pbs:status_archived ) ;
            sh:maxCount 1 ;
            sh:order 17 ;
            sh:path pbs:status ],
        [ sh:datatype xsd:string ;
            sh:description "IFC GlobalId of the mapped entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path pbs:ifc_global_id ;
            sh:pattern "^[0-3][0-9A-Za-z_$]{21}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Entity type discriminator for adapter projection and querying. Must be a ContentKind value." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path pbs:content_kind ],
        [ sh:datatype xsd:string ;
            sh:description "Default display name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path pbs:name ],
        [ sh:class pbs:LocalizedText ;
            sh:description "Localized variants of name." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path pbs:localized_names ],
        [ sh:class pbs:Entity ;
            sh:description "Model entities this record applies to (requirements, cost items, schedule items, etc.)." ;
            sh:nodeKind sh:IRI ;
            sh:order 13 ;
            sh:path pbs:applies_to_entities ],
        [ sh:datatype xsd:integer ;
            sh:description "Integer revision counter for change tracking." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path pbs:revision ],
        [ sh:class pbs:Classification ;
            sh:description "Classification entries from IFC and other schemes." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path pbs:classifications ],
        [ sh:datatype xsd:string ;
            sh:description "Default description text." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path pbs:description ],
        [ sh:class pbs:LocalizedText ;
            sh:description "Localized variants of description." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path pbs:localized_descriptions ],
        [ sh:class pbs:PerformanceProperty ;
            sh:description """Normalized, strongly typed domain properties (fire/acoustic/thermal/structural/ security/material) extracted from raw IFC PropertySet values.
""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path pbs:performance_properties ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Last modification timestamp for this entity record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path pbs:modified_at ],
        [ sh:class pbs:QuantityValue ;
            sh:description "Quantities associated with the entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path pbs:quantity_values ] ;
    sh:targetClass pbs:Entity .

pbs:LocalizedText a sh:NodeShape ;
    rdfs:comment "Localized text value for a specific language tag." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "IETF BCP 47 language tag (for example en, de, pt-BR)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path pbs:language_tag ],
        [ sh:datatype xsd:string ;
            sh:description "Localized text value." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path pbs:text_value ] ;
    sh:targetClass pbs:LocalizedText .


