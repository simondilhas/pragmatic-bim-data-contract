-name-classification/RN_OUT_PAT> <https://example.org/abstract/building-space-name-classification/RN_OUT_GDN> <https://example.org/abstract/building-space-name-classification/RN_OUT_PLY> <https://example.org/abstract/building-space-name-classification/RN_OUT_SPL> <https://example.org/abstract/building-space-name-classification/RN_OUT_CWK> <https://example.org/abstract/building-space-name-classification/RN_OUT_PRT> <https://example.org/abstract/building-space-name-classification/RN_VOI_SHA> <https://example.org/abstract/building-space-name-classification/RN_VOI_RIS> <https://example.org/abstract/building-space-name-classification/RN_VOI_PLN> <https://example.org/abstract/building-space-name-classification/RN_VOI_MCH> <https://example.org/abstract/building-space-name-classification/RN_VOI_AIR> <https://example.org/abstract/building-space-name-classification/RN_VOI_ATR> <https://example.org/abstract/building-space-name-classification/RN_VOI_STR> <https://example.org/abstract/building-space-name-classification/RN_VOI_PRK> ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path pbs:space_name_type ],
        [ sh:class pbs:LevelContext ;
            sh:description "Parent level/storey context reference." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path pbs:parent_level ],
        [ sh:datatype xsd:string ;
            sh:description "IFC GlobalId of the mapped entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path pbs:ifc_global_id ;
            sh:pattern "^[0-3][0-9A-Za-z_$]{21}$" ],
        [ sh:class pbs:Entity ;
            sh:description "Model entities this record applies to (requirements, cost items, schedule items, etc.)." ;
            sh:nodeKind sh:IRI ;
            sh:order 26 ;
            sh:path pbs:applies_to_entities ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether the space is above ground level. When unset, consumers may derive from parent_level elevation relative to project datum." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path pbs:is_above_ground ],
        [ sh:class pbs:BuiltAssetContext ;
            sh:description "Parent building context reference." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path pbs:parent_building ],
        [ sh:datatype xsd:string ;
            sh:description "Default description text." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path pbs:description ],
        [ sh:class pbs:Classification ;
            sh:description "Classification entries from IFC and other schemes." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path pbs:classifications ],
        [ sh:class pbs:PerformanceProperty ;
            sh:description """Normalized, strongly typed domain properties (fire/acoustic/thermal/structural/ security/material) extracted from raw IFC PropertySet values.
""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 25 ;
            sh:path pbs:performance_properties ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Last modification timestamp for this entity record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 28 ;
            sh:path pbs:modified_at ],
        [ sh:datatype xsd:string ;
            sh:description "Unique local identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path pbs:id ],
        [ sh:datatype xsd:boolean ;
            sh:description "Whether the space is designed to receive cooling (air conditioning)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path pbs:is_cooled ],
        [ sh:class pbs:Entity ;
            sh:description "Generic containment for associated entities." ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path pbs:contained_entities ],
        [ sh:class pbs:ZoneContext ;
            sh:description "Parent zone context reference." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path pbs:parent_zone ],
        [ sh:datatype xsd:string ;
            sh:description "Default display name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path pbs:name ],
        [ sh:datatype xsd:integer ;
            sh:description "Integer revision counter for change tracking." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 29 ;
            sh:path pbs:revision ] ;
    sh:targetClass pbs:Space .

pbs:Agent a sh:NodeShape ;
    rdfs:comment "Abstract base class for human and software actors in workflow and communication roles." ;
    sh:closed false ;
    sh:ignoredProperties ( pbs:postal_addresses pbs:retain_until pbs:redacted_at pbs:service_endpoint pbs:personal_data_processing_state pbs:processing_purposes pbs:operated_by pbs:privacy_policy_uri pbs:software_version pbs:redaction_reason pbs:belongs_to_company pbs:data_controller pbs:consent_records pbs:contact_points rdf:type ) ;
    sh:property [ sh:class pbs:PerformanceProperty ;
            sh:description """Normalized, strongly typed domain properties (fire/acoustic/thermal/structural/ security/material) extracted from raw IFC PropertySet values.
""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path pbs:performance_properties ],
        [ sh:datatype xsd:string ;
            sh:description "Unique local identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path pbs:id ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Last modification timestamp for this entity record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path pbs:modified_at ],
        [ sh:datatype xsd:integer ;
            sh:description "Integer revision counter for change tracking." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path pbs:revision ],
        [ sh:datatype xsd:string ;
            sh:description "Default description text." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path pbs:description ],
        [ sh:datatype xsd:string ;
            sh:description "Default display name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path pbs:name ],
        [ sh:class pbs:LocalizedText ;
            sh:description "Localized variants of name." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path pbs:localized_names ],
        [ sh:class pbs:MetadataEntry ;
            sh:description "Generic metadata container for IFC attributes/properties and project-specific extensions." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path pbs:metadata ],
        [ sh:class pbs:GeometryRepresentation ;
            sh:description """Geometry references associated with the entity. A single element may link to multiple geometry representations to serve different intents (authoring, coordination, analysis, visualization) without duplicating the element itself.
""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path pbs:geometry_representations ],
        [ sh:description "Optional semantic URI for linking the entity instance to an external ontology concept." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path pbs:meaning_uri ],
        [ sh:datatype xsd:string ;
            sh:description "IFC GlobalId of the mapped entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path pbs:ifc_global_id ;
            sh:pattern "^[0-3][0-9A-Za-z_$]{21}$" ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp for this entity record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path pbs:created_at ],
        [ sh:class pbs:QuantityValue ;
            sh:description "Quantities associated with the entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path pbs:quantity_values ],
        [ sh:datatype xsd:string ;
            sh:description "Entity type discriminator for adapter projection and querying. Must be a ContentKind value." ;
            sh:in ( "agent" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path pbs:content_kind ],
        [ sh:class pbs:Classification ;
            sh:description "Classification entries from IFC and other schemes." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path pbs:classifications ],
        [ sh:class pbs:LocalizedText ;
            sh:description "Localized variants of description." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path pbs:localized_descriptions ],
        [ sh:description "Lifecycle or QA status." ;
            sh:in ( pbs:status_draft pbs:status_submitted pbs:status_reviewed pbs:status_approved pbs:status_rejected pbs:status_archived ) ;
            sh:maxCount 1 ;
            sh:order 17 ;
            sh:path pbs:status ],
        [ sh:class pbs:Entity ;
            sh:description "Model entities this record applies to (requirements, cost items, schedule items, etc.)." ;
            sh:nodeKind sh:IRI ;
            sh:order 13 ;
            sh:path pbs:applies_to_entities ] ;
    sh:targetClass pbs:Agent .

