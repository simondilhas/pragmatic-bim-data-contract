pbs:ConnectionPhysical a sh:NodeShape ;
    rdfs:comment "Physical connector providing functional connection between spaces (for example door, window, duct, pipe, cable)." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class pbs:QuantityValue ;
            sh:description "Quantities associated with the entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path pbs:quantity_values ],
        [ sh:description "Primary transport medium carried or enabled by the connector (for example human_access, air, liquid, electricity)." ;
            sh:in ( pbs:transport_medium_human_access pbs:transport_medium_daylight_view pbs:transport_medium_air pbs:transport_medium_liquid pbs:transport_medium_gas pbs:transport_medium_electricity pbs:transport_medium_data ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path pbs:transport_medium ],
