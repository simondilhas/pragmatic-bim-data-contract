            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path pbs:modified_at ],
        [ sh:datatype xsd:string ;
            sh:description "Default description text." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path pbs:description ],
        [ sh:description "Comparison operator for the requirement target." ;
            sh:in ( pbs:requirement_target_operator_equals pbs:requirement_target_operator_minimum pbs:requirement_target_operator_maximum pbs:requirement_target_operator_range ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path pbs:target_operator ],
        [ sh:class pbs:Artifact ;
            sh:description "Optional source artifact backing this requirement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path pbs:source_artifact ],
        [ sh:class pbs:LocalizedText ;
            sh:description "Localized variants of name." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path pbs:localized_names ],
        [ sh:datatype xsd:string ;
