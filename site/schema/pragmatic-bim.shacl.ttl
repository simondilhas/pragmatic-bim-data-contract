            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path pbs:name ],
        [ sh:description """Performance requirement drivers for this physical connection element. Multiple values are allowed because one connection may need to satisfy several requirements.
""" ;
            sh:in ( pbs:connection_requirement_driver_fire pbs:connection_requirement_driver_security pbs:connection_requirement_driver_accessibility pbs:connection_requirement_driver_acoustic pbs:connection_requirement_driver_thermal pbs:connection_requirement_driver_visual pbs:connection_requirement_driver_structural ) ;
            sh:order 4 ;
            sh:path pbs:connection_physical_requirement_drivers ],
        [ sh:class pbs:GeometryRepresentation ;
            sh:description """Geometry references associated with the entity. A single element may link to multiple geometry representations to serve different intents (authoring, coordination, analysis, visualization) without duplicating the element itself.
""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
