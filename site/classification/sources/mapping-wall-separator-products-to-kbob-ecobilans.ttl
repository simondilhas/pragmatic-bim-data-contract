@prefix swp: <https://example.org/abstract/wall-separator-product/> .
@prefix kbobbm: <https://example.org/ch/kbob/ecobilans/baumat/2009-1-2022/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix map: <https://example.org/mapping/> .

map:abstractWallSeparatorProductsToKbobEcobilansMapping a dcterms:Dataset ;
  dcterms:title "Abstract wall separator products to KBOB ecobilans mapping"@en ;
  dcterms:title "Mapping abstrakter Wand-Trennelementprodukte nach KBOB Oekobilanz"@de ;
  dcterms:references swp:scheme, kbobbm:scheme ;
  dcterms:issued "2026-07-01" ;
  dcterms:description "Maps abstract wall separator products to KBOB ecobilans rows. m2-priced walls mapped to kg rows use default area yields in kbob-ecobilans-price-unit-defaults.json. m3 concrete uses density conversion from 01.002."@en ;
  dcterms:description "Ordnet abstrakte Wand-Trennelementprodukte KBOB-Oekobilanz-Zeilen zu. m2-bewertete Waende auf kg-Zeilen nutzen Standard-Flaechenertraege in kbob-ecobilans-price-unit-defaults.json. m3-Beton nutzt Dichtekonversion von 01.002."@de .

swp:SWP-ORTBETON skos:closeMatch kbobbm:01_002 .

swp:SWP-MASONRY skos:closeMatch kbobbm:02_001 ;
  skos:relatedMatch kbobbm:02_002, kbobbm:02_006 .

swp:SWP-RAMMED-EARTH skos:closeMatch kbobbm:03_020 ;
  skos:relatedMatch kbobbm:10_015 .

swp:SWP-BLT skos:closeMatch kbobbm:02_006 ;
  skos:relatedMatch kbobbm:01_041 .

swp:SWP-PREFAB-CONC skos:closeMatch kbobbm:01_042 ;
  skos:relatedMatch kbobbm:01_041 .

swp:SWP-STEEL skos:closeMatch kbobbm:06_012 ;
  skos:relatedMatch kbobbm:06_001 .

swp:SWP-TIMBER skos:closeMatch kbobbm:07_003 ;
  skos:relatedMatch kbobbm:07_023 .

swp:SWP-LEICHTBAU skos:closeMatch kbobbm:07_005 ;
  skos:relatedMatch kbobbm:07_004 .

swp:SWP-CURTAIN-WALL skos:closeMatch kbobbm:05_008 .

swp:SWP-ELEMENT-WALL skos:closeMatch kbobbm:05_021 ;
  skos:relatedMatch kbobbm:03_008, kbobbm:07_014 .

swp:SWP-OTH skos:closeMatch kbobbm:01_002 ;
  skos:relatedMatch kbobbm:02_001, kbobbm:07_005 .
