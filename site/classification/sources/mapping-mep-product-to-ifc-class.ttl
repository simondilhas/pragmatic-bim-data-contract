@prefix mup: <https://example.org/abstract/mep-unit-product/> .
@prefix mtp: <https://example.org/abstract/mep-terminal-product/> .
@prefix ifcowl: <https://w3id.org/ifc/IFC4_ADD2#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix map: <https://example.org/mapping/> .

map:mepProductToIfcClassMapping a dcterms:Dataset ;
  dcterms:title "MEP product to IFC class mapping"@en ;
  dcterms:title "Mapping TGA-Produkte zu IFC-Klassen"@de ;
  dcterms:references mup:scheme, mtp:scheme ;
  dcterms:description "Maps assignable MEP unit and terminal product concepts to IFC entity classes for ingestion hints. Uses skos:closeMatch where the mapping is typical but not exclusive."@en ;
  dcterms:description "Ordnet zuweisbare TGA-Erzeuger- und Endgeraeteprodukte IFC-Entitaetsklassen fuer Ingestion-Hinweise zu. skos:closeMatch wo die Zuordnung typisch, aber nicht ausschliesslich ist."@de .

# --- MUP electrical ---

mup:MUP-ELEC-TRANSFORMER skos:closeMatch ifcowl:IfcTransformer .
mup:MUP-ELEC-MAIN-DIST-BOARD skos:closeMatch ifcowl:IfcElectricDistributionBoard .
mup:MUP-ELEC-SUB-DIST-BOARD skos:closeMatch ifcowl:IfcElectricDistributionBoard .
mup:MUP-ELEC-UPS skos:closeMatch ifcowl:IfcElectricFlowStorageDevice .
mup:MUP-ELEC-GENERATOR skos:closeMatch ifcowl:IfcElectricGenerator .

# --- MUP data ---

mup:MUP-DATA-PATCH-PANEL skos:closeMatch ifcowl:IfcCommunicationsAppliance .
mup:MUP-DATA-NETWORK-SWITCH skos:closeMatch ifcowl:IfcCommunicationsAppliance .
mup:MUP-DATA-SERVER skos:closeMatch ifcowl:IfcCommunicationsAppliance .

# --- MUP ventilation ---

mup:MUP-VENT-AHU skos:closeMatch ifcowl:IfcUnitaryEquipment .
mup:MUP-VENT-FAN skos:closeMatch ifcowl:IfcFan .

# --- MUP heating ---

mup:MUP-HEAT-BOILER skos:closeMatch ifcowl:IfcBoiler .
mup:MUP-HEAT-HEAT-PUMP skos:closeMatch ifcowl:IfcUnitaryEquipment .
mup:MUP-HEAT-DISTRICT-HEAT-SUBSTATION skos:closeMatch ifcowl:IfcHeatExchanger .

# --- MUP cooling ---

mup:MUP-COOL-CHILLER skos:closeMatch ifcowl:IfcChiller .
mup:MUP-COOL-FREE-COOLER skos:closeMatch ifcowl:IfcCoolingTower .

# --- MUP fresh water ---

mup:MUP-FW-PRESSURE-BOOSTER skos:closeMatch ifcowl:IfcPump .
mup:MUP-FW-WATER-HEATER skos:closeMatch ifcowl:IfcBoiler .

# --- MUP waste water ---

mup:MUP-WW-LIFTING-STATION skos:closeMatch ifcowl:IfcPump .
mup:MUP-WW-GREASE-SEPARATOR skos:closeMatch ifcowl:IfcTank .

# --- MUP special media ---

mup:MUP-SM-COMPRESSOR skos:closeMatch ifcowl:IfcCompressor .
mup:MUP-SM-GAS-REGULATOR skos:closeMatch ifcowl:IfcFlowMeter .
mup:MUP-SM-FIRE-PUMP skos:closeMatch ifcowl:IfcPump .

# --- MTP electrical ---

mtp:MTP-ELEC-SOCKET skos:closeMatch ifcowl:IfcOutlet .
mtp:MTP-ELEC-LIGHT skos:closeMatch ifcowl:IfcLightFixture .
mtp:MTP-ELEC-SWITCH skos:closeMatch ifcowl:IfcSwitchingDevice .

# --- MTP data ---

mtp:MTP-DATA-DATA-OUTLET skos:closeMatch ifcowl:IfcOutlet ;
  skos:closeMatch ifcowl:IfcCommunicationsAppliance .
mtp:MTP-DATA-WIFI-AP skos:closeMatch ifcowl:IfcCommunicationsAppliance .
mtp:MTP-DATA-SENSOR-ACTUATOR skos:closeMatch ifcowl:IfcSensor ;
  skos:closeMatch ifcowl:IfcActuator .

# --- MTP ventilation ---

mtp:MTP-VENT-AIR-VALVE skos:closeMatch ifcowl:IfcAirTerminal ;
  skos:closeMatch ifcowl:IfcAirTerminalBox .
mtp:MTP-VENT-GRILLE skos:closeMatch ifcowl:IfcAirTerminal .

# --- MTP heating ---

mtp:MTP-HEAT-RADIATOR skos:closeMatch ifcowl:IfcSpaceHeater .
mtp:MTP-HEAT-UFH-MANIFOLD skos:closeMatch ifcowl:IfcValve .
mtp:MTP-HEAT-FAN-COIL skos:closeMatch ifcowl:IfcUnitaryEquipment .

# --- MTP cooling ---

mtp:MTP-COOL-FAN-COIL skos:closeMatch ifcowl:IfcUnitaryEquipment .
mtp:MTP-COOL-CHILLED-CEILING skos:closeMatch ifcowl:IfcCooledBeam .

# --- MTP fresh water ---

mtp:MTP-FW-TAP skos:closeMatch ifcowl:IfcSanitaryTerminal .
mtp:MTP-FW-SHOWER skos:closeMatch ifcowl:IfcSanitaryTerminal .
mtp:MTP-FW-WC-FLUSH skos:closeMatch ifcowl:IfcSanitaryTerminal .

# --- MTP waste water ---

mtp:MTP-WW-FLOOR-DRAIN skos:closeMatch ifcowl:IfcWasteTerminal .
mtp:MTP-WW-WC-OUTLET skos:closeMatch ifcowl:IfcWasteTerminal .
mtp:MTP-WW-SINK-DRAIN skos:closeMatch ifcowl:IfcWasteTerminal .

# --- MTP special media ---

mtp:MTP-SM-GAS-OUTLET skos:closeMatch ifcowl:IfcGasTerminal .
mtp:MTP-SM-SPRINKLER-HEAD skos:closeMatch ifcowl:IfcFireSuppressionTerminal .
mtp:MTP-SM-HOSE-REEL skos:closeMatch ifcowl:IfcFireSuppressionTerminal .

# --- MTP fire safety ---

mtp:MTP-FIRE-FIRE-DAMPER skos:closeMatch ifcowl:IfcDamper .
mtp:MTP-FIRE-FIRE-DAMPER-ACTUATOR skos:closeMatch ifcowl:IfcActuator .
mtp:MTP-FIRE-SMOKE-DETECTOR skos:closeMatch ifcowl:IfcSensor ;
  skos:closeMatch ifcowl:IfcAlarm .
