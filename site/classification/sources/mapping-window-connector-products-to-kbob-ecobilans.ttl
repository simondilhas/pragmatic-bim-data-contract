@prefix wicp: <https://example.org/abstract/window-connector-product/> .
@prefix kbobbm: <https://example.org/ch/kbob/ecobilans/baumat/2009-1-2022/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix map: <https://example.org/mapping/> .

map:abstractWindowConnectorProductsToKbobEcobilansMapping a dcterms:Dataset ;
  dcterms:title "Abstract window connector products to KBOB ecobilans mapping"@en ;
  dcterms:title "Mapping abstrakter Fenster-Verbindungsprodukte nach KBOB Oekobilanz"@de ;
  dcterms:references wicp:scheme, kbobbm:scheme ;
  dcterms:issued "2026-07-01" ;
  dcterms:description "Maps abstract window connector products to KBOB ecobilans rows. Frame and glazing layers use skos:closeMatch on narrower concepts; parent window types use skos:relatedMatch for the default 2-pane recipe. Facade glazing units map to the full curtain-wall assembly row."@en ;
  dcterms:description "Ordnet abstrakte Fenster-Verbindungsprodukte KBOB-Oekobilanz-Zeilen zu. Rahmen- und Verglasungsschichten per skos:closeMatch auf narrower-Konzepte; Eltern-Fenstertypen skos:relatedMatch fuer Standard-2-fach-Rezept."@de .

# --- Wood window ---

wicp:WICP-WOOD-FRAME skos:closeMatch kbobbm:05_005 .

wicp:WICP-WOOD-GLZ-2P skos:closeMatch kbobbm:05_001 .

wicp:WICP-WOOD skos:relatedMatch kbobbm:05_005, kbobbm:05_001 .

# --- Wood–metal window ---

wicp:WICP-WOOD-METAL-FRAME skos:closeMatch kbobbm:05_006 .

wicp:WICP-WOOD-METAL-GLZ-2P skos:closeMatch kbobbm:05_001 .

wicp:WICP-WOOD-METAL skos:relatedMatch kbobbm:05_006, kbobbm:05_001 .

# --- PVC window ---

wicp:WICP-PVC-FRAME skos:closeMatch kbobbm:05_007 .

wicp:WICP-PVC-GLZ-2P skos:closeMatch kbobbm:05_001 .

wicp:WICP-PVC skos:relatedMatch kbobbm:05_007, kbobbm:05_001 .

# --- Steel window ---

wicp:WICP-STEEL-FRAME skos:closeMatch kbobbm:05_004 ;
  skos:relatedMatch kbobbm:06_012 .

wicp:WICP-STEEL-GLZ-2P skos:closeMatch kbobbm:05_001 .

wicp:WICP-STEEL skos:relatedMatch kbobbm:05_004, kbobbm:05_001 .

# --- Aluminium window ---

wicp:WICP-ALUMINIUM-FRAME skos:closeMatch kbobbm:05_004 .

wicp:WICP-ALUMINIUM-GLZ-2P skos:closeMatch kbobbm:05_001 ;
  skos:relatedMatch kbobbm:05_003, kbobbm:05_012 .

wicp:WICP-ALUMINIUM skos:relatedMatch kbobbm:05_004, kbobbm:05_001 .

# --- Assembly products ---

wicp:WICP-FACADE-UNIT skos:closeMatch kbobbm:05_008 .

wicp:WICP-SKYLIGHT skos:closeMatch kbobbm:05_005 ;
  skos:relatedMatch kbobbm:05_012 .

# --- Special / fallback ---

wicp:WICP-SPECIAL skos:closeMatch kbobbm:05_012 ;
  skos:relatedMatch kbobbm:05_016, kbobbm:05_008 .

wicp:WICP-OTH skos:closeMatch kbobbm:05_005 ;
  skos:relatedMatch kbobbm:05_001 .
