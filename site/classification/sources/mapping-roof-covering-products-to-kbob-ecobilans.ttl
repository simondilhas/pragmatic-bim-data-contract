@prefix rcp: <https://example.org/abstract/roof-covering-product/> .
@prefix kbobbm: <https://example.org/ch/kbob/ecobilans/baumat/2009-1-2022/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix map: <https://example.org/mapping/> .

map:abstractRoofCoveringProductsToKbobEcobilansMapping a dcterms:Dataset ;
  dcterms:title "Abstract roof covering products to KBOB ecobilans mapping"@en ;
  dcterms:title "Mapping abstrakter Dachbekleidungsprodukte nach KBOB Oekobilanz"@de ;
  dcterms:references rcp:scheme, kbobbm:scheme ;
  dcterms:issued "2026-07-01" ;
  dcterms:description "Maps abstract roof covering products to KBOB ecobilans rows. Flat roof composites use layer narrowers for insulation and membrane; pitched and bundled types map to closest assembly or material row where available."@en ;
  dcterms:description "Ordnet abstrakte Dachbekleidungsprodukte KBOB-Oekobilanz-Zeilen zu. Flachdach-Verbundsysteme nutzen Schicht-narrower fuer Daemmung und Abdichtung; geneigte und gebündelte Typen naechste Baugruppen- oder Materialzeile."@de .

# --- Flat roof composites (layer decomposition) ---

rcp:RCP-FLAT-BITUMEN-INS skos:closeMatch kbobbm:10_008 ;
  skos:relatedMatch kbobbm:10_004 .

rcp:RCP-FLAT-BITUMEN-MEM skos:closeMatch kbobbm:09_003 ;
  skos:relatedMatch kbobbm:08_002 .

rcp:RCP-FLAT-BITUMEN skos:relatedMatch kbobbm:09_003, kbobbm:10_008, kbobbm:08_002 .

rcp:RCP-FLAT-SINGLE-PLY-INS skos:closeMatch kbobbm:10_008 ;
  skos:relatedMatch kbobbm:10_004, kbobbm:10_005 .

rcp:RCP-FLAT-SINGLE-PLY-MEM skos:closeMatch kbobbm:09_004 ;
  skos:relatedMatch kbobbm:09_005 .

rcp:RCP-FLAT-SINGLE-PLY skos:relatedMatch kbobbm:09_004, kbobbm:10_008, kbobbm:09_005 .

rcp:RCP-FLAT-LIQUID skos:closeMatch kbobbm:08_003 ;
  skos:relatedMatch kbobbm:09_003 .

# --- Bundled pitched and specialty roof types ---

rcp:RCP-METAL-SHEET skos:closeMatch kbobbm:06_001 ;
  skos:relatedMatch kbobbm:06_002 .

rcp:RCP-TILE-CLAY skos:closeMatch kbobbm:03_010 ;
  skos:relatedMatch kbobbm:11_008 .

rcp:RCP-TILE-CONCRETE skos:closeMatch kbobbm:03_003 ;
  skos:relatedMatch kbobbm:01_042 .

rcp:RCP-SLATE skos:closeMatch kbobbm:05_025 ;
  skos:relatedMatch kbobbm:03_010 .

rcp:RCP-WOOD-SHINGLE skos:closeMatch kbobbm:07_014 ;
  skos:relatedMatch kbobbm:07_003 .

rcp:RCP-GREEN-EXTENSIVE skos:closeMatch kbobbm:10_004 ;
  skos:relatedMatch kbobbm:09_003, kbobbm:10_008 .

rcp:RCP-GREEN-INTENSIVE skos:closeMatch kbobbm:10_008 ;
  skos:relatedMatch kbobbm:01_002, kbobbm:09_003 .

rcp:RCP-PV-ROOF skos:closeMatch kbobbm:05_008 ;
  skos:relatedMatch kbobbm:06_001, kbobbm:09_003 .

rcp:RCP-OTH skos:closeMatch kbobbm:09_003 ;
  skos:relatedMatch kbobbm:06_001, kbobbm:10_008 .
