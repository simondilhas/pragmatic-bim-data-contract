@prefix dcp: <https://example.org/abstract/door-connector-product/> .
@prefix wicp: <https://example.org/abstract/window-connector-product/> .
@prefix bkp: <https://example.org/ch/bkp/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix map: <https://example.org/mapping/> .

map:abstractConnectorProductsToBkpMapping a dcterms:Dataset ;
  dcterms:title "Abstract connector products to BKP mapping"@en ;
  dcterms:title "Mapping abstrakter Verbindungsprodukte nach BKP"@de ;
  dcterms:references dcp:scheme, wicp:scheme, bkp:scheme ;
  dcterms:issued "2026-06-30" ;
  dcterms:description "Maps abstract door and window connector product concepts to BKP Rohbau 221.x (exterior windows and doors) and Ausbau 272/273 (interior metal and wood openings). BKP subcodes use underscore notation (e.g. bkp:221_0 for BKP 221.0). Full BKP vocabulary is external."@en ;
  dcterms:description "Ordnet abstrakte Tuer- und Fenster-Verbindungsprodukte BKP-Rohbau-221.x (Aussenfenster und -tueren) und Ausbau-272/273 (innere Metall- und Holz-Oeffnungen) zu. BKP-Untercodes mit Unterstrich. Vollstaendiges BKP-Vokabular extern."@de .

# --- Door connector products (BKP 221.5–221.6 exterior; 272/273 interior) ---

dcp:DCP-WOOD skos:closeMatch bkp:221_5 ;
  skos:relatedMatch bkp:273 .

dcp:DCP-METAL skos:closeMatch bkp:221_6 ;
  skos:relatedMatch bkp:272 .

dcp:DCP-WOOD-METAL skos:closeMatch bkp:221_5 ;
  skos:relatedMatch bkp:273, bkp:272 .

dcp:DCP-PVC skos:closeMatch bkp:221_6 ;
  skos:relatedMatch bkp:272 .

dcp:DCP-GLASS skos:closeMatch bkp:221_6 ;
  skos:relatedMatch bkp:272, bkp:221_8 .

dcp:DCP-GATE skos:closeMatch bkp:221_6 ;
  skos:relatedMatch bkp:272, bkp:221_9 .

dcp:DCP-SPECIAL skos:closeMatch bkp:221_8 ;
  skos:relatedMatch bkp:221_6, bkp:272 .

# --- Window connector products (BKP 221.0–221.4 exterior; 272/273 interior) ---

wicp:WICP-WOOD skos:closeMatch bkp:221_0 ;
  skos:relatedMatch bkp:273 .

wicp:WICP-WOOD-METAL skos:closeMatch bkp:221_1 ;
  skos:relatedMatch bkp:273, bkp:272 .

wicp:WICP-PVC skos:closeMatch bkp:221_2 ;
  skos:relatedMatch bkp:272 .

wicp:WICP-STEEL skos:closeMatch bkp:221_3 ;
  skos:relatedMatch bkp:272 .

wicp:WICP-ALUMINIUM skos:closeMatch bkp:221_4 ;
  skos:relatedMatch bkp:272 .

wicp:WICP-SPECIAL skos:closeMatch bkp:221_8 ;
  skos:relatedMatch bkp:221_4, bkp:272 .

wicp:WICP-SKYLIGHT skos:relatedMatch bkp:224, bkp:221_0, bkp:221_4 .

wicp:WICP-FACADE-UNIT skos:closeMatch bkp:221_8 ;
  skos:relatedMatch bkp:221_9, bkp:221_4 .
