@prefix fcp: <https://example.org/abstract/floor-covering-product/> .
@prefix wcp: <https://example.org/abstract/wall-covering-product/> .
@prefix ccp: <https://example.org/abstract/ceiling-covering-product/> .
@prefix facp: <https://example.org/abstract/facade-covering-product/> .
@prefix rcp: <https://example.org/abstract/roof-covering-product/> .
@prefix fdp: <https://example.org/abstract/foundation-product/> .
@prefix mat: <https://example.org/abstract/material-classification/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix map: <https://example.org/mapping/> .

map:abstractCoveringProductsToMaterialMapping a dcterms:Dataset ;
  dcterms:title "Abstract covering products to material mapping"@en ;
  dcterms:title "Mapping abstrakter Bekleidungsprodukte nach Material"@de ;
  dcterms:references fcp:scheme, wcp:scheme, ccp:scheme, facp:scheme, rcp:scheme, fdp:scheme, mat:scheme ;
  dcterms:issued "2026-06-30" ;
  dcterms:modified "2026-07-01" ;
  dcterms:description "Maps abstract floor, wall, ceiling, facade, roof, and foundation covering product concepts to dominant-substance material classes. Uses skos:closeMatch for primary substance; skos:relatedMatch where composite or variable."@en ;
  dcterms:description "Ordnet abstrakte Boden-, Wand-, Decken-, Fassaden-, Dach- und Fundamentbekleidungsprodukte dominanten Materialklassen zu. skos:closeMatch fuer primaere Substanz; skos:relatedMatch bei Verbund oder Variabilitaet."@de .

# --- Floor covering products ---

fcp:FCP-SUBFLOOR skos:closeMatch mat:MAT-CONC ;
  skos:relatedMatch mat:MAT-CMP .

fcp:FCP-SEAMLESS-RESIN skos:closeMatch mat:MAT-PLA .

fcp:FCP-CARPET skos:closeMatch mat:MAT-PLA ;
  skos:relatedMatch mat:MAT-CMP .

fcp:FCP-LVT skos:closeMatch mat:MAT-PLA .

fcp:FCP-LINOLIUM skos:closeMatch mat:MAT-PLA .

fcp:FCP-NATURAL-STONE skos:closeMatch mat:MAT-MSN .

fcp:FCP-ARTIFICIAL-STONE skos:closeMatch mat:MAT-CONC ;
  skos:relatedMatch mat:MAT-CMP .

fcp:FCP-CERAMIC-TILE skos:closeMatch mat:MAT-MSN-CLY .

fcp:FCP-PARQUET skos:closeMatch mat:MAT-WOD .

fcp:FCP-LAMINATE skos:closeMatch mat:MAT-WOD ;
  skos:relatedMatch mat:MAT-CMP .

fcp:FCP-RAISED-FLOOR skos:closeMatch mat:MAT-CMP .

fcp:FCP-OTH skos:closeMatch mat:MAT-OTH .

# --- Wall covering products ---

wcp:WCP-SEAMLESS-COATING skos:closeMatch mat:MAT-MSN ;
  skos:relatedMatch mat:MAT-CMP .

wcp:WCP-WALLPAPER skos:closeMatch mat:MAT-PLA ;
  skos:relatedMatch mat:MAT-CMP .

wcp:WCP-NATURAL-STONE skos:closeMatch mat:MAT-MSN .

wcp:WCP-ARTIFICIAL-STONE skos:closeMatch mat:MAT-CONC ;
  skos:relatedMatch mat:MAT-CMP .

wcp:WCP-CERAMIC-TILE skos:closeMatch mat:MAT-MSN-CLY .

wcp:WCP-WOOD-PANEL skos:closeMatch mat:MAT-WOD .

wcp:WCP-TEXTILE skos:closeMatch mat:MAT-PLA .

wcp:WCP-SYNTHETIC-PANEL skos:closeMatch mat:MAT-PLA .

wcp:WCP-PAINT skos:closeMatch mat:MAT-PLA ;
  skos:relatedMatch mat:MAT-CMP .

wcp:WCP-OTH skos:closeMatch mat:MAT-OTH .

# --- Ceiling covering products ---

ccp:CCP-METAL-SHEET skos:closeMatch mat:MAT-MET .

ccp:CCP-GYPSUM-BOARD skos:closeMatch mat:MAT-GYP .

ccp:CCP-MINERAL-FIBRE skos:closeMatch mat:MAT-INS-MWO .

ccp:CCP-WOOD skos:closeMatch mat:MAT-WOD .

ccp:CCP-SYNTHETIC skos:closeMatch mat:MAT-PLA .

ccp:CCP-METAL-PANEL skos:closeMatch mat:MAT-MET .

ccp:CCP-METAL-GRID skos:closeMatch mat:MAT-MET .

ccp:CCP-OTH skos:closeMatch mat:MAT-OTH .

# --- Facade covering products ---

facp:FaCP-METAL-SHEET-STANDING-SEAM skos:closeMatch mat:MAT-MET .

facp:FaCP-METAL-COMPOSITE-PANEL skos:closeMatch mat:MAT-MET ;
  skos:relatedMatch mat:MAT-CMP .

facp:FaCP-FIBER-CEMENT-BOARD skos:closeMatch mat:MAT-CONC ;
  skos:relatedMatch mat:MAT-CMP .

facp:FaCP-NATURAL-STONE-VENTILATED skos:closeMatch mat:MAT-MSN .

facp:FaCP-CERAMIC-VENTILATED skos:closeMatch mat:MAT-MSN-CLY .

facp:FaCP-TIMBER-VENTILATED skos:closeMatch mat:MAT-WOD .

facp:FaCP-RENDER-ETICS-WDVS skos:closeMatch mat:MAT-CMP ;
  skos:relatedMatch mat:MAT-INS, mat:MAT-MSN, mat:MAT-PLA .

facp:FaCP-RENDER-ETICS-WDVS-INS skos:closeMatch mat:MAT-PLA ;
  skos:relatedMatch mat:MAT-INS-MWO .

facp:FaCP-RENDER-ETICS-WDVS-RENDER skos:closeMatch mat:MAT-MSN ;
  skos:relatedMatch mat:MAT-PLA .

facp:FaCP-SYNTHETIC-VENTILATED skos:closeMatch mat:MAT-PLA .

facp:FaCP-EXTERIOR-PAINT-COATING skos:closeMatch mat:MAT-PLA ;
  skos:relatedMatch mat:MAT-CMP .

facp:FaCP-RETROFIT-OVERCLADDING skos:closeMatch mat:MAT-CMP ;
  skos:relatedMatch mat:MAT-INS .

facp:FaCP-BIPV-INTEGRATED skos:closeMatch mat:MAT-MET ;
  skos:relatedMatch mat:MAT-GLS, mat:MAT-CMP .

facp:FaCP-PREFAB-MODULAR-TIMBER skos:closeMatch mat:MAT-WOD ;
  skos:relatedMatch mat:MAT-INS, mat:MAT-CMP .

facp:FaCP-PREFAB-MODULAR-METAL skos:closeMatch mat:MAT-MET ;
  skos:relatedMatch mat:MAT-INS, mat:MAT-CMP .

facp:FaCP-HPL-PANEL skos:closeMatch mat:MAT-PLA ;
  skos:relatedMatch mat:MAT-CMP .

facp:FaCP-BRICK-SLIP skos:closeMatch mat:MAT-MSN ;
  skos:relatedMatch mat:MAT-MSN-CLY .

facp:FaCP-OTHER skos:closeMatch mat:MAT-OTH .

# --- Roof covering products ---

rcp:RCP-FLAT-BITUMEN skos:closeMatch mat:MAT-ASP ;
  skos:relatedMatch mat:MAT-INS, mat:MAT-PLA .

rcp:RCP-FLAT-BITUMEN-INS skos:closeMatch mat:MAT-INS ;
  skos:relatedMatch mat:MAT-INS-MWO, mat:MAT-PLA .

rcp:RCP-FLAT-BITUMEN-MEM skos:closeMatch mat:MAT-ASP ;
  skos:relatedMatch mat:MAT-PLA .

rcp:RCP-FLAT-SINGLE-PLY skos:closeMatch mat:MAT-PLA ;
  skos:relatedMatch mat:MAT-INS .

rcp:RCP-FLAT-SINGLE-PLY-INS skos:closeMatch mat:MAT-INS ;
  skos:relatedMatch mat:MAT-INS-MWO, mat:MAT-PLA .

rcp:RCP-FLAT-SINGLE-PLY-MEM skos:closeMatch mat:MAT-PLA .

rcp:RCP-FLAT-LIQUID skos:closeMatch mat:MAT-PLA ;
  skos:relatedMatch mat:MAT-ASP .

rcp:RCP-METAL-SHEET skos:closeMatch mat:MAT-MET .

rcp:RCP-TILE-CLAY skos:closeMatch mat:MAT-MSN-CLY .

rcp:RCP-TILE-CONCRETE skos:closeMatch mat:MAT-CONC ;
  skos:relatedMatch mat:MAT-CMP .

rcp:RCP-SLATE skos:closeMatch mat:MAT-MSN .

rcp:RCP-WOOD-SHINGLE skos:closeMatch mat:MAT-WOD .

rcp:RCP-GREEN-EXTENSIVE skos:closeMatch mat:MAT-CMP ;
  skos:relatedMatch mat:MAT-INS, mat:MAT-PLA .

rcp:RCP-GREEN-INTENSIVE skos:closeMatch mat:MAT-CMP ;
  skos:relatedMatch mat:MAT-INS, mat:MAT-CONC .

rcp:RCP-PV-ROOF skos:closeMatch mat:MAT-MET ;
  skos:relatedMatch mat:MAT-GLS .

rcp:RCP-OTH skos:closeMatch mat:MAT-OTH .

# --- Foundation products ---

fdp:FDP-RAFT skos:closeMatch mat:MAT-CONC ;
  skos:relatedMatch mat:MAT-INS .

fdp:FDP-RAFT-INS skos:closeMatch mat:MAT-PLA ;
  skos:relatedMatch mat:MAT-INS .

fdp:FDP-STRIP skos:closeMatch mat:MAT-CONC .

fdp:FDP-PAD skos:closeMatch mat:MAT-CONC .

fdp:FDP-PILE skos:closeMatch mat:MAT-CONC .

fdp:FDP-MICRO-PILE skos:closeMatch mat:MAT-CONC ;
  skos:relatedMatch mat:MAT-MSN .

fdp:FDP-RETAINING skos:closeMatch mat:MAT-CONC ;
  skos:relatedMatch mat:MAT-INS .

fdp:FDP-RETAINING-INS skos:closeMatch mat:MAT-INS-MWO ;
  skos:relatedMatch mat:MAT-PLA .

fdp:FDP-WATERPROOF skos:closeMatch mat:MAT-ASP ;
  skos:relatedMatch mat:MAT-PLA .

fdp:FDP-DRAINAGE skos:closeMatch mat:MAT-PLA ;
  skos:relatedMatch mat:MAT-CMP .

fdp:FDP-OTH skos:closeMatch mat:MAT-OTH .
