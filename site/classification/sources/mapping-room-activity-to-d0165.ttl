@prefix abs: <https://example.org/abstract/building-space-activity-classification/> .
@prefix d0165: <https://example.org/d0165/flaechenbaum/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ex: <https://example.org/mapping/> .

ex:abstractToD0165Mapping a dcterms:Dataset ;
  dcterms:title "Abstract Building Classification to D0165 mapping"@en ;
  dcterms:references abs:scheme, d0165:scheme ;
  dcterms:description "Operational 1:n mapping from abstract classes to D0165 categories/leaves."@en .

# Main activity domain
abs:M ex:mapsToD0165 d0165:HNF_1, d0165:HNF_2, d0165:HNF_3, d0165:HNF_4, d0165:HNF_5, d0165:HNF_6 .
