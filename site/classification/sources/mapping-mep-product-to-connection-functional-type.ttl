@prefix mup: <https://example.org/abstract/mep-unit-product/> .
@prefix mtp: <https://example.org/abstract/mep-terminal-product/> .
@prefix func: <https://example.org/abstract/connection-functional-type/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix map: <https://example.org/mapping/> .

map:mepProductToConnectionFunctionalTypeMapping a dcterms:Dataset ;
  dcterms:title "MEP product to connection functional type mapping"@en ;
  dcterms:title "Mapping TGA-Produkte zu funktionalen Verbindungstypen"@de ;
  dcterms:references mup:scheme, mtp:scheme, func:scheme ;
  dcterms:description "Maps assignable MEP unit and terminal product concepts to ConnectionFunctionalType disciplines. MTP-FIRE-* cross-cutting terminals use relatedMatch to applicable host disciplines; discipline is resolved from the inline host system at assignment time."@en ;
  dcterms:description "Ordnet zuweisbare TGA-Erzeuger- und Endgeraeteprodukte ConnectionFunctionalType-Disziplinen zu. MTP-FIRE-* Querschnitts-Endgeraete verwenden relatedMatch zu anwendbaren Host-Disziplinen; die Disziplin wird bei Zuweisung vom Inline-Hostsystem aufgeloest."@de .

# --- MUP electrical ---

mup:MUP-ELEC-TRANSFORMER skos:broader func:electrical .
mup:MUP-ELEC-MAIN-DIST-BOARD skos:broader func:electrical .
mup:MUP-ELEC-SUB-DIST-BOARD skos:broader func:electrical .
mup:MUP-ELEC-UPS skos:broader func:electrical .
mup:MUP-ELEC-GENERATOR skos:broader func:electrical .

# --- MUP data ---

mup:MUP-DATA-PATCH-PANEL skos:broader func:data .
mup:MUP-DATA-NETWORK-SWITCH skos:broader func:data .
mup:MUP-DATA-SERVER skos:broader func:data .

# --- MUP ventilation ---

mup:MUP-VENT-AHU skos:broader func:ventilation .
mup:MUP-VENT-FAN skos:broader func:ventilation .

# --- MUP heating ---

mup:MUP-HEAT-BOILER skos:broader func:heating .
mup:MUP-HEAT-HEAT-PUMP skos:broader func:heating .
mup:MUP-HEAT-DISTRICT-HEAT-SUBSTATION skos:broader func:heating .

# --- MUP cooling ---

mup:MUP-COOL-CHILLER skos:broader func:cooling .
mup:MUP-COOL-FREE-COOLER skos:broader func:cooling .

# --- MUP fresh water ---

mup:MUP-FW-PRESSURE-BOOSTER skos:broader func:fresh_water .
mup:MUP-FW-WATER-HEATER skos:broader func:fresh_water .

# --- MUP waste water ---

mup:MUP-WW-LIFTING-STATION skos:broader func:waste_water .
mup:MUP-WW-GREASE-SEPARATOR skos:broader func:waste_water .

# --- MUP special media ---

mup:MUP-SM-COMPRESSOR skos:broader func:special_media .
mup:MUP-SM-GAS-REGULATOR skos:broader func:special_media .
mup:MUP-SM-FIRE-PUMP skos:broader func:special_media .

# --- MTP electrical ---

mtp:MTP-ELEC-SOCKET skos:broader func:electrical .
mtp:MTP-ELEC-LIGHT skos:broader func:electrical .
mtp:MTP-ELEC-SWITCH skos:broader func:electrical .

# --- MTP data ---

mtp:MTP-DATA-DATA-OUTLET skos:broader func:data .
mtp:MTP-DATA-WIFI-AP skos:broader func:data .
mtp:MTP-DATA-SENSOR-ACTUATOR skos:broader func:data .

# --- MTP ventilation ---

mtp:MTP-VENT-AIR-VALVE skos:broader func:ventilation .
mtp:MTP-VENT-GRILLE skos:broader func:ventilation .

# --- MTP heating ---

mtp:MTP-HEAT-RADIATOR skos:broader func:heating .
mtp:MTP-HEAT-UFH-MANIFOLD skos:broader func:heating .
mtp:MTP-HEAT-FAN-COIL skos:broader func:heating .

# --- MTP cooling ---

mtp:MTP-COOL-FAN-COIL skos:broader func:cooling .
mtp:MTP-COOL-CHILLED-CEILING skos:broader func:cooling .

# --- MTP fresh water ---

mtp:MTP-FW-TAP skos:broader func:fresh_water .
mtp:MTP-FW-SHOWER skos:broader func:fresh_water .
mtp:MTP-FW-WC-FLUSH skos:broader func:fresh_water .

# --- MTP waste water ---

mtp:MTP-WW-FLOOR-DRAIN skos:broader func:waste_water .
mtp:MTP-WW-WC-OUTLET skos:broader func:waste_water .
mtp:MTP-WW-SINK-DRAIN skos:broader func:waste_water .

# --- MTP special media ---

mtp:MTP-SM-GAS-OUTLET skos:broader func:special_media .
mtp:MTP-SM-SPRINKLER-HEAD skos:broader func:special_media .
mtp:MTP-SM-HOSE-REEL skos:broader func:special_media .

# --- MTP fire safety (cross-cutting) ---

mtp:MTP-FIRE-FIRE-DAMPER skos:relatedMatch func:ventilation ;
  skos:relatedMatch func:heating ;
  skos:relatedMatch func:cooling .

mtp:MTP-FIRE-FIRE-DAMPER-ACTUATOR skos:relatedMatch func:ventilation ;
  skos:relatedMatch func:heating ;
  skos:relatedMatch func:cooling .

mtp:MTP-FIRE-SMOKE-DETECTOR skos:relatedMatch func:electrical ;
  skos:relatedMatch func:data .
