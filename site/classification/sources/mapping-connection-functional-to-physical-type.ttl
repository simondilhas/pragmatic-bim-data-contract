@prefix func: <https://example.org/abstract/connection-functional-type/> .
@prefix phys: <https://schema.pragmaticbim.ch/ConnectionPhysicalType/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix map: <https://example.org/mapping/> .

map:connectionFunctionalToPhysicalTypeMapping a dcterms:Dataset ;
  dcterms:title "Connection functional type to physical type mapping"@en ;
  dcterms:title "Mapping funktionaler Verbindungstypen zu physischen Typen"@de ;
  dcterms:references func:scheme ;
  dcterms:description "Maps assignable connection functional types to compatible ConnectionPhysicalType enum values (IFC-aligned physical types). opening_other disambiguation is resolved at functional-type assignment, not by splitting the physical enum."@en ;
  dcterms:description "Ordnet zuweisbare funktionale Verbindungstypen kompatiblen ConnectionPhysicalType-Enum-Werten (IFC-ausgerichtete physische Typen) zu. opening_other wird ueber die funktionale Zuweisung aufgeloest, nicht durch Aufteilung des physischen Enums."@de .

func:electrical skos:relatedMatch phys:cable, phys:conduit .
func:data skos:relatedMatch phys:cable, phys:conduit .
func:ventilation skos:relatedMatch phys:duct .
func:heating skos:relatedMatch phys:pipe .
func:cooling skos:relatedMatch phys:pipe .
func:fresh_water skos:relatedMatch phys:pipe .
func:waste_water skos:relatedMatch phys:pipe .
func:special_media skos:relatedMatch phys:pipe, phys:network_other .
func:access skos:relatedMatch phys:door, phys:opening_other .
func:visual skos:relatedMatch phys:window, phys:opening_other .
