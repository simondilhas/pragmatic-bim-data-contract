  skos:prefLabel "Natural slate roof"@en ;
  skos:prefLabel "Naturschiefer-Dach"@de ;
  skos:definition "Natural slate tile pitched roof covering."@en ;
  skos:definition "Naturschiefer-Steildacheindeckung."@de ;
  dcterms:subject "IfcCovering" ;
  dcterms:subject "IfcRoof" ;
  dcterms:identifier "slate-roof" .

