  skos:topConceptOf :scheme ;
  skos:notation "RCP-METAL-SHEET" ;
  skos:prefLabel "Metal sheet roof"@en ;
  skos:prefLabel "Metallblech-Dach"@de ;
  skos:definition "Profiled metal sheet or standing-seam roof cladding on pitched or low-slope roofs."@en ;
  skos:definition "Profiliertes Metallblech- oder Stehfalzdach auf geneigten oder flachen Daechern."@de ;
  dcterms:subject "IfcCovering" ;
  dcterms:subject "IfcRoof" ;
  dcterms:identifier "metal-sheet-roof" .

