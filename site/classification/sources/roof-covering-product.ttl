  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "RCP-TILE-CLAY" ;
  skos:prefLabel "Clay tile roof"@en ;
  skos:prefLabel "Tonziegel-Dach"@de ;
  skos:definition "Clay or ceramic tile pitched roof covering with battens and underlay."@en ;
  skos:definition "Ton- oder Keramikziegel-Steildach mit Lattung und Unterspannbahn."@de ;
