@prefix : <https://example.org/abstract/roof-covering-product/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

:scheme a skos:ConceptScheme ;
  skos:prefLabel "Abstract roof covering products"@en ;
  skos:prefLabel "Abstrakte Dachbekleidungsprodukte"@de ;
  dcterms:title "Abstract roof covering products"@en ;
  dcterms:identifier "AbstractRoofCoveringProduct" ;
  dcterms:creator "abstract" ;
  dcterms:issued "2026-07-01" ;
  dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
  dcterms:source <https://github.com/simondilhas/pragmatic-bim-data-contract> ;
  skos:definition "Product-type classification for roof weatherproofing, cladding, and build-up systems above the structural roof slab. For catalog, specification, and cost workflows; pair with separator slab role L-ROF for structural context, slab separator products for the load-bearing deck, and abstract material classification for dominant substance."@en ;
  skos:definition "Produkttyp-Klassifikation fuer Dachabdichtungen, -bekleidungen und Aufbauten oberhalb der tragenden Dachdecke. Fuer Katalog-, Spezifikations- und Kostenworkflows; mit Trenndeckenrolle L-ROF fuer tragenden Kontext, Trenndeckenprodukten fuer die Tragplatte und abstrakter Materialklassifikation fuer dominante Substanz kombinieren."@de ;
  skos:scopeNote "Default PBS entity is Boundary with boundary_type roofing (IfcCovering ROOFING, IfcRoof where used). Tags weatherproofing and finish system, not the structural roof slab alone."@en ;
  skos:scopeNote "Standard-PBS-Entitaet ist Boundary mit boundary_type roofing (IfcCovering ROOFING, IfcRoof wo verwendet). Kennzeichnet Abdichtungs- und Fertigungssystem, nicht allein die tragende Dachplatte."@de ;
  skos:scopeNote "Subsystem assignment: assign one topConcept per roof covering element. Baseline cost uses the parent bundled price. Narrower layer concepts (*-INS, *-MEM, etc.) are LCA-only decomposition; do not use as primary classification_code."@en ;
  skos:scopeNote "Subsystem-Zuordnung: ein topConcept pro Dachbekleidungselement. Baseline-Kosten ueber gebündelten Elternpreis. Engere Schichtkonzepte (*-INS, *-MEM usw.) nur fuer Oekobilanz-Zerlegung; nicht als primaere classification_code verwenden."@de ;
  skos:hasTopConcept
    :RCP-FLAT-BITUMEN,
    :RCP-FLAT-SINGLE-PLY,
    :RCP-FLAT-LIQUID,
    :RCP-METAL-SHEET,
    :RCP-TILE-CLAY,
    :RCP-TILE-CONCRETE,
    :RCP-SLATE,
    :RCP-WOOD-SHINGLE,
    :RCP-GREEN-EXTENSIVE,
    :RCP-GREEN-INTENSIVE,
    :RCP-PV-ROOF,
    :RCP-OTH .

:RCP-FLAT-BITUMEN a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "RCP-FLAT-BITUMEN" ;
  skos:prefLabel "Built-up / bitumen flat roof"@en ;
  skos:prefLabel "Mehrlagen- / Bitumen-Flachdach"@de ;
  skos:definition "Multi-layer built-up or modified bitumen flat roof waterproofing system with insulation and protection layers."@en ;
  skos:definition "Mehrlagen- oder Polymerbitumen-Flachdachabdichtung mit Daemm- und Schutzschichten."@de ;
  skos:narrower :RCP-FLAT-BITUMEN-INS, :RCP-FLAT-BITUMEN-MEM ;
  dcterms:subject "IfcCovering" ;
  dcterms:subject "IfcRoof" ;
  dcterms:identifier "bitumen-flat-roof" .

:RCP-FLAT-BITUMEN-INS a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "RCP-FLAT-BITUMEN-INS" ;
  skos:prefLabel "Bitumen flat roof insulation layer"@en ;
  skos:prefLabel "Bitumen-Flachdach Daemmschicht"@de ;
  skos:definition "Insulation board or layer of a built-up bitumen flat roof system."@en ;
  skos:definition "Daemmplatten- oder -schicht eines mehrlagigen Bitumen-Flachdachs."@de ;
  skos:broader :RCP-FLAT-BITUMEN ;
  skos:scopeNote "LCA layer component of RCP-FLAT-BITUMEN. Used for ecobilans decomposition and carbon calculation; not a standalone roof product classification."@en ;
  skos:scopeNote "LCA-Schichtkomponente von RCP-FLAT-BITUMEN. Fuer Oekobilanz-Zerlegung und CO2-Berechnung; keine eigenstaendige Dachprodukt-Klassifikation."@de ;
  dcterms:subject "IfcCovering" ;
  dcterms:identifier "bitumen-flat-roof-insulation-layer" .

:RCP-FLAT-BITUMEN-MEM a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "RCP-FLAT-BITUMEN-MEM" ;
  skos:prefLabel "Bitumen flat roof membrane layer"@en ;
  skos:prefLabel "Bitumen-Flachdach Abdichtungsschicht"@de ;
  skos:definition "Primary waterproofing membrane layer of a built-up bitumen flat roof system."@en ;
  skos:definition "Primaere Abdichtungsschicht eines mehrlagigen Bitumen-Flachdachs."@de ;
  skos:broader :RCP-FLAT-BITUMEN ;
  skos:scopeNote "LCA layer component of RCP-FLAT-BITUMEN. Used for ecobilans decomposition and carbon calculation; not a standalone roof product classification."@en ;
  skos:scopeNote "LCA-Schichtkomponente von RCP-FLAT-BITUMEN. Fuer Oekobilanz-Zerlegung und CO2-Berechnung; keine eigenstaendige Dachprodukt-Klassifikation."@de ;
  dcterms:subject "IfcCovering" ;
  dcterms:identifier "bitumen-flat-roof-membrane-layer" .

:RCP-FLAT-SINGLE-PLY a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "RCP-FLAT-SINGLE-PLY" ;
  skos:prefLabel "Single-ply membrane flat roof"@en ;
  skos:prefLabel "Einfachlagen-Flachdach (EPDM / TPO / PVC)"@de ;
  skos:definition "Single-ply synthetic membrane flat roof system such as EPDM, TPO, or PVC with insulation and ballast or adhesive fixing."@en ;
  skos:definition "Einfachlagen-Kunststoffdach (EPDM, TPO oder PVC) mit Daemmung und Ballast oder Klebefixierung."@de ;
  skos:narrower :RCP-FLAT-SINGLE-PLY-INS, :RCP-FLAT-SINGLE-PLY-MEM ;
  dcterms:subject "IfcCovering" ;
  dcterms:subject "IfcRoof" ;
  dcterms:identifier "single-ply-flat-roof" .

:RCP-FLAT-SINGLE-PLY-INS a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "RCP-FLAT-SINGLE-PLY-INS" ;
  skos:prefLabel "Single-ply flat roof insulation layer"@en ;
  skos:prefLabel "Einfachlagen-Flachdach Daemmschicht"@de ;
  skos:definition "Insulation board or layer of a single-ply membrane flat roof system."@en ;
  skos:definition "Daemmplatten- oder -schicht eines Einfachlagen-Flachdachs."@de ;
  skos:broader :RCP-FLAT-SINGLE-PLY ;
  skos:scopeNote "LCA layer component of RCP-FLAT-SINGLE-PLY. Used for ecobilans decomposition and carbon calculation; not a standalone roof product classification."@en ;
  skos:scopeNote "LCA-Schichtkomponente von RCP-FLAT-SINGLE-PLY. Fuer Oekobilanz-Zerlegung und CO2-Berechnung; keine eigenstaendige Dachprodukt-Klassifikation."@de ;
  dcterms:subject "IfcCovering" ;
  dcterms:identifier "single-ply-flat-roof-insulation-layer" .

:RCP-FLAT-SINGLE-PLY-MEM a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "RCP-FLAT-SINGLE-PLY-MEM" ;
  skos:prefLabel "Single-ply flat roof membrane layer"@en ;
  skos:prefLabel "Einfachlagen-Flachdach Folien-Schicht"@de ;
  skos:definition "Primary single-ply waterproofing membrane layer of a flat roof system."@en ;
  skos:definition "Primaere Einfachlagen-Abdichtungsfolie eines Flachdachs."@de ;
  skos:broader :RCP-FLAT-SINGLE-PLY ;
  skos:scopeNote "LCA layer component of RCP-FLAT-SINGLE-PLY. Used for ecobilans decomposition and carbon calculation; not a standalone roof product classification."@en ;
  skos:scopeNote "LCA-Schichtkomponente von RCP-FLAT-SINGLE-PLY. Fuer Oekobilanz-Zerlegung und CO2-Berechnung; keine eigenstaendige Dachprodukt-Klassifikation."@de ;
  dcterms:subject "IfcCovering" ;
  dcterms:identifier "single-ply-flat-roof-membrane-layer" .

:RCP-FLAT-LIQUID a skos:Concept ;
