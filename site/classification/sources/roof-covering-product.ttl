  skos:prefLabel "Wood shingle / shake roof"@en ;
  skos:prefLabel "Holzschindel- / -schindeldach"@de ;
  skos:definition "Wood shingle, shake, or board pitched roof covering."@en ;
  skos:definition "Holzschindel-, Schindel- oder Brett-Steildach."@de ;
  dcterms:subject "IfcCovering" ;
  dcterms:subject "IfcRoof" ;
  dcterms:identifier "wood-shingle-roof" .

:RCP-GREEN-EXTENSIVE a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "RCP-GREEN-EXTENSIVE" ;
  skos:prefLabel "Extensive green roof"@en ;
  skos:prefLabel "Extensives Gruendach"@de ;
  skos:definition "Low-maintenance extensive sedum or lightweight green roof build-up on a waterproofed deck."@en ;
  skos:definition "Pflegearmes extensives Sedum- oder Leichtbau-Gruendach auf abgedichteter Decke."@de ;
  dcterms:subject "IfcCovering" ;
  dcterms:subject "IfcRoof" ;
  dcterms:identifier "extensive-green-roof" .

:RCP-GREEN-INTENSIVE a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "RCP-GREEN-INTENSIVE" ;
  skos:prefLabel "Intensive green roof"@en ;
  skos:prefLabel "Intensives Gruendach"@de ;
  skos:definition "Intensive accessible green roof or roof garden with deeper substrate and higher structural demand."@en ;
  skos:definition "Intensives begehbares Gruendach oder Dachgarten mit tieferem Substrat und hoeherer Traglast."@de ;
  dcterms:subject "IfcCovering" ;
  dcterms:subject "IfcRoof" ;
  dcterms:identifier "intensive-green-roof" .

:RCP-PV-ROOF a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "RCP-PV-ROOF" ;
  skos:prefLabel "Roof-mounted photovoltaic system"@en ;
  skos:prefLabel "Aufgestaendigtes Photovoltaik-Dach"@de ;
  skos:definition "Photovoltaic module array mounted on or integrated with the roof covering system."@en ;
  skos:definition "Photovoltaik-Modulanordnung auf oder integriert in das Dachbekleidungssystem."@de ;
  skos:scopeNote "Distinct from facade-integrated BIPV (FaCP-BIPV-INTEGRATED); roof skylights remain window connector products (WICP-SKYLIGHT)."@en ;
  skos:scopeNote "Unterscheidet sich von fassadenintegrierter BIPV (FaCP-BIPV-INTEGRATED); Dachfenster bleiben Fensterverbindungsprodukte (WICP-SKYLIGHT)."@de ;
  dcterms:subject "IfcCovering" ;
  dcterms:subject "IfcSolarDevice" ;
  dcterms:identifier "pv-roof" .

:RCP-OTH a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "RCP-OTH" ;
  skos:prefLabel "Other / unknown roof covering"@en ;
  skos:prefLabel "Sonstige / unbekannte Dachbekleidung"@de ;
  skos:definition "Roof covering product not classified or not yet known."@en ;
  skos:definition "Dachbekleidungsprodukt nicht klassifiziert oder noch unbekannt."@de ;
  skos:scopeNote "Fallback for early design stages or missing data."@en ;
  skos:scopeNote "Fallback fuer fruehe Entwurfsstufen oder fehlende Daten."@de ;
  dcterms:subject "IfcCovering" ;
  dcterms:identifier "other" .
