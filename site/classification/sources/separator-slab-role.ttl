@prefix : <https://example.org/abstract/separator-slab-role-classification/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

:scheme a skos:ConceptScheme ;
  skos:prefLabel "Building Separator Slab Role Classification"@en ;
  skos:prefLabel "Klassifikation der Trenndeckenrollen"@de ;
  dcterms:title "Building Separator Slab Role Classification"@en ;
  dcterms:identifier "BuildingSeparatorSlabRoleClassification" ;
  dcterms:creator "abstract" ;
  dcterms:issued "2026-06-02" ;
  dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
  skos:definition "Topological role classification for slab-based separating elements (SeparatorSlab), grouped by slab element type and adjacent space relationships."@en ;
  skos:definition "Topologische Rollenklassifikation fuer deckenbasierte Trennelemente (SeparatorSlab), gruppiert nach Deckenelementtyp und angrenzenden Raumbeziehungen."@de ;
  skos:hasTopConcept :L_BAS, :L_FLR, :L_ROF .

:L_BAS a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "L-BAS" ;
  skos:prefLabel "Base slab"@en ;
  skos:prefLabel "Bodenplatte"@de ;
  skos:definition "Slab at or below ground level forming the primary separation between the building and earth or below-grade conditions."@en ;
  skos:definition "Platte auf oder unter Gelaendehoehe als primaere Abgrenzung zwischen Gebaeude und Erdreich oder unterirdischen Bedingungen."@de ;
  dcterms:description "Including foundation slabs, basement floor slabs, and cellar decks."@en ;
  dcterms:description "Einschliesslich Fundamentplatten, Kellerdecken und Untergeschossabgrenzungen."@de ;
  dcterms:subject "IfcSlab" ;
  dcterms:identifier "L-BAS" .

:L_FLR a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "L-FLR" ;
  skos:prefLabel "Floor slab"@en ;
  skos:prefLabel "Geschossdecke"@de ;
  skos:definition "Horizontal slab separating occupied levels, excluding base slab and roof roles."@en ;
  skos:definition "Horizontale Decke zur Trennung genutzter Geschosse, ohne Bodenplatten- oder Dachrolle."@de ;
  skos:narrower :L_FLR_INT, :L_FLR_EXT ;
  dcterms:description "Including typical story floors, landings, and mezzanine decks; subdivided by interior and exterior exposure."@en ;
  dcterms:description "Einschliesslich uebliche Geschossdecken, Podeste und Zwischengeschosse; unterteilt nach innerer und aeusserer Exposition."@de ;
  dcterms:subject "IfcSlab" ;
  dcterms:identifier "L-FLR" .

:L_FLR_INT a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "L-FLR-INT" ;
  skos:prefLabel "Interior floor slab"@en ;
  skos:prefLabel "Innere Geschossdecke"@de ;
  skos:definition "Floor slab separating interior spaces or levels within the building envelope."@en ;
  skos:definition "Geschossdecke, die Innenraeume oder Geschosse innerhalb der Gebaeudehuelle voneinander trennt."@de ;
  dcterms:description "Including typical story floors, corridor floors, mezzanines, and unit boundary floors."@en ;
  dcterms:description "Einschliesslich uebliche Geschossdecken, Korridorboeden, Zwischengeschosse und Decken zwischen Nutzungseinheiten."@de ;
  skos:broader :L_FLR ;
  dcterms:subject "IfcSlab" ;
  dcterms:identifier "L-FLR-INT" .

:L_FLR_EXT a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "L-FLR-EXT" ;
  skos:prefLabel "Exterior floor slab"@en ;
  skos:prefLabel "Aussere Geschossdecke"@de ;
  skos:definition "Floor slab exposed to the exterior environment."@en ;
  skos:definition "Geschossdecke mit Exposition zur Aussenumgebung."@de ;
  dcterms:description "Including balcony slabs, terrace decks, and other exterior horizontal walking surfaces."@en ;
  dcterms:description "Einschliesslich Balkonplatten, Terrassendecken und andere horizontale Aussenbelaege."@de ;
  skos:broader :L_FLR ;
  dcterms:subject "IfcSlab" ;
  dcterms:identifier "L-FLR-EXT" .

:L_ROF a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "L-ROF" ;
  skos:prefLabel "Roof slab"@en ;
  skos:prefLabel "Dachdecke"@de ;
  skos:definition "Slab forming the primary weather-exposed separation at roof level."@en ;
  skos:definition "Decke als primaere wetterexponierte Abgrenzung auf Dachniveau."@de ;
  dcterms:description "Including flat roof decks, pitched roof structural slabs, and top-floor roof build-up separations."@en ;
  dcterms:description "Einschliesslich Flachdachplatten, tragende Dachdecken und oberste Geschossabgrenzungen im Dachaufbau."@de ;
  dcterms:subject "IfcSlab" ;
  dcterms:identifier "L-ROF" .
