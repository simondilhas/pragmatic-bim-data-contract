# --- politics ---

:politics a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "POL" ;
  skos:prefLabel "Politics"@en ;
  skos:prefLabel "Politik"@de ;
  skos:narrower :politics_austria, :politics_eu, :politics_active, :politics_retired .

:politics_austria a skos:Concept ;
  skos:inScheme :scheme ;
  skos:broader :politics ;
  skos:notation "POL-AT" ;
  skos:prefLabel "Austria"@en ;
  skos:prefLabel "Österreich"@de ;
  skos:scopeNote "Austrian national or federal politics and public affairs."@en ;
  skos:scopeNote "Österreichische nationale oder bundespolitische Tätigkeit."@de .

:politics_eu a skos:Concept ;
  skos:inScheme :scheme ;
  skos:broader :politics ;
  skos:notation "POL-EU" ;
  skos:prefLabel "European Union"@en ;
  skos:prefLabel "EU"@de ;
  skos:scopeNote "EU-level politics and institutions."@en ;
  skos:scopeNote "Politik und Institutionen auf EU-Ebene."@de .

:politics_active a skos:Concept ;
  skos:inScheme :scheme ;
  skos:broader :politics ;
  skos:notation "POL-ACT" ;
  skos:prefLabel "Active"@en ;
  skos:prefLabel "Aktiv"@de ;
  skos:altLabel "Active in politics"@en ;
  skos:scopeNote "Currently holding or actively pursuing a political mandate or office."@en ;
  skos:scopeNote "Derzeit politisches Mandat oder Amt innehabend oder aktiv anstreben."@de .

:politics_retired a skos:Concept ;
  skos:inScheme :scheme ;
  skos:broader :politics ;
  skos:notation "POL-RET" ;
  skos:prefLabel "In retirement"@en ;
  skos:prefLabel "Im Ruhestand"@de ;
  skos:altLabel "Retired from politics"@en ;
  skos:altLabel "i.R."@de ;
  skos:scopeNote "Former political mandate holder; no longer active in office."@en ;
  skos:scopeNote "Ehemaliges politisches Mandat; nicht mehr im Amt."@de .

