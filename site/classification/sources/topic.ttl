@prefix : <https://example.org/ch/abstract-topic/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

:scheme a skos:ConceptScheme ;
  skos:prefLabel "Abstract topic classification"@en ;
  skos:prefLabel "Abstrakte Themen-Klassifikation"@de ;
  dcterms:title "Abstract topic classification"@en ;
  dcterms:identifier "AbstractTopicClassification" ;
  dcterms:creator "pragmatic-bim-public-rules" ;
  dcterms:issued "2026-07-08" ;
  dcterms:description "General person interests and subject areas for CRM stories and LLM extraction."@en ;
  dcterms:description "Allgemeine Personeninteressen und Themenbereiche für CRM-Geschichten und LLM-Extraktion."@de ;
  skos:hasTopConcept :arts_entertainment, :sports_recreation, :professional, :travel, :food_drink, :politics, :causes, :family .

# --- arts_entertainment ---

:arts_entertainment a skos:Concept ;
