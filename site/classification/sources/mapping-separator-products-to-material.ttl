@prefix swp: <https://example.org/abstract/wall-separator-product/> .
@prefix ssp: <https://example.org/abstract/slab-separator-product/> .
@prefix mat: <https://example.org/abstract/material-classification/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix map: <https://example.org/mapping/> .

map:abstractSeparatorProductsToMaterialMapping a dcterms:Dataset ;
  dcterms:title "Abstract separator products to material mapping"@en ;
  dcterms:title "Mapping abstrakter Trennelementprodukte nach Material"@de ;
  dcterms:references swp:scheme, ssp:scheme, mat:scheme ;
  dcterms:issued "2026-06-30" ;
  dcterms:description "Maps abstract wall and slab separator product concepts to dominant-substance material classes. Uses skos:closeMatch for primary substance; skos:relatedMatch where composite or variable."@en ;
  dcterms:description "Ordnet abstrakte Wand- und Deckenplatten-Trennelementprodukte dominanten Materialklassen zu. skos:closeMatch fuer primaere Substanz; skos:relatedMatch bei Verbund oder Variabilitaet."@de .

# --- Wall separator products ---

swp:SWP-ORTBETON skos:closeMatch mat:MAT-CONC .

swp:SWP-MASONRY skos:closeMatch mat:MAT-MSN ;
  skos:relatedMatch mat:MAT-CONC .

swp:SWP-RAMMED-EARTH skos:closeMatch mat:MAT-MSN ;
  skos:relatedMatch mat:MAT-CMP .

swp:SWP-BLT skos:closeMatch mat:MAT-CONC ;
  skos:relatedMatch mat:MAT-CMP .

swp:SWP-PREFAB-CONC skos:closeMatch mat:MAT-CONC ;
  skos:relatedMatch mat:MAT-CMP .

swp:SWP-STEEL skos:closeMatch mat:MAT-MET-STL .

swp:SWP-TIMBER skos:closeMatch mat:MAT-WOD ;
  skos:relatedMatch mat:MAT-CMP .

swp:SWP-LEICHTBAU skos:closeMatch mat:MAT-CMP ;
  skos:relatedMatch mat:MAT-GYP, mat:MAT-PLA .

swp:SWP-CURTAIN-WALL skos:closeMatch mat:MAT-MET-ALU ;
  skos:relatedMatch mat:MAT-GLS, mat:MAT-PLA .

swp:SWP-ELEMENT-WALL skos:closeMatch mat:MAT-GYP ;
  skos:relatedMatch mat:MAT-CMP, mat:MAT-MET-STL .

swp:SWP-OTH skos:closeMatch mat:MAT-OTH .

# --- Slab separator products ---

ssp:SSP-INSITU skos:closeMatch mat:MAT-CONC .

ssp:SSP-PREFAB-CONC skos:closeMatch mat:MAT-CONC ;
  skos:relatedMatch mat:MAT-CMP .

ssp:SSP-STEEL-COMPOSITE skos:closeMatch mat:MAT-MET-STL ;
  skos:relatedMatch mat:MAT-CONC .

ssp:SSP-TIMBER skos:closeMatch mat:MAT-WOD ;
  skos:relatedMatch mat:MAT-CMP .

ssp:SSP-CLT skos:closeMatch mat:MAT-WOD ;
  skos:relatedMatch mat:MAT-CMP .

ssp:SSP-HBV skos:closeMatch mat:MAT-CMP ;
  skos:relatedMatch mat:MAT-WOD, mat:MAT-CONC .

ssp:SSP-HBV-WOD skos:closeMatch mat:MAT-WOD .

ssp:SSP-HBV-CONC skos:closeMatch mat:MAT-CONC .

ssp:SSP-HOLZ-LEHM skos:closeMatch mat:MAT-WOD ;
  skos:relatedMatch mat:MAT-MSN, mat:MAT-CMP .

ssp:SSP-HOLZ-LEHM-WOD skos:closeMatch mat:MAT-WOD .

ssp:SSP-HOLZ-LEHM-MSN skos:closeMatch mat:MAT-MSN .

ssp:SSP-LIGHTWEIGHT skos:closeMatch mat:MAT-CMP ;
  skos:relatedMatch mat:MAT-INS .

ssp:SSP-STEEL-COMPOSITE skos:closeMatch mat:MAT-MET-STL ;
  skos:relatedMatch mat:MAT-CONC .

ssp:SSP-STEEL-COMPOSITE-STL skos:closeMatch mat:MAT-MET-STL .

ssp:SSP-STEEL-COMPOSITE-CONC skos:closeMatch mat:MAT-CONC .

ssp:SSP-OTH skos:closeMatch mat:MAT-OTH .
