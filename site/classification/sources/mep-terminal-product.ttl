  dcterms:identifier "hose-reel" .

# --- Fire safety (FIRE, cross-cutting) ---

:MTP-FIRE-FIRE-DAMPER a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "MTP-FIRE-FIRE-DAMPER" ;
  skos:prefLabel "Fire damper"@en ;
  skos:prefLabel "Brandschutzklappe"@de ;
  skos:definition "Fire damper (Brandschutzklappe) inline on whichever host distribution system it serves."@en ;
  skos:definition "Brandschutzklappe inline am jeweiligen Verteilungssystem."@de ;
  skos:scopeNote "Cross-cutting: discipline inherited from inline host system (ventilation, heating, or cooling)."@en ;
  skos:scopeNote "Querschnitt: Disziplin wird vom Inline-Hostsystem uebernommen (Lueftung, Heizung oder Kuehlung)."@de ;
  dcterms:subject "IfcDamper" ;
  dcterms:identifier "fire-damper" .

:MTP-FIRE-FIRE-DAMPER-ACTUATOR a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "MTP-FIRE-FIRE-DAMPER-ACTUATOR" ;
  skos:prefLabel "Fire damper actuator"@en ;
  skos:prefLabel "Brandschutzklappen-Antrieb"@de ;
  skos:definition "Actuator for fire damper or smoke control damper."@en ;
  skos:definition "Antrieb fuer Brandschutz- oder Rauchschutzklappe."@de ;
  skos:scopeNote "Cross-cutting: discipline inherited from inline host system."@en ;
  skos:scopeNote "Querschnitt: Disziplin wird vom Inline-Hostsystem uebernommen."@de ;
  dcterms:subject "IfcActuator" ;
  dcterms:identifier "fire-damper-actuator" .

:MTP-FIRE-SMOKE-DETECTOR a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "MTP-FIRE-SMOKE-DETECTOR" ;
  skos:prefLabel "Smoke detector"@en ;
  skos:prefLabel "Rauchmelder"@de ;
  skos:definition "Smoke detector or fire alarm initiating device."@en ;
  skos:definition "Rauchmelder oder Brandmelder-Initialisierungseinrichtung."@de ;
  skos:scopeNote "Cross-cutting: typically on electrical or data fire-alarm system; discipline from parent system."@en ;
  skos:scopeNote "Querschnitt: typischerweise an elektrischem oder Daten-Brandmeldesystem; Disziplin vom Elternsystem."@de ;
  dcterms:subject "IfcSensor, IfcAlarm" ;
  dcterms:identifier "smoke-detector" .
