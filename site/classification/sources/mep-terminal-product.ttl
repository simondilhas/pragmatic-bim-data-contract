:MTP-FW-WC-FLUSH a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "MTP-FW-WC-FLUSH" ;
  skos:prefLabel "WC flush valve"@en ;
  skos:prefLabel "WC-Spuelung"@de ;
