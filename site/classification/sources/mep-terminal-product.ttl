  dcterms:identifier "ufh-manifold" .

:MTP-HEAT-FAN-COIL a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "MTP-HEAT-FAN-COIL" ;
  skos:prefLabel "Fan coil (heating mode)"@en ;
  skos:prefLabel "Geblaesekonvektor (Heizbetrieb)"@de ;
  skos:definition "Fan coil unit operating in heating mode on a heating distribution system."@en ;
  skos:definition "Geblaesekonvektor im Heizbetrieb an einem Heizverteilungssystem."@de ;
  dcterms:subject "IfcUnitaryEquipment" ;
  dcterms:identifier "fan-coil-heat" .

# --- Cooling (COOL) ---

:MTP-COOL-FAN-COIL a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "MTP-COOL-FAN-COIL" ;
  skos:prefLabel "Fan coil (cooling mode)"@en ;
  skos:prefLabel "Geblaesekonvektor (Kuehlbetrieb)"@de ;
  skos:definition "Fan coil unit operating in cooling mode on a chilled-water or DX system."@en ;
  skos:definition "Geblaesekonvektor im Kuehlbetrieb an einem Kaltwasser- oder DX-System."@de ;
  dcterms:subject "IfcUnitaryEquipment" ;
