  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "MTP-SM-GAS-OUTLET" ;
  skos:prefLabel "Gas outlet valve"@en ;
  skos:prefLabel "Gasentnahmestelle"@de ;
  skos:definition "Gas outlet terminal or appliance connection valve."@en ;
  skos:definition "Gasentnahmestelle oder Geraeteanschlussventil."@de ;
  dcterms:subject "IfcGasTerminal" ;
  dcterms:identifier "gas-outlet" .

