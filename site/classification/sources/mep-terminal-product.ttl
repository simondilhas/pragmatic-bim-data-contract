@prefix : <https://example.org/abstract/mep-terminal-product/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

:scheme a skos:ConceptScheme ;
  skos:prefLabel "Abstract MEP terminal products"@en ;
  skos:prefLabel "Abstrakte TGA-Endgeraeteprodukte"@de ;
  dcterms:title "Abstract MEP terminal products"@en ;
  dcterms:identifier "AbstractMepTerminalProduct" ;
  dcterms:creator "abstract" ;
  dcterms:issued "2026-07-02" ;
  dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
  dcterms:source <https://github.com/simondilhas/pragmatic-bim-data-contract> ;
  skos:definition "Product-type classification for MEP end devices and terminals located in served spaces (aligns with SystemType.terminal). For catalog, specification, and cost workflows on Equipment."@en ;
  skos:definition "Produkttyp-Klassifikation fuer TGA-Endgeraete und Terminals in versorgten Raeumen (entspricht SystemType.terminal). Fuer Katalog-, Spezifikations- und Kostenworkflows auf Equipment."@de ;
  skos:scopeNote "Default PBS entity is Equipment. Discipline token in notation must be compatible with parent system ConnectionFunctionalType via mapping bridge, except MTP-FIRE-* cross-cutting terminals where discipline is inherited from the inline host system."@en ;
  skos:scopeNote "Standard-PBS-Entitaet ist Equipment. Disziplin-Token in der Notation muss ueber Mapping-Bruecke mit ConnectionFunctionalType des Elternsystems kompatibel sein, ausser MTP-FIRE-* Querschnitts-Endgeraete, bei denen die Disziplin vom Inline-Hostsystem uebernommen wird."@de ;
  skos:hasTopConcept
    :MTP-ELEC-SOCKET,
    :MTP-ELEC-LIGHT,
    :MTP-ELEC-SWITCH,
    :MTP-DATA-DATA-OUTLET,
    :MTP-DATA-WIFI-AP,
    :MTP-DATA-SENSOR-ACTUATOR,
    :MTP-VENT-AIR-VALVE,
    :MTP-VENT-GRILLE,
    :MTP-HEAT-RADIATOR,
    :MTP-HEAT-UFH-MANIFOLD,
    :MTP-HEAT-FAN-COIL,
    :MTP-COOL-FAN-COIL,
    :MTP-COOL-CHILLED-CEILING,
    :MTP-FW-TAP,
    :MTP-FW-SHOWER,
    :MTP-FW-WC-FLUSH,
    :MTP-WW-FLOOR-DRAIN,
    :MTP-WW-WC-OUTLET,
    :MTP-WW-SINK-DRAIN,
    :MTP-SM-GAS-OUTLET,
    :MTP-SM-SPRINKLER-HEAD,
    :MTP-SM-HOSE-REEL,
    :MTP-FIRE-FIRE-DAMPER,
    :MTP-FIRE-FIRE-DAMPER-ACTUATOR,
    :MTP-FIRE-SMOKE-DETECTOR .

# --- Electrical (ELEC) ---

:MTP-ELEC-SOCKET a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "MTP-ELEC-SOCKET" ;
  skos:prefLabel "Socket outlet"@en ;
  skos:prefLabel "Steckdose"@de ;
  skos:definition "Electrical socket outlet or power connection point."@en ;
  skos:definition "Elektrische Steckdose oder Stromanschlusspunkt."@de ;
  dcterms:subject "IfcOutlet" ;
  dcterms:identifier "socket" .

:MTP-ELEC-LIGHT a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "MTP-ELEC-LIGHT" ;
  skos:prefLabel "Light fixture"@en ;
  skos:prefLabel "Leuchte"@de ;
  skos:definition "Fixed or portable luminaire or light fixture."@en ;
  skos:definition "Feste oder mobile Leuchte."@de ;
  dcterms:subject "IfcLightFixture" ;
  dcterms:identifier "light" .

:MTP-ELEC-SWITCH a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "MTP-ELEC-SWITCH" ;
  skos:prefLabel "Switch"@en ;
  skos:prefLabel "Schalter"@de ;
  skos:definition "Electrical switching device for lighting or power circuits."@en ;
  skos:definition "Elektrisches Schaltgeraet fuer Beleuchtungs- oder Stromkreise."@de ;
  dcterms:subject "IfcSwitchingDevice" ;
  dcterms:identifier "switch" .

# --- Data / ICT (DATA) ---

:MTP-DATA-DATA-OUTLET a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "MTP-DATA-DATA-OUTLET" ;
  skos:prefLabel "Data outlet"@en ;
  skos:prefLabel "Datendose"@de ;
  skos:definition "Structured cabling data outlet or telecom connection point."@en ;
  skos:definition "Datendose oder Telekom-Anschlusspunkt der strukturierten Verkabelung."@de ;
  dcterms:subject "IfcOutlet, IfcCommunicationsAppliance" ;
  dcterms:identifier "data-outlet" .

:MTP-DATA-WIFI-AP a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "MTP-DATA-WIFI-AP" ;
  skos:prefLabel "WiFi access point"@en ;
  skos:prefLabel "WLAN-Access-Point"@de ;
  skos:definition "Wireless LAN access point or distributed antenna node."@en ;
  skos:definition "WLAN-Access-Point oder Distributed-Antenna-Knoten."@de ;
  dcterms:subject "IfcCommunicationsAppliance" ;
  dcterms:identifier "wifi-ap" .

:MTP-DATA-SENSOR-ACTUATOR a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "MTP-DATA-SENSOR-ACTUATOR" ;
  skos:prefLabel "Sensor / actuator (KNX / BACnet)"@en ;
  skos:prefLabel "Sensor / Aktuator (KNX / BACnet)"@de ;
  skos:definition "Building automation field device such as KNX or BACnet sensor or actuator."@en ;
  skos:definition "Gebaeudeautomations-Feldgeraet wie KNX- oder BACnet-Sensor oder -Aktuator."@de ;
  dcterms:subject "IfcSensor, IfcActuator" ;
  dcterms:identifier "sensor-actuator" .

# --- Ventilation (VENT) ---

:MTP-VENT-AIR-VALVE a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "MTP-VENT-AIR-VALVE" ;
  skos:prefLabel "Supply / extract air valve or diffuser"@en ;
  skos:prefLabel "Zuluft- / Abluftventil oder Diffusor"@de ;
  skos:definition "Supply, extract, or transfer air terminal, valve, or diffuser."@en ;
  skos:definition "Zuluft-, Abluft- oder Umluft-Endgeraet, Ventil oder Diffusor."@de ;
  dcterms:subject "IfcAirTerminal, IfcAirTerminalBox" ;
  dcterms:identifier "air-valve" .

:MTP-VENT-GRILLE a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "MTP-VENT-GRILLE" ;
  skos:prefLabel "Grille"@en ;
  skos:prefLabel "Gitter / Luftgitter"@de ;
  skos:definition "Air transfer grille or linear slot diffuser without active control."@en ;
  skos:definition "Luftuebergangs-Gitter oder Linearschlitz ohne aktive Regelung."@de ;
  dcterms:subject "IfcAirTerminal" ;
  dcterms:identifier "grille" .

# --- Heating (HEAT) ---

:MTP-HEAT-RADIATOR a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "MTP-HEAT-RADIATOR" ;
  skos:prefLabel "Radiator"@en ;
  skos:prefLabel "Radiator / Heizkoerper"@de ;
  skos:definition "Space heating radiator or convector terminal."@en ;
  skos:definition "Raumheiz-Radiator oder Konvektor-Endgeraet."@de ;
  dcterms:subject "IfcSpaceHeater" ;
  dcterms:identifier "radiator" .

:MTP-HEAT-UFH-MANIFOLD a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "MTP-HEAT-UFH-MANIFOLD" ;
  skos:prefLabel "Underfloor heating manifold"@en ;
  skos:prefLabel "Heizkreisverteiler (FBH)"@de ;
  skos:definition "Underfloor heating manifold or circuit distributor (Heizkreisverteiler)."@en ;
  skos:definition "Fussbodenheizungs-Heizkreisverteiler."@de ;
