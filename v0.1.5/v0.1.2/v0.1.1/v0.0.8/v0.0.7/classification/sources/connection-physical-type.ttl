@prefix : <https://example.org/abstract/connection-physical-type/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

:scheme a skos:ConceptScheme ;
  skos:prefLabel "Connection Physical Type"@en ;
  skos:prefLabel "Typ physischer Verbindungselemente"@de ;
  dcterms:title "Connection Physical Type"@en ;
  dcterms:identifier "ConnectionPhysicalType" ;
  dcterms:creator "abstract" ;
  dcterms:issued "2026-06-02" ;
  dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
  skos:definition "Classification of physical connector elements that connect spaces, aligned with IFC entity types."@en ;
  skos:definition "Klassifikation physischer Verbindungselemente, die Raeume verbinden, abgestimmt auf IFC-Entitaetstypen."@de ;
  skos:hasTopConcept :door, :window, :duct, :pipe, :cable, :conduit, :opening_other, :network_other .

:door a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "door" ;
  skos:prefLabel "Door"@en ;
  skos:prefLabel "Tuer"@de ;
  skos:definition "Human access connector via a door element."@en ;
  skos:definition "Zugangsverbindung fuer Personen ueber ein Tuerlement."@de ;
  dcterms:subject "IfcDoor" ;
  dcterms:identifier "door" .

:window a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "window" ;
  skos:prefLabel "Window"@en ;
  skos:prefLabel "Fenster"@de ;
  skos:definition "Visual and daylight connector via a window element."@en ;
  skos:definition "Sicht- und Tageslichtverbindung ueber ein Fensterelement."@de ;
  dcterms:subject "IfcWindow" ;
  dcterms:identifier "window" .

:duct a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "duct" ;
  skos:prefLabel "Duct"@en ;
  skos:prefLabel "Luftkanal"@de ;
  skos:definition "Air distribution connector segment."@en ;
  skos:definition "Verbindungssegment fuer Luftverteilung."@de ;
  dcterms:subject "IfcDuctSegment" ;
  dcterms:identifier "duct" .

:pipe a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "pipe" ;
  skos:prefLabel "Pipe"@en ;
  skos:prefLabel "Rohr"@de ;
  skos:definition "Fluid or gas distribution connector segment."@en ;
  skos:definition "Verbindungssegment fuer Fluessigkeits- oder Gasverteilung."@de ;
  dcterms:subject "IfcPipeSegment" ;
  dcterms:identifier "pipe" .

:cable a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "cable" ;
  skos:prefLabel "Cable"@en ;
  skos:prefLabel "Kabel"@de ;
  skos:definition "Electrical or data cable connector segment."@en ;
  skos:definition "Verbindungssegment fuer elektrische oder Datenkabel."@de ;
  dcterms:subject "IfcCableSegment" ;
  dcterms:identifier "cable" .

:conduit a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "conduit" ;
  skos:prefLabel "Conduit"@en ;
  skos:prefLabel "Leerrohr"@de ;
  skos:definition "Electrical or data conduit connector segment."@en ;
  skos:definition "Verbindungssegment fuer elektrische oder Datenleerrohre."@de ;
  dcterms:subject "IfcConduitSegment" ;
  dcterms:identifier "conduit" .

:opening_other a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "opening_other" ;
  skos:prefLabel "Opening Other"@en ;
  skos:prefLabel "Sonstige Oeffnung"@de ;
  skos:definition "Other opening-style connector not covered by door or window."@en ;
  skos:definition "Sonstige oeffnungsartige Verbindung, die nicht durch Tuer oder Fenster abgedeckt ist."@de ;
  dcterms:subject "IfcOpeningElement" ;
  dcterms:identifier "opening_other" .

:network_other a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "network_other" ;
  skos:prefLabel "Network Other"@en ;
  skos:prefLabel "Sonstiges Netz"@de ;
  skos:definition "Other network connector segment not covered by controlled values."@en ;
  skos:definition "Sonstiges Netzverbindungssegment, das nicht durch kontrollierte Werte abgedeckt ist."@de ;
  dcterms:subject "IfcFlowSegment" ;
  dcterms:identifier "network_other" .
