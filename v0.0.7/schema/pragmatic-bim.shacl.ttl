pbs:Entity a sh:NodeShape ;
    rdfs:comment "Common base class for all schema entities." ;
    sh:closed false ;
    sh:ignoredProperties ( dcterms:type pbs:planned_finish_at pbs:contact_points pbs:parent_project pbs:actual_finish_at pbs:serves_spaces pbs:separator_requirement_drivers pbs:separator_wall_type pbs:applies_to_entities pbs:parent_building pbs:time_plan pbs:transport_medium pbs:group_members pbs:connects_spaces pbs:cost_quantity_unit pbs:bounded_by pbs:separates_levels pbs:cost_records pbs:separates_spaces pbs:space_type pbs:connection_physical_type pbs:parent_perimeter pbs:parent_legal_site pbs:context_type pbs:materials pbs:connection_virtual_requirement_drivers pbs:component_time_items pbs:cost_quantity_value pbs:contained_entities pbs:system_type pbs:separator_slab_type rdf:type pbs:connects_physical_elements pbs:parent_zone pbs:component_cost_items pbs:serves_zones pbs:actual_start_at <http://schema.org/dateSent> pbs:zone_type pbs:planned_start_at pbs:currency pbs:boundary_type <http://schema.org/text> pbs:cost_quantity_type pbs:system_discipline pbs:belongs_to_company <http://schema.org/sender> pbs:material_specification pbs:parent_space pbs:cost_category <http://schema.org/recipient> pbs:unit_cost pbs:connection_virtual_type pbs:parent_level <http://schema.org/headline> pbs:material_category pbs:postal_addresses pbs:milestone_at pbs:successors pbs:equipment_type pbs:time_records pbs:connection_physical_requirement_drivers pbs:parent_system pbs:bounded_space ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Unique local identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path pbs:id ],
        [ sh:class pbs:LocalizedText ;
            sh:description "Localized variants of name." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path pbs:localized_names ],
