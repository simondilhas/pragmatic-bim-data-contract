        [ sh:defaultValue "FS" ;
            sh:description "FS | SS | FF | SF" ;
            sh:in ( pbs:dependency_type_finish_to_start pbs:dependency_type_start_to_start pbs:dependency_type_finish_to_finish pbs:dependency_type_start_to_finish ) ;
            sh:maxCount 1 ;
