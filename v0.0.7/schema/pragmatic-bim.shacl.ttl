pbs:VirtualEntity a sh:NodeShape ;
    rdfs:comment "Abstract base class for non-physical, conceptual, or informational entities." ;
    sh:closed false ;
    sh:ignoredProperties ( pbs:planned_finish_at pbs:parent_project pbs:actual_finish_at pbs:serves_spaces pbs:applies_to_entities pbs:parent_building pbs:time_plan pbs:group_members pbs:connects_spaces pbs:cost_quantity_unit pbs:bounded_by pbs:space_type pbs:parent_perimeter pbs:parent_legal_site pbs:context_type pbs:connection_virtual_requirement_drivers pbs:component_time_items pbs:cost_quantity_value pbs:contained_entities pbs:system_type rdf:type pbs:connects_physical_elements pbs:parent_zone pbs:component_cost_items pbs:serves_zones pbs:actual_start_at pbs:planned_start_at pbs:zone_type pbs:currency pbs:cost_quantity_type pbs:system_discipline pbs:material_specification pbs:cost_category pbs:connection_virtual_type pbs:unit_cost pbs:parent_level pbs:material_category pbs:milestone_at pbs:successors ) ;
    sh:property [ sh:class pbs:GeometryRepresentation ;
            sh:description """Geometry references associated with the entity. A single element may link to multiple geometry representations to serve different intents (authoring, coordination, analysis, visualization) without duplicating the element itself.
""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path pbs:geometry_representations ],
        [ sh:class pbs:TimeRecord ;
            sh:description "Time records associated with this entity." ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path pbs:time_records ],
        [ sh:class pbs:Document ;
            sh:description "Linked documents associated with this entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path pbs:documents ],
        [ sh:class pbs:CostRecord ;
            sh:description "Cost records associated with this entity." ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path pbs:cost_records ],
        [ sh:class pbs:Task ;
            sh:description "Tasks associated with this entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path pbs:tasks ],
        [ sh:class pbs:MetadataEntry ;
            sh:description "Generic metadata container for IFC attributes/properties and project-specific extensions." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path pbs:metadata ],
        [ sh:description "Optional semantic URI for linking the entity instance to an external ontology concept." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path pbs:meaning_uri ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp for this entity record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path pbs:created_at ],
        [ sh:datatype xsd:integer ;
            sh:description "Integer revision counter for change tracking." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path pbs:revision ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Last modification timestamp for this entity record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path pbs:modified_at ],
        [ sh:datatype xsd:string ;
            sh:description "IFC GlobalId of the mapped entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path pbs:ifc_global_id ;
            sh:pattern "^[0-3][0-9A-Za-z_$]{21}$" ],
        [ sh:class pbs:PerformanceProperty ;
            sh:description """Normalized, strongly typed domain properties (fire/acoustic/thermal/structural/ security/material) extracted from raw IFC PropertySet values.
""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path pbs:performance_properties ],
        [ sh:class pbs:Material ;
            sh:description "Material definitions associated with this entity." ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path pbs:materials ],
        [ sh:datatype xsd:string ;
            sh:description "Default description text." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path pbs:description ],
        [ sh:class pbs:Classification ;
            sh:description "Classification entries from IFC and other schemes." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path pbs:classifications ],
        [ sh:class pbs:LocalizedText ;
            sh:description "Localized variants of description." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path pbs:localized_descriptions ],
        [ sh:datatype xsd:string ;
            sh:description "Unique local identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path pbs:id ],
        [ sh:datatype xsd:string ;
            sh:description "Default display name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path pbs:name ],
        [ sh:class pbs:LocalizedText ;
            sh:description "Localized variants of name." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path pbs:localized_names ],
        [ sh:class pbs:QuantityValue ;
            sh:description "Quantities associated with the entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path pbs:quantity_values ],
        [ sh:class pbs:Message ;
            sh:description "Messages associated with this entity." ;
            sh:nodeKind sh:IRI ;
            sh:order 18 ;
            sh:path pbs:messages ],
        [ sh:class pbs:Decision ;
            sh:description "Decision records associated with this entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path pbs:decisions ],
        [ sh:description "Lifecycle or QA status." ;
            sh:in ( pbs:status_draft pbs:status_submitted pbs:status_reviewed pbs:status_approved pbs:status_rejected pbs:status_archived ) ;
            sh:maxCount 1 ;
            sh:order 22 ;
            sh:path pbs:status ] ;
