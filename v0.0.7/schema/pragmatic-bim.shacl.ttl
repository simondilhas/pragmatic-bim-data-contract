pbs:Change a sh:NodeShape ;
    rdfs:comment """Detected difference for one subject between two revisions (content_kind change). Supports IFC model diffs, document/text diffs, and schema-entity field changes. Use change_type together with the concrete subclass for interpretation.
""" ;
    sh:closed false ;
    sh:ignoredProperties ( pbs:related_requirement_id pbs:property_path_kind pbs:property_path pbs:source_pset rdf:type pbs:ifc_attribute_name pbs:to_value pbs:source_property pbs:match_status pbs:affected_requirement_id pbs:affected_geometry_role pbs:from_value ) ;
    sh:property [ sh:description "URI identifying the tool or pipeline that produced this change record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 14 ;
            sh:path pbs:change_source ],
        [ sh:datatype xsd:string ;
            sh:description "Id of a Task record that this change triggered or should trigger." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path pbs:triggered_task ],
        [ sh:description "Category of change detected between two revisions." ;
            sh:in ( pbs:change_type_geometry_change pbs:change_type_property_change pbs:change_type_requirement_change pbs:change_type_match_change pbs:change_type_addition pbs:change_type_deletion ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path pbs:change_type ],
        [ sh:datatype xsd:string ;
            sh:description "Unique local identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path pbs:id ],
        [ sh:datatype xsd:string ;
            sh:description "IFC GlobalId of the mapped entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path pbs:ifc_global_id ;
            sh:pattern "^[0-3][0-9A-Za-z_$]{21}$" ],
        [ sh:description "Optional severity independent of change type." ;
            sh:in ( pbs:change_severity_unchanged pbs:change_severity_minor pbs:change_severity_major pbs:change_severity_rewritten ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path pbs:change_severity ],
        [ sh:datatype xsd:string ;
            sh:description """Optional JSON-pointer-style path for nested targets (for example documents[2], localized_descriptions[de], section.4.2.paragraph_1).
""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path pbs:affected_subject_path ],
        [ sh:datatype xsd:string ;
            sh:description """LinkML class name of the changed subject (for example Space, SeparatorWall, Document).
""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path pbs:affected_subject_type ],
        [ sh:datatype xsd:integer ;
            sh:description "Source revision number for this change." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path pbs:from_revision ],
        [ sh:description "Intent stability verdict from an automated judge (for example iterthink STABLE/NEW)." ;
            sh:in ( pbs:change_intent_verdict_stable pbs:change_intent_verdict_new_intent ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path pbs:intent_verdict ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Timestamp when this change was detected." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path dcterms:created ],
        [ sh:description "External workflow process URI (for example yourcompanyos process instance)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 12 ;
            sh:path pbs:triggered_process ],
        [ sh:datatype xsd:string ;
            sh:description "Identifier of the changed subject (entity id, document id, or external key)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path pbs:affected_subject_id ],
        [ sh:datatype xsd:integer ;
            sh:description "Target revision number for this change." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path pbs:to_revision ],
        [ sh:description "Document location when the subject is or embeds a Document." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path pbs:document_storage_link ] ;
    sh:targetClass pbs:Change .

