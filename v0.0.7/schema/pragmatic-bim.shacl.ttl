pbs:DeletionChange a sh:NodeShape ;
    rdfs:comment "Entity or requirement removed in to_revision." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description """Optional JSON-pointer-style path for nested targets (for example documents[2], localized_descriptions[de], section.4.2.paragraph_1).
""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path pbs:affected_subject_path ],
        [ sh:datatype xsd:integer ;
            sh:description "Target revision number for this change." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path pbs:to_revision ],
        [ sh:datatype xsd:string ;
            sh:description "Id of a Task record that this change triggered or should trigger." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path pbs:triggered_task ],
        [ sh:description "Category of change detected between two revisions." ;
            sh:in ( pbs:change_type_geometry_change pbs:change_type_property_change pbs:change_type_requirement_change pbs:change_type_match_change pbs:change_type_addition pbs:change_type_deletion ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path pbs:change_type ],
        [ sh:description "Document location when the subject is or embeds a Document." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path pbs:document_storage_link ],
        [ sh:description "URI identifying the tool or pipeline that produced this change record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 14 ;
            sh:path pbs:change_source ],
        [ sh:description "Optional severity independent of change type." ;
            sh:in ( pbs:change_severity_unchanged pbs:change_severity_minor pbs:change_severity_major pbs:change_severity_rewritten ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path pbs:change_severity ],
        [ sh:datatype xsd:string ;
            sh:description """LinkML class name of the changed subject (for example Space, SeparatorWall, Document).
""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path pbs:affected_subject_type ],
        [ sh:datatype xsd:string ;
            sh:description "Unique local identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path pbs:id ],
        [ sh:datatype xsd:integer ;
            sh:description "Source revision number for this change." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path pbs:from_revision ],
        [ sh:description "External workflow process URI (for example yourcompanyos process instance)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 12 ;
            sh:path pbs:triggered_process ],
        [ sh:description "Intent stability verdict from an automated judge (for example iterthink STABLE/NEW)." ;
            sh:in ( pbs:change_intent_verdict_stable pbs:change_intent_verdict_new_intent ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path pbs:intent_verdict ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Timestamp when this change was detected." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path dcterms:created ],
        [ sh:datatype xsd:string ;
            sh:description "IFC GlobalId of the mapped entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path pbs:ifc_global_id ;
            sh:pattern "^[0-3][0-9A-Za-z_$]{21}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Identifier of the changed subject (entity id, document id, or external key)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path pbs:affected_subject_id ] ;
    sh:targetClass pbs:DeletionChange .

pbs:Equipment a sh:NodeShape ;
    rdfs:comment "Endpoint or device element (for example terminal, unit, control device, sensor) located in a space and assigned to a system." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Classification of equipment (for example HVAC, electrical, plumbing)." ;
            sh:in ( ifcowl:IfcDistributionElement ifcowl:IfcElectricalElement ifcowl:IfcFlowTerminal ifcowl:IfcFireSuppressionTerminal ifcowl:IfcDistributionControlElement ifcowl:IfcFurniture ifcowl:IfcElement ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path pbs:equipment_type ],
        [ sh:class pbs:Classification ;
            sh:description "Classification entries from IFC and other schemes." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path pbs:classifications ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Last modification timestamp for this entity record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 22 ;
            sh:path pbs:modified_at ],
        [ sh:class pbs:BuiltAssetContext ;
            sh:description "Parent building context reference." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path pbs:parent_building ],
        [ sh:class pbs:LevelContext ;
            sh:description "Parent level/storey context reference." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path pbs:parent_level ],
        [ sh:datatype xsd:string ;
            sh:description "IFC GlobalId of the mapped entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path pbs:ifc_global_id ;
            sh:pattern "^[0-3][0-9A-Za-z_$]{21}$" ],
        [ sh:class pbs:GeometryRepresentation ;
            sh:description """Geometry references associated with the entity. A single element may link to multiple geometry representations to serve different intents (authoring, coordination, analysis, visualization) without duplicating the element itself.
""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path pbs:geometry_representations ],
        [ sh:description "Optional semantic URI for linking the entity instance to an external ontology concept." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path pbs:meaning_uri ],
        [ sh:class pbs:LocalizedText ;
            sh:description "Localized variants of description." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path pbs:localized_descriptions ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp for this entity record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path pbs:created_at ],
        [ sh:class pbs:MetadataEntry ;
            sh:description "Generic metadata container for IFC attributes/properties and project-specific extensions." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path pbs:metadata ],
        [ sh:datatype xsd:integer ;
            sh:description "Integer revision counter for change tracking." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 23 ;
            sh:path pbs:revision ],
        [ sh:description "Lifecycle or QA status." ;
            sh:in ( pbs:status_draft pbs:status_submitted pbs:status_reviewed pbs:status_approved pbs:status_rejected pbs:status_archived ) ;
            sh:maxCount 1 ;
            sh:order 24 ;
            sh:path pbs:status ],
        [ sh:class pbs:PerformanceProperty ;
            sh:description """Normalized, strongly typed domain properties (fire/acoustic/thermal/structural/ security/material) extracted from raw IFC PropertySet values.
""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path pbs:performance_properties ],
        [ sh:class pbs:Space ;
            sh:description "Parent space where the equipment is located." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path pbs:parent_space ],
        [ sh:datatype xsd:string ;
            sh:description "Default display name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path pbs:name ],
        [ sh:class pbs:Task ;
            sh:description "Tasks associated with this entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 19 ;
            sh:path pbs:tasks ],
        [ sh:class pbs:Message ;
            sh:description "Messages associated with this entity." ;
            sh:nodeKind sh:IRI ;
            sh:order 20 ;
            sh:path pbs:messages ],
        [ sh:class pbs:QuantityValue ;
            sh:description "Quantities associated with the entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path pbs:quantity_values ],
        [ sh:datatype xsd:string ;
            sh:description "Unique local identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path pbs:id ],
        [ sh:class pbs:System ;
            sh:description "Parent systems that the equipment belongs to." ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path pbs:parent_system ],
        [ sh:class pbs:LocalizedText ;
            sh:description "Localized variants of name." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path pbs:localized_names ],
        [ sh:class pbs:Document ;
            sh:description "Linked documents associated with this entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path pbs:documents ],
        [ sh:class pbs:Decision ;
            sh:description "Decision records associated with this entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path pbs:decisions ],
        [ sh:datatype xsd:string ;
            sh:description "Default description text." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path pbs:description ] ;
    sh:targetClass pbs:Equipment .

pbs:FireProperty a sh:NodeShape ;
    rdfs:comment "Normalized fire-related property." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "String value when property_value_type is string." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path pbs:property_value_string ],
        [ sh:description "Value type discriminator for normalized storage (for example string, number, boolean)." ;
            sh:in ( pbs:performance_property_value_type_string pbs:performance_property_value_type_number pbs:performance_property_value_type_boolean ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path pbs:property_value_type ],
        [ sh:datatype xsd:string ;
            sh:description "Original property name inside the source PropertySet (for example FireRating)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path pbs:source_property ],
        [ sh:datatype xsd:string ;
            sh:description "Original IFC PropertySet name (for example Pset_WallCommon)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path pbs:source_pset ],
        [ sh:datatype xsd:double ;
            sh:description "Numeric value when property_value_type is number." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path pbs:property_value_number ],
        [ sh:description "Canonical key inside the domain; constrained via subclass slot_usage to a domain-specific enum." ;
            sh:in ( pbs:fire_property_resistance_rating pbs:fire_property_smoke_rating pbs:fire_property_reaction_to_fire ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path pbs:property_key ],
        [ sh:datatype xsd:string ;
            sh:description "Normalized unit where applicable (for example min, dB, W/m2K)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path pbs:property_unit ],
        [ sh:datatype xsd:string ;
            sh:description "Raw source value before normalization." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path pbs:source_value_raw ],
        [ sh:datatype xsd:string ;
            sh:description "Mapping specification version used to derive the normalized property." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path pbs:mapping_version ],
        [ sh:datatype xsd:boolean ;
            sh:description "Boolean value when property_value_type is boolean." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path pbs:property_value_boolean ],
        [ sh:description "Optional URI that identifies the normalized property unit in an external vocabulary such as QUDT." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path pbs:property_unit_uri ] ;
    sh:targetClass pbs:FireProperty .

pbs:GeometryChange a sh:NodeShape ;
    rdfs:comment "Geometry or representation change for a subject." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "External workflow process URI (for example yourcompanyos process instance)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 13 ;
            sh:path pbs:triggered_process ],
        [ sh:datatype xsd:string ;
            sh:description "Unique local identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path pbs:id ],
        [ sh:description "Optional severity independent of change type." ;
            sh:in ( pbs:change_severity_unchanged pbs:change_severity_minor pbs:change_severity_major pbs:change_severity_rewritten ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path pbs:change_severity ],
        [ sh:datatype xsd:integer ;
            sh:description "Target revision number for this change." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path pbs:to_revision ],
        [ sh:description "Category of change detected between two revisions." ;
            sh:in ( pbs:change_type_geometry_change pbs:change_type_property_change pbs:change_type_requirement_change pbs:change_type_match_change pbs:change_type_addition pbs:change_type_deletion ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path pbs:change_type ],
        [ sh:datatype xsd:string ;
            sh:description """LinkML class name of the changed subject (for example Space, SeparatorWall, Document).
""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path pbs:affected_subject_type ],
        [ sh:datatype xsd:string ;
            sh:description """Optional JSON-pointer-style path for nested targets (for example documents[2], localized_descriptions[de], section.4.2.paragraph_1).
""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path pbs:affected_subject_path ],
        [ sh:description "Intent stability verdict from an automated judge (for example iterthink STABLE/NEW)." ;
            sh:in ( pbs:change_intent_verdict_stable pbs:change_intent_verdict_new_intent ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path pbs:intent_verdict ],
        [ sh:description "Document location when the subject is or embeds a Document." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path pbs:document_storage_link ],
        [ sh:description "Geometry role affected for GeometryChange records." ;
            sh:in ( "axis" "body_3d" "footprint_2d" "point" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path pbs:affected_geometry_role ],
        [ sh:datatype xsd:integer ;
            sh:description "Source revision number for this change." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path pbs:from_revision ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Timestamp when this change was detected." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path dcterms:created ],
        [ sh:datatype xsd:string ;
            sh:description "IFC GlobalId of the mapped entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path pbs:ifc_global_id ;
            sh:pattern "^[0-3][0-9A-Za-z_$]{21}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Identifier of the changed subject (entity id, document id, or external key)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path pbs:affected_subject_id ],
        [ sh:description "URI identifying the tool or pipeline that produced this change record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 15 ;
            sh:path pbs:change_source ],
        [ sh:datatype xsd:string ;
            sh:description "Id of a Task record that this change triggered or should trigger." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path pbs:triggered_task ] ;
    sh:targetClass pbs:GeometryChange .

pbs:MatchChange a sh:NodeShape ;
    rdfs:comment """Entity match status against a requirement changed (previously met / no longer meets).
""" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:dateTime ;
            sh:description "Timestamp when this change was detected." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path dcterms:created ],
        [ sh:description "Category of change detected between two revisions." ;
            sh:in ( pbs:change_type_geometry_change pbs:change_type_property_change pbs:change_type_requirement_change pbs:change_type_match_change pbs:change_type_addition pbs:change_type_deletion ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 3 ;
            sh:path pbs:change_type ],
        [ sh:datatype xsd:string ;
            sh:description "Id of a Task record that this change triggered or should trigger." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path pbs:triggered_task ],
        [ sh:description "Document location when the subject is or embeds a Document." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path pbs:document_storage_link ],
        [ sh:description "Optional severity independent of change type." ;
            sh:in ( pbs:change_severity_unchanged pbs:change_severity_minor pbs:change_severity_major pbs:change_severity_rewritten ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path pbs:change_severity ],
        [ sh:datatype xsd:integer ;
            sh:description "Target revision number for this change." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path pbs:to_revision ],
        [ sh:datatype xsd:string ;
            sh:description "Requirement identifier for match_change records." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path pbs:related_requirement_id ],
        [ sh:description "Whether the subject met the requirement at the target revision." ;
            sh:in ( pbs:match_status_met pbs:match_status_unmet pbs:match_status_unknown ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path pbs:match_status ],
        [ sh:datatype xsd:string ;
            sh:description """LinkML class name of the changed subject (for example Space, SeparatorWall, Document).
""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path pbs:affected_subject_type ],
        [ sh:description "URI identifying the tool or pipeline that produced this change record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 16 ;
            sh:path pbs:change_source ],
        [ sh:description "Intent stability verdict from an automated judge (for example iterthink STABLE/NEW)." ;
            sh:in ( pbs:change_intent_verdict_stable pbs:change_intent_verdict_new_intent ) ;
            sh:maxCount 1 ;
            sh:order 5 ;
            sh:path pbs:intent_verdict ],
        [ sh:datatype xsd:string ;
            sh:description "IFC GlobalId of the mapped entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path pbs:ifc_global_id ;
            sh:pattern "^[0-3][0-9A-Za-z_$]{21}$" ],
        [ sh:description "External workflow process URI (for example yourcompanyos process instance)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 14 ;
            sh:path pbs:triggered_process ],
        [ sh:datatype xsd:integer ;
            sh:description "Source revision number for this change." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path pbs:from_revision ],
        [ sh:datatype xsd:string ;
            sh:description "Identifier of the changed subject (entity id, document id, or external key)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path pbs:affected_subject_id ],
        [ sh:datatype xsd:string ;
            sh:description """Optional JSON-pointer-style path for nested targets (for example documents[2], localized_descriptions[de], section.4.2.paragraph_1).
""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path pbs:affected_subject_path ],
        [ sh:datatype xsd:string ;
            sh:description "Unique local identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path pbs:id ] ;
    sh:targetClass pbs:MatchChange .

pbs:MaterialProperty a sh:NodeShape ;
    rdfs:comment "Normalized material-related property." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Canonical key inside the domain; constrained via subclass slot_usage to a domain-specific enum." ;
            sh:in ( pbs:material_property_name pbs:material_property_class pbs:material_property_density pbs:material_property_thermal_conductivity ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path pbs:property_key ],
        [ sh:datatype xsd:boolean ;
            sh:description "Boolean value when property_value_type is boolean." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path pbs:property_value_boolean ],
        [ sh:datatype xsd:string ;
            sh:description "Raw source value before normalization." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path pbs:source_value_raw ],
        [ sh:datatype xsd:string ;
            sh:description "Normalized unit where applicable (for example min, dB, W/m2K)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path pbs:property_unit ],
        [ sh:description "Value type discriminator for normalized storage (for example string, number, boolean)." ;
            sh:in ( pbs:performance_property_value_type_string pbs:performance_property_value_type_number pbs:performance_property_value_type_boolean ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path pbs:property_value_type ],
        [ sh:datatype xsd:string ;
            sh:description "Original property name inside the source PropertySet (for example FireRating)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path pbs:source_property ],
        [ sh:description "Optional URI that identifies the normalized property unit in an external vocabulary such as QUDT." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path pbs:property_unit_uri ],
        [ sh:datatype xsd:string ;
            sh:description "Original IFC PropertySet name (for example Pset_WallCommon)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path pbs:source_pset ],
        [ sh:datatype xsd:string ;
            sh:description "Mapping specification version used to derive the normalized property." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path pbs:mapping_version ],
        [ sh:datatype xsd:double ;
            sh:description "Numeric value when property_value_type is number." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path pbs:property_value_number ],
        [ sh:datatype xsd:string ;
            sh:description "String value when property_value_type is string." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path pbs:property_value_string ] ;
    sh:targetClass pbs:MaterialProperty .

pbs:PerformanceRequirement a sh:NodeShape ;
    rdfs:comment "Performance target requirement (U-value, fire rating, airflow, acoustic, etc.)." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Default display name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path pbs:name ],
        [ sh:datatype xsd:string ;
            sh:description "Textual target value when applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path pbs:target_value_string ],
        [ sh:datatype xsd:double ;
            sh:description "Numeric target value when applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path pbs:target_value_number ],
        [ sh:datatype xsd:string ;
            sh:description "Default description text." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path pbs:description ],
        [ sh:datatype xsd:string ;
            sh:description """Canonical performance key for the target (for example u_value, resistance_rating). Aligns with performance property keys where applicable.
""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path pbs:requirement_property_key ],
        [ sh:description "Lifecycle or QA status." ;
            sh:in ( pbs:status_draft pbs:status_submitted pbs:status_reviewed pbs:status_approved pbs:status_rejected pbs:status_archived ) ;
            sh:maxCount 1 ;
            sh:order 12 ;
            sh:path pbs:status ],
        [ sh:class pbs:Entity ;
            sh:description "Model entities this record applies to (requirements, cost items, schedule items, etc.)." ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path pbs:applies_to_entities ],
        [ sh:description "Comparison operator for the requirement target." ;
            sh:in ( pbs:requirement_target_operator_equals pbs:requirement_target_operator_minimum pbs:requirement_target_operator_maximum pbs:requirement_target_operator_range ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path pbs:target_operator ],
        [ sh:datatype xsd:string ;
            sh:description "Unit for numeric targets (for example W/m2K, min, dB)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path pbs:target_unit ],
        [ sh:description "Optional URI identifying the target unit (for example QUDT)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path pbs:target_unit_uri ],
        [ sh:datatype xsd:string ;
            sh:description "Unique local identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path pbs:id ],
        [ sh:description "Optional URI to norm, brief, or source document backing this requirement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 11 ;
            sh:path pbs:source_document ],
        [ sh:datatype xsd:boolean ;
            sh:description "Boolean target value when applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path pbs:target_value_boolean ] ;
    sh:targetClass pbs:PerformanceRequirement .

pbs:Person a sh:NodeShape ;
    rdfs:comment "Individual stakeholder, contributor, assignee, or responsible party represented in the schema." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class pbs:Decision ;
            sh:description "Decision records associated with this entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path pbs:decisions ],
        [ sh:class pbs:Document ;
            sh:description "Linked documents associated with this entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path pbs:documents ],
        [ sh:description "Optional semantic URI for linking the entity instance to an external ontology concept." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path pbs:meaning_uri ],
        [ sh:class pbs:PerformanceProperty ;
            sh:description """Normalized, strongly typed domain properties (fire/acoustic/thermal/structural/ security/material) extracted from raw IFC PropertySet values.
""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path pbs:performance_properties ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Last modification timestamp for this entity record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path pbs:modified_at ],
        [ sh:description "Lifecycle or QA status." ;
            sh:in ( pbs:status_draft pbs:status_submitted pbs:status_reviewed pbs:status_approved pbs:status_rejected pbs:status_archived ) ;
            sh:maxCount 1 ;
            sh:order 22 ;
            sh:path pbs:status ],
        [ sh:class pbs:Company ;
            sh:description "Optional company that the person belongs to." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path pbs:belongs_to_company ],
        [ sh:datatype xsd:integer ;
            sh:description "Integer revision counter for change tracking." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 21 ;
            sh:path pbs:revision ],
        [ sh:class pbs:ContactPoint ;
            sh:description "Structured communication channels and profiles associated with this agent." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path pbs:contact_points ],
        [ sh:datatype xsd:string ;
            sh:description "Unique local identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path pbs:id ],
        [ sh:datatype xsd:string ;
            sh:description "Default description text." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path pbs:description ],
        [ sh:class pbs:QuantityValue ;
            sh:description "Quantities associated with the entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path pbs:quantity_values ],
        [ sh:class pbs:Task ;
            sh:description "Tasks associated with this entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path pbs:tasks ],
        [ sh:class pbs:PostalAddress ;
            sh:description "Structured postal or physical addresses associated with this agent." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path pbs:postal_addresses ],
        [ sh:class pbs:Classification ;
            sh:description "Classification entries from IFC and other schemes." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path pbs:classifications ],
        [ sh:datatype xsd:string ;
            sh:description "Default display name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path pbs:name ],
        [ sh:class pbs:LocalizedText ;
            sh:description "Localized variants of description." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path pbs:localized_descriptions ],
        [ sh:datatype xsd:string ;
            sh:description "IFC GlobalId of the mapped entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path pbs:ifc_global_id ;
            sh:pattern "^[0-3][0-9A-Za-z_$]{21}$" ],
        [ sh:class pbs:Message ;
            sh:description "Messages associated with this entity." ;
            sh:nodeKind sh:IRI ;
            sh:order 18 ;
            sh:path pbs:messages ],
        [ sh:class pbs:GeometryRepresentation ;
            sh:description """Geometry references associated with the entity. A single element may link to multiple geometry representations to serve different intents (authoring, coordination, analysis, visualization) without duplicating the element itself.
""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path pbs:geometry_representations ],
        [ sh:class pbs:LocalizedText ;
            sh:description "Localized variants of name." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path pbs:localized_names ],
        [ sh:class pbs:MetadataEntry ;
            sh:description "Generic metadata container for IFC attributes/properties and project-specific extensions." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path pbs:metadata ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Creation timestamp for this entity record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 19 ;
            sh:path pbs:created_at ] ;
    sh:targetClass pbs:Person .

pbs:PropertyChange a sh:NodeShape ;
    rdfs:comment "Attribute, PropertySet, schema slot, or document field change." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:dateTime ;
            sh:description "Timestamp when this change was detected." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 20 ;
            sh:path dcterms:created ],
        [ sh:description "Category of change detected between two revisions." ;
            sh:in ( pbs:change_type_geometry_change pbs:change_type_property_change pbs:change_type_requirement_change pbs:change_type_match_change pbs:change_type_addition pbs:change_type_deletion ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 8 ;
            sh:path pbs:change_type ],
        [ sh:datatype xsd:string ;
            sh:description "Unique local identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path pbs:id ],
        [ sh:description "Document location when the subject is or embeds a Document." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 15 ;
            sh:path pbs:document_storage_link ],
        [ sh:datatype xsd:string ;
            sh:description "Prior value serialized as text. Absent or null for new subjects or fields." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path pbs:from_value ],
        [ sh:datatype xsd:string ;
            sh:description """Canonical path to the changed field. Examples: Pset_WallCommon.FireRating, IfcWall.Name, description, section.4.2.requirement_3, body:char_offset:1204-1389.
""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path pbs:property_path ],
        [ sh:description "Optional severity independent of change type." ;
            sh:in ( pbs:change_severity_unchanged pbs:change_severity_minor pbs:change_severity_major pbs:change_severity_rewritten ) ;
            sh:maxCount 1 ;
            sh:order 9 ;
            sh:path pbs:change_severity ],
        [ sh:description "External workflow process URI (for example yourcompanyos process instance)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 19 ;
            sh:path pbs:triggered_process ],
        [ sh:datatype xsd:string ;
            sh:description "Id of a Task record that this change triggered or should trigger." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 18 ;
            sh:path pbs:triggered_task ],
        [ sh:datatype xsd:integer ;
            sh:description "Target revision number for this change." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 17 ;
            sh:path pbs:to_revision ],
        [ sh:description "Intent stability verdict from an automated judge (for example iterthink STABLE/NEW)." ;
            sh:in ( pbs:change_intent_verdict_stable pbs:change_intent_verdict_new_intent ) ;
            sh:maxCount 1 ;
            sh:order 10 ;
            sh:path pbs:intent_verdict ],
        [ sh:datatype xsd:string ;
            sh:description "IFC PropertySet name when property_path_kind is ifc_pset." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path pbs:source_pset ],
        [ sh:datatype xsd:integer ;
            sh:description "Source revision number for this change." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 16 ;
            sh:path pbs:from_revision ],
        [ sh:datatype xsd:string ;
            sh:description "New value serialized as text. Absent or null for deleted subjects or fields." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path pbs:to_value ],
        [ sh:description "Classification of the property path for downstream diff interpretation." ;
            sh:in ( pbs:property_path_kind_ifc_attribute pbs:property_path_kind_ifc_pset pbs:property_path_kind_schema_slot pbs:property_path_kind_document_field pbs:property_path_kind_text_span ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path pbs:property_path_kind ],
        [ sh:datatype xsd:string ;
            sh:description "IFC GlobalId of the mapped entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path pbs:ifc_global_id ;
            sh:pattern "^[0-3][0-9A-Za-z_$]{21}$" ],
        [ sh:datatype xsd:string ;
            sh:description "IFC property name within the PropertySet when property_path_kind is ifc_pset." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path pbs:source_property ],
        [ sh:datatype xsd:string ;
            sh:description "IFC attribute name when property_path_kind is ifc_attribute (for example Name, GlobalId)." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path pbs:ifc_attribute_name ],
        [ sh:datatype xsd:string ;
            sh:description """LinkML class name of the changed subject (for example Space, SeparatorWall, Document).
""" ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path pbs:affected_subject_type ],
        [ sh:description "URI identifying the tool or pipeline that produced this change record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 21 ;
            sh:path pbs:change_source ],
        [ sh:datatype xsd:string ;
            sh:description "Identifier of the changed subject (entity id, document id, or external key)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path pbs:affected_subject_id ],
        [ sh:datatype xsd:string ;
            sh:description """Optional JSON-pointer-style path for nested targets (for example documents[2], localized_descriptions[de], section.4.2.paragraph_1).
""" ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path pbs:affected_subject_path ] ;
    sh:targetClass pbs:PropertyChange .

pbs:RegulatoryRequirement a sh:NodeShape ;
    rdfs:comment "Regulatory reference requirement (building code, norm, standard)." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Unique local identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path pbs:id ],
        [ sh:datatype xsd:string ;
            sh:description "Clause, article, or section reference within the norm." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path pbs:clause_ref ],
        [ sh:description "Optional URI to norm, brief, or source document backing this requirement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path pbs:source_document ],
        [ sh:datatype xsd:string ;
            sh:description "Jurisdiction or authority scope for the regulatory requirement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path pbs:jurisdiction ],
        [ sh:description "Lifecycle or QA status." ;
            sh:in ( pbs:status_draft pbs:status_submitted pbs:status_reviewed pbs:status_approved pbs:status_rejected pbs:status_archived ) ;
            sh:maxCount 1 ;
            sh:order 8 ;
            sh:path pbs:status ],
        [ sh:datatype xsd:string ;
            sh:description "Default description text." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path pbs:description ],
        [ sh:description "URI identifying the norm, standard, or building code." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path pbs:norm_uri ],
        [ sh:datatype xsd:string ;
            sh:description "Default display name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path pbs:name ],
        [ sh:class pbs:Entity ;
            sh:description "Model entities this record applies to (requirements, cost items, schedule items, etc.)." ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path pbs:applies_to_entities ] ;
    sh:targetClass pbs:RegulatoryRequirement .

pbs:Requirement a sh:NodeShape ;
    rdfs:comment """Prescriptive requirement record (content_kind requirement). Not an Entity; may apply to one or more model entities. Domain is discriminated by concrete subclass (PerformanceRequirement, SpatialRequirement, etc.), not a separate slot.
""" ;
    sh:closed false ;
    sh:ignoredProperties ( pbs:jurisdiction pbs:target_operator pbs:target_value_number pbs:min_height pbs:target_unit_uri rdf:type pbs:target_value_string pbs:statement pbs:min_area pbs:min_clear_distance pbs:target_value_boolean pbs:programme_ref pbs:norm_uri pbs:related_entity pbs:adjacency_kind pbs:target_unit pbs:clause_ref pbs:requirement_property_key ) ;
    sh:property [ sh:description "Lifecycle or QA status." ;
            sh:in ( pbs:status_draft pbs:status_submitted pbs:status_reviewed pbs:status_approved pbs:status_rejected pbs:status_archived ) ;
            sh:maxCount 1 ;
            sh:order 5 ;
            sh:path pbs:status ],
        [ sh:datatype xsd:string ;
            sh:description "Default display name." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path pbs:name ],
        [ sh:datatype xsd:string ;
            sh:description "Unique local identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path pbs:id ],
        [ sh:datatype xsd:string ;
            sh:description "Default description text." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path pbs:description ],
        [ sh:class pbs:Entity ;
            sh:description "Model entities this record applies to (requirements, cost items, schedule items, etc.)." ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path pbs:applies_to_entities ],
        [ sh:description "Optional URI to norm, brief, or source document backing this requirement." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path pbs:source_document ] ;
    sh:targetClass pbs:Requirement .

