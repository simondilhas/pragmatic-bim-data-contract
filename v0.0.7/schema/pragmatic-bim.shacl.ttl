            sh:path pbs:triggered_process ],
        [ sh:description "Classification of the property path for downstream diff interpretation." ;
            sh:in ( pbs:property_path_kind_ifc_attribute pbs:property_path_kind_ifc_pset pbs:property_path_kind_schema_slot pbs:property_path_kind_document_field pbs:property_path_kind_text_span ) ;
            sh:maxCount 1 ;
