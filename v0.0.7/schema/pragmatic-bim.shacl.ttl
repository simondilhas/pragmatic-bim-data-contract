""" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 24 ;
            sh:path pbs:performance_properties ],
        [ sh:datatype xsd:integer ;
            sh:description "Integer revision counter for change tracking." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 30 ;
            sh:path pbs:revision ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Actual start timestamp for the time record where known." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path pbs:actual_start_at ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Actual finish timestamp for the time record where known." ;
