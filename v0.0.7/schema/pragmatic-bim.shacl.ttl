            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path pbs:milestone_at ],
        [ sh:class pbs:TimeRecord ;
            sh:description "Parent time plan this record belongs to." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path pbs:time_plan ],
        [ sh:description "Optional semantic URI for linking the entity instance to an external ontology concept." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 16 ;
            sh:path pbs:meaning_uri ],
        [ sh:class pbs:Message ;
            sh:description "Messages associated with this entity." ;
            sh:nodeKind sh:IRI ;
            sh:order 27 ;
            sh:path pbs:messages ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Planned finish timestamp for the time record." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path pbs:planned_finish_at ],
        [ sh:class pbs:Material ;
            sh:description "Material definitions associated with this entity." ;
            sh:nodeKind sh:IRI ;
            sh:order 11 ;
            sh:path pbs:materials ],
        [ sh:class pbs:LocalizedText ;
            sh:description "Localized variants of description." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path pbs:localized_descriptions ],
        [ sh:datatype xsd:string ;
            sh:description "Default description text." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 15 ;
            sh:path pbs:description ],
        [ sh:class pbs:TimeLink ;
            sh:description "Forward precedence links to successor records. Reverse lookup (find all predecessors of X) requires scanning all TimeRecord.successors — acceptable for document exchange, not for live graph queries." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
