:food a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "SEC-FOD" ;
  skos:prefLabel "Food and nutrition"@en ;
  skos:prefLabel "Lebensmittel"@de ;
  skos:narrower :dietary_supplements, :micronutrients, :chef .

:dietary_supplements a skos:Concept ;
