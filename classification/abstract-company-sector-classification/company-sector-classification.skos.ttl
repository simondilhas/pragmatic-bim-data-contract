@prefix : <https://example.org/ch/abstract-company-sector/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

:scheme a skos:ConceptScheme ;
  skos:prefLabel "Abstract company sector classification"@en ;
  skos:prefLabel "Abstrakte Unternehmens-Branchen-Klassifikation"@de ;
  dcterms:title "Abstract company sector classification"@en ;
  dcterms:identifier "AbstractCompanySectorClassification" ;
  dcterms:creator "pragmatic-bim-public-rules" ;
  dcterms:issued "2026-07-09" ;
  dcterms:description "Industry and sector taxonomy for classifying organizations in CRM and LLM extraction."@en ;
  dcterms:description "Branchen- und Sektor-Taxonomie zur Klassifikation von Organisationen in CRM und LLM-Extraktion."@de ;
  skos:hasTopConcept
    :construction, :real_estate, :legal, :esg, :media, :food,
    :funding, :military, :health, :investor, :association, :economy_professions .

# --- construction (Bauwesen) ---

:construction a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "SEC-BAU" ;
  skos:prefLabel "Construction and built environment"@en ;
  skos:prefLabel "Bauwesen"@de ;
  skos:narrower :client_side, :planning, :construction_contracting, :facility_management .

:client_side a skos:Concept ;
  skos:inScheme :scheme ;
  skos:broader :construction ;
  skos:notation "SEC-BAU-CLI" ;
  skos:prefLabel "Client side"@en ;
  skos:prefLabel "Besteller"@de ;
  skos:narrower :project_developer, :building_owner, :design_build_contractor .

:project_developer a skos:Concept ;
  skos:inScheme :scheme ;
  skos:broader :client_side ;
  skos:notation "SEC-BAU-CLI-DEV" ;
  skos:prefLabel "Project developer"@en ;
  skos:prefLabel "Projektentwickler"@de .

:building_owner a skos:Concept ;
  skos:inScheme :scheme ;
  skos:broader :client_side ;
  skos:notation "SEC-BAU-CLI-OWN" ;
  skos:prefLabel "Building owner"@en ;
  skos:prefLabel "Bauherr"@de .

:design_build_contractor a skos:Concept ;
  skos:inScheme :scheme ;
  skos:broader :client_side ;
  skos:notation "SEC-BAU-CLI-GC" ;
  skos:prefLabel "Design-build / total contractor"@en ;
  skos:prefLabel "Totalunternehmer"@de .

:planning a skos:Concept ;
  skos:inScheme :scheme ;
  skos:broader :construction ;
  skos:notation "SEC-BAU-PLN" ;
  skos:prefLabel "Planning and design"@en ;
  skos:prefLabel "Planung"@de ;
  skos:narrower :architecture, :expert_assessor, :building_services .

:architecture a skos:Concept ;
  skos:inScheme :scheme ;
  skos:broader :planning ;
  skos:notation "SEC-BAU-PLN-ARC" ;
  skos:prefLabel "Architecture"@en ;
  skos:prefLabel "Architektur"@de .

:expert_assessor a skos:Concept ;
  skos:inScheme :scheme ;
  skos:broader :planning ;
  skos:notation "SEC-BAU-PLN-EXP" ;
  skos:prefLabel "Expert assessor"@en ;
  skos:prefLabel "Gutachter"@de .

:building_services a skos:Concept ;
  skos:inScheme :scheme ;
  skos:broader :planning ;
  skos:notation "SEC-BAU-PLN-MEP" ;
  skos:prefLabel "Building services (MEP)"@en ;
  skos:prefLabel "TGA / HLKSE"@de ;
  skos:altLabel "HLKSE"@de ;
  skos:altLabel "TGA"@de .

:construction_contracting a skos:Concept ;
  skos:inScheme :scheme ;
  skos:broader :construction ;
  skos:notation "SEC-BAU-CNT" ;
  skos:prefLabel "Construction contracting"@en ;
  skos:prefLabel "Bauunternehmung"@de .

:facility_management a skos:Concept ;
  skos:inScheme :scheme ;
  skos:broader :construction ;
  skos:notation "SEC-BAU-FM" ;
  skos:prefLabel "Facility and property management"@en ;
  skos:prefLabel "Bewirtschafter"@de ;
  skos:altLabel "Facility Management"@de .

# --- real estate ---

:real_estate a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "SEC-REA" ;
  skos:prefLabel "Real estate"@en ;
  skos:prefLabel "Immobilien"@de .

# --- legal ---

:legal a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "SEC-LAW" ;
  skos:prefLabel "Legal services"@en ;
  skos:prefLabel "Recht"@de ;
  skos:narrower :law_firm, :legal_professional .

:law_firm a skos:Concept ;
  skos:inScheme :scheme ;
  skos:broader :legal ;
  skos:notation "SEC-LAW-LAW" ;
  skos:prefLabel "Law firm"@en ;
  skos:prefLabel "Rechtsanwalt"@de ;
  skos:scopeNote "Law firm or attorney practice; use narrower concepts for practice areas."@en ;
  skos:scopeNote "Anwaltskanzlei oder Rechtsanwaltspraxis; engere Konzepte für Schwerpunkte verwenden."@de ;
  skos:narrower :capital_markets_law, :corporate_law .

:capital_markets_law a skos:Concept ;
  skos:inScheme :scheme ;
  skos:broader :law_firm ;
  skos:notation "SEC-LAW-LAW-CMR" ;
  skos:prefLabel "Capital markets law"@en ;
  skos:prefLabel "Kapitalmarktrecht"@de .

:corporate_law a skos:Concept ;
  skos:inScheme :scheme ;
  skos:broader :law_firm ;
  skos:notation "SEC-LAW-LAW-COR" ;
  skos:prefLabel "Corporate law"@en ;
  skos:prefLabel "Gesellschaftsrecht"@de .

:legal_professional a skos:Concept ;
  skos:inScheme :scheme ;
  skos:broader :legal ;
  skos:notation "SEC-LAW-JUR" ;
  skos:prefLabel "Legal professional"@en ;
  skos:prefLabel "Jurist"@de ;
  skos:scopeNote "Broader legal sector role beyond attorney practice (in-house, notary, legal counsel)."@en ;
  skos:scopeNote "Breitere juristische Rolle ausserhalb der Anwaltskanzlei (Inhouse, Notariat, Rechtsberatung)."@de .

