  skos:notation "SEC-FND" ;
  skos:prefLabel "Funding and promotion"@en ;
  skos:prefLabel "Förderung"@de ;
  skos:scopeNote "Public or private funding bodies, grant programs, and promotional organizations."@en ;
  skos:scopeNote "Öffentliche oder private Förderstellen, Förderprogramme und Förderorganisationen."@de .

