# --- investor ---

:investor a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "SEC-INV" ;
  skos:prefLabel "Investor and capital"@en ;
  skos:prefLabel "Investor"@de ;
  skos:narrower
    :family_office, :private_investor, :institutional_investor,
    :foundation, :multiplier, :advisor .

:family_office a skos:Concept ;
  skos:inScheme :scheme ;
  skos:broader :investor ;
  skos:notation "SEC-INV-FO" ;
  skos:prefLabel "Family office"@en ;
  skos:prefLabel "Family Office"@de ;
  skos:narrower :multi_family_office, :single_family_office .

:multi_family_office a skos:Concept ;
  skos:inScheme :scheme ;
  skos:broader :family_office ;
  skos:notation "SEC-INV-FO-MFO" ;
  skos:prefLabel "Multi family office"@en ;
  skos:prefLabel "Multi Family Office"@de .

:single_family_office a skos:Concept ;
  skos:inScheme :scheme ;
  skos:broader :family_office ;
  skos:notation "SEC-INV-FO-SFO" ;
  skos:prefLabel "Single family office"@en ;
  skos:prefLabel "Single Family Office"@de .

:private_investor a skos:Concept ;
  skos:inScheme :scheme ;
  skos:broader :investor ;
  skos:notation "SEC-INV-PRI" ;
  skos:prefLabel "Private investor"@en ;
  skos:prefLabel "Privatinvestor"@de .

:institutional_investor a skos:Concept ;
  skos:inScheme :scheme ;
  skos:broader :investor ;
  skos:notation "SEC-INV-INS" ;
  skos:prefLabel "Institutional investor"@en ;
  skos:prefLabel "Institutioneller Investor"@de ;
  skos:narrower :hnwi, :uhnwi .

:hnwi a skos:Concept ;
  skos:inScheme :scheme ;
  skos:broader :institutional_investor ;
  skos:notation "SEC-INV-INS-HNW" ;
  skos:prefLabel "High net worth individual (HNWI)"@en ;
  skos:prefLabel "HNWI"@de ;
  skos:altLabel "High Net Worth Individual"@en .

:uhnwi a skos:Concept ;
  skos:inScheme :scheme ;
  skos:broader :institutional_investor ;
  skos:notation "SEC-INV-INS-UHN" ;
  skos:prefLabel "Ultra high net worth individual (UHNWI)"@en ;
  skos:prefLabel "UHNWI"@de ;
  skos:altLabel "Ultra High Net Worth Individual"@en .

:foundation a skos:Concept ;
  skos:inScheme :scheme ;
  skos:broader :investor ;
  skos:notation "SEC-INV-FDN" ;
  skos:prefLabel "Foundation"@en ;
  skos:prefLabel "Stiftung"@de ;
  skos:narrower :charitable_foundation .

:charitable_foundation a skos:Concept ;
  skos:inScheme :scheme ;
  skos:broader :foundation ;
  skos:notation "SEC-INV-FDN-CHR" ;
  skos:prefLabel "Charitable foundation"@en ;
  skos:prefLabel "Gemeinnützige Stiftung"@de .

:multiplier a skos:Concept ;
  skos:inScheme :scheme ;
  skos:broader :investor ;
  skos:notation "SEC-INV-MLT" ;
  skos:prefLabel "Multiplier"@en ;
  skos:prefLabel "Multiplikator"@de ;
  skos:scopeNote "Network hub or influencer connecting investors and opportunities."@en ;
  skos:scopeNote "Netzwerk-Knoten oder Multiplikator zwischen Investoren und Projekten."@de .

:advisor a skos:Concept ;
  skos:inScheme :scheme ;
  skos:broader :investor ;
  skos:notation "SEC-INV-ADV" ;
  skos:prefLabel "Investment advisor"@en ;
  skos:prefLabel "Advisor"@de ;
  skos:altLabel "Berater"@de .

# --- association ---

:association a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "SEC-ASS" ;
  skos:prefLabel "Association and non-profit"@en ;
  skos:prefLabel "Verein"@de .

# --- economy and professions ---

:economy_professions a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "SEC-ECO" ;
  skos:prefLabel "Economy and professions"@en ;
  skos:prefLabel "Wirtschaft und Berufe"@de ;
  skos:scopeNote "General business and professional services not covered by a more specific sector."@en ;
  skos:scopeNote "Allgemeine Wirtschaft und Berufe, die keinem spezifischeren Sektor zugeordnet sind."@de .
