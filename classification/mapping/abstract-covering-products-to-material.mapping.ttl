@prefix fcp: <https://example.org/abstract/floor-covering-product/> .
@prefix wcp: <https://example.org/abstract/wall-covering-product/> .
@prefix ccp: <https://example.org/abstract/ceiling-covering-product/> .
@prefix mat: <https://example.org/abstract/material-classification/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix map: <https://example.org/mapping/> .

map:abstractCoveringProductsToMaterialMapping a dcterms:Dataset ;
  dcterms:title "Abstract covering products to material mapping"@en ;
  dcterms:title "Mapping abstrakter Bekleidungsprodukte nach Material"@de ;
  dcterms:references fcp:scheme, wcp:scheme, ccp:scheme, mat:scheme ;
  dcterms:issued "2026-06-30" ;
  dcterms:description "Maps abstract floor, wall, and ceiling covering product concepts to dominant-substance material classes. Uses skos:closeMatch for primary substance; skos:relatedMatch where composite or variable."@en ;
  dcterms:description "Ordnet abstrakte Boden-, Wand- und Deckenbekleidungsprodukte dominanten Materialklassen zu. skos:closeMatch fuer primaere Substanz; skos:relatedMatch bei Verbund oder Variabilitaet."@de .

# --- Floor covering products ---

fcp:FCP-SUBFLOOR skos:closeMatch mat:MAT-CONC ;
  skos:relatedMatch mat:MAT-CMP .

fcp:FCP-SEAMLESS-RESIN skos:closeMatch mat:MAT-PLA .

fcp:FCP-CARPET skos:closeMatch mat:MAT-PLA ;
  skos:relatedMatch mat:MAT-CMP .

fcp:FCP-LVT skos:closeMatch mat:MAT-PLA .

fcp:FCP-LINOLIUM skos:closeMatch mat:MAT-PLA .

fcp:FCP-NATURAL-STONE skos:closeMatch mat:MAT-MSN .

fcp:FCP-ARTIFICIAL-STONE skos:closeMatch mat:MAT-CONC ;
  skos:relatedMatch mat:MAT-CMP .

fcp:FCP-CERAMIC-TILE skos:closeMatch mat:MAT-MSN-CLY .

fcp:FCP-PARQUET skos:closeMatch mat:MAT-WOD .

fcp:FCP-LAMINATE skos:closeMatch mat:MAT-WOD ;
  skos:relatedMatch mat:MAT-CMP .

fcp:FCP-RAISED-FLOOR skos:closeMatch mat:MAT-CMP .

fcp:FCP-OTH skos:closeMatch mat:MAT-OTH .

# --- Wall covering products ---

wcp:WCP-SEAMLESS-COATING skos:closeMatch mat:MAT-MSN ;
  skos:relatedMatch mat:MAT-CMP .

wcp:WCP-WALLPAPER skos:closeMatch mat:MAT-PLA ;
  skos:relatedMatch mat:MAT-CMP .

wcp:WCP-NATURAL-STONE skos:closeMatch mat:MAT-MSN .

wcp:WCP-ARTIFICIAL-STONE skos:closeMatch mat:MAT-CONC ;
  skos:relatedMatch mat:MAT-CMP .

wcp:WCP-CERAMIC-TILE skos:closeMatch mat:MAT-MSN-CLY .

wcp:WCP-WOOD-PANEL skos:closeMatch mat:MAT-WOD .

wcp:WCP-TEXTILE skos:closeMatch mat:MAT-PLA .

wcp:WCP-SYNTHETIC-PANEL skos:closeMatch mat:MAT-PLA .

wcp:WCP-PAINT skos:closeMatch mat:MAT-PLA ;
  skos:relatedMatch mat:MAT-CMP .

wcp:WCP-OTH skos:closeMatch mat:MAT-OTH .

# --- Ceiling covering products ---

ccp:CCP-METAL-SHEET skos:closeMatch mat:MAT-MET .

ccp:CCP-GYPSUM-BOARD skos:closeMatch mat:MAT-GYP .

ccp:CCP-MINERAL-FIBRE skos:closeMatch mat:MAT-INS-MWO .

ccp:CCP-WOOD skos:closeMatch mat:MAT-WOD .

ccp:CCP-SYNTHETIC skos:closeMatch mat:MAT-PLA .

ccp:CCP-METAL-PANEL skos:closeMatch mat:MAT-MET .

ccp:CCP-METAL-GRID skos:closeMatch mat:MAT-MET .

ccp:CCP-OTH skos:closeMatch mat:MAT-OTH .
