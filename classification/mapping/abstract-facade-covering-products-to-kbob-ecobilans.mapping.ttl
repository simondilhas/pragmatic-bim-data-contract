@prefix facp: <https://example.org/abstract/facade-covering-product/> .
@prefix kbobbm: <https://example.org/ch/kbob/ecobilans/baumat/2009-1-2022/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix map: <https://example.org/mapping/> .

map:abstractFacadeCoveringProductsToKbobEcobilansMapping a dcterms:Dataset ;
  dcterms:title "Abstract facade covering products to KBOB ecobilans mapping"@en ;
  dcterms:title "Mapping abstrakter Fassadenbekleidungsprodukte nach KBOB Oekobilanz"@de ;
  dcterms:references facp:scheme, kbobbm:scheme ;
  dcterms:issued "2026-07-01" ;
  dcterms:description "Maps abstract facade covering products to KBOB ecobilans rows. ETICS/WDVS uses layer narrowers for insulation and render; other facade types map to closest assembly or material row where available."@en ;
  dcterms:description "Ordnet abstrakte Fassadenbekleidungsprodukte KBOB-Oekobilanz-Zeilen zu. ETICS/WDVS nutzt Schicht-narrower fuer Daemmung und Putz; andere Fassadentypen naechste Baugruppen- oder Materialzeile."@de .

# --- ETICS / WDVS composite (layer decomposition) ---

facp:FaCP-RENDER-ETICS-WDVS-INS skos:closeMatch kbobbm:10_004 ;
  skos:relatedMatch kbobbm:10_008 .

facp:FaCP-RENDER-ETICS-WDVS-RENDER skos:closeMatch kbobbm:04_007 .

facp:FaCP-RENDER-ETICS-WDVS skos:relatedMatch kbobbm:10_004, kbobbm:04_007, kbobbm:10_008 .

# --- Direct facade product matches ---

facp:FaCP-METAL-COMPOSITE-PANEL skos:closeMatch kbobbm:05_022 .

facp:FaCP-NATURAL-STONE-VENTILATED skos:closeMatch kbobbm:05_025 .

facp:FaCP-FIBER-CEMENT-BOARD skos:closeMatch kbobbm:03_003 ;
  skos:relatedMatch kbobbm:05_028 .

facp:FaCP-SYNTHETIC-VENTILATED skos:closeMatch kbobbm:05_023 ;
  skos:relatedMatch kbobbm:05_024 .

facp:FaCP-CERAMIC-VENTILATED skos:closeMatch kbobbm:03_010 ;
  skos:relatedMatch kbobbm:11_008 .

facp:FaCP-TIMBER-VENTILATED skos:closeMatch kbobbm:07_003 .

facp:FaCP-METAL-SHEET-STANDING-SEAM skos:closeMatch kbobbm:06_001 ;
  skos:relatedMatch kbobbm:06_002 .

facp:FaCP-EXTERIOR-PAINT-COATING skos:closeMatch kbobbm:14_001 .

# --- Emerging / modular / retrofit ---

facp:FaCP-BIPV-INTEGRATED skos:closeMatch kbobbm:05_008 ;
  skos:relatedMatch kbobbm:05_022, kbobbm:06_001 .

facp:FaCP-PREFAB-MODULAR-TIMBER skos:closeMatch kbobbm:07_003 ;
  skos:relatedMatch kbobbm:07_023 .

facp:FaCP-PREFAB-MODULAR-METAL skos:closeMatch kbobbm:05_022 ;
  skos:relatedMatch kbobbm:06_012 .

facp:FaCP-RETROFIT-OVERCLADDING skos:relatedMatch kbobbm:10_004, kbobbm:04_007, kbobbm:10_008, kbobbm:05_023 .

facp:FaCP-HPL-PANEL skos:closeMatch kbobbm:05_020 ;
  skos:relatedMatch kbobbm:05_022 .

facp:FaCP-BRICK-SLIP skos:closeMatch kbobbm:02_001 ;
  skos:relatedMatch kbobbm:03_010 .

facp:FaCP-OTHER skos:closeMatch kbobbm:05_023 ;
  skos:relatedMatch kbobbm:05_022, kbobbm:04_007 .
