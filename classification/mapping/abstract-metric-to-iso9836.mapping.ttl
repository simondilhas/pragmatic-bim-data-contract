@prefix met: <https://example.org/abstract/building-metric-definition/> .
@prefix iso9836: <https://example.org/iso/9836/2017/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ex: <https://example.org/mapping/> .

ex:abstractMetricToIso9836Mapping a dcterms:Dataset ;
  dcterms:title "Abstract building metrics to ISO 9836:2017 mapping"@en ;
  dcterms:references met:scheme, iso9836:scheme ;
  dcterms:description "Close match between abstract building metrics and ISO 9836:2017 area and volume definitions."@en .

met:total_gross_floor_area skos:closeMatch iso9836:TotalFloorArea .
met:total_net_floor_area skos:closeMatch iso9836:NetFloorArea .
met:total_construction_floor_area skos:closeMatch iso9836:StructuralElementsArea .
met:total_gross_building_volume skos:closeMatch iso9836:GrossVolume .
met:total_net_building_volume skos:closeMatch iso9836:NetVolume .
