@prefix met: <https://example.org/abstract/building-metric-definition/> .
@prefix sia416: <https://example.org/sia/416/flaechen/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ex: <https://example.org/mapping/> .

ex:abstractMetricToSia416Mapping a dcterms:Dataset ;
  dcterms:title "Abstract building metrics to SIA 416 mapping"@en ;
  dcterms:references met:scheme, sia416:scheme ;
  dcterms:description "Close match between abstract building-level metrics and SIA 416 area/volume codes. Above/below ground scope variants have no SIA 416 equivalent."@en .

met:total_gross_floor_area skos:closeMatch sia416:GF .
met:total_net_floor_area skos:closeMatch sia416:NGF .
met:total_construction_floor_area skos:closeMatch sia416:KF .
met:total_exterior_floor_area skos:closeMatch sia416:AGF .
met:total_gross_building_volume skos:closeMatch sia416:GV .
