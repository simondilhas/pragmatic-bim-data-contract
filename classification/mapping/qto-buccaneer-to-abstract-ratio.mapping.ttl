@prefix qto: <https://example.org/qto-buccaneer/metric/> .
@prefix rat: <https://example.org/abstract/building-ratio-definition/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ex: <https://example.org/mapping/> .

ex:qtoBuccaneerToAbstractRatioMapping a dcterms:Dataset ;
  dcterms:title "qto_buccaneer ratio keys to abstract building ratios mapping"@en ;
  dcterms:references rat:scheme ;
  dcterms:source <https://github.com/simondilhas/qto_buccaneer/releases/tag/V0.1.3> ;
  dcterms:description "Optional guideline bridge from qto_buccaneer V0.1.3 derived ratio keys to abstract ratio concepts."@en .

qto:gv_to_gf_ratio skos:closeMatch rat:ratio_building_volume_to_gross_floor_area .
qto:window_to_floor_ratio skos:closeMatch rat:ratio_window_area_to_gross_floor_area .

qto:facade_area_to_gross_volume_ratio skos:closeMatch rat:ratio_facade_area_to_gross_volume .
qto:facade_area_to_gross_volume_ratio_above_ground skos:closeMatch rat:ratio_facade_area_to_gross_volume .

qto:facade_area_to_gross_floor_area_ratio skos:closeMatch rat:ratio_facade_area_to_gross_floor_area .
qto:facade_area_to_gross_floor_area_ratio_above_ground skos:closeMatch rat:ratio_facade_area_to_gross_floor_area .
qto:facade_area_to_gross_floor_area_ratio_below_ground skos:closeMatch rat:ratio_facade_area_to_gross_floor_area .

qto:construction_area_to_gross_floor_area_ratio skos:closeMatch rat:ratio_construction_floor_area_to_gross_floor_area .
qto:construction_area_to_gross_floor_area_ratio_above_ground skos:closeMatch rat:ratio_construction_floor_area_to_gross_floor_area .
qto:construction_area_to_gross_floor_area_ratio_below_ground skos:closeMatch rat:ratio_construction_floor_area_to_gross_floor_area .

qto:total_envelope_area_to_gross_floor_area_ratio skos:closeMatch rat:ratio_envelope_area_to_gross_floor_area .
