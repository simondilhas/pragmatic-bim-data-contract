:V01001 a skos:Concept ;
  skos:inScheme :scheme ;
  dcterms:identifier "V01001" ;
  skos:notation "V01001" ;
  skos:prefLabel "Zonenplan"@de ;
  skos:prefLabel "Plan de zones"@fr ;
  skos:definition "Bestimmt die Zonenzugehörigkeit der einzelnen Parzellen und die zulässige Nutzungsart (z.B. Wohnen, Gewerbe)"@de ;
  skos:definition "Détermine l’appartenance de zone des différentes parcelles et le type d’utilisation autorisé (p.ex. habitation, commercial)"@fr ;
  skos:broader :V01  .

:V01002 a skos:Concept ;
  skos:inScheme :scheme ;
  dcterms:identifier "V01002" ;
  skos:notation "V01002" ;
  skos:prefLabel "Nutzungsplan"@de ;
  skos:prefLabel "Plan d’affectation"@fr ;
  skos:definition "Legt die zulässige Bodennutzung flächendeckend für das ganze Gemeindegebiet grundeigentümerverbindlich fest"@de ;
  skos:definition "Définit l’utilisation autorisée du sol étendue à tout le territoire communal et rendue contraignante pour les propriétaires fonciers"@fr ;
  skos:broader :V01  .

:V01003 a skos:Concept ;
  skos:inScheme :scheme ;
  dcterms:identifier "V01003" ;
  skos:notation "V01003" ;
  skos:prefLabel "Erschliessungsplan"@de ;
  skos:prefLabel "Plan de desserte"@fr ;
  skos:definition "Legt fristgerecht die Erschliessung der Bauzonen durch das Gemeinwesen fest"@de ;
  skos:definition "Détermine en temps voulu la desserte des zones de construction par la collectivité publique"@fr ;
  skos:broader :V01  .

:V01004 a skos:Concept ;
  skos:inScheme :scheme ;
  dcterms:identifier "V01004" ;
  skos:notation "V01004" ;
  skos:prefLabel "Gestaltungsplan"@de ;
  skos:prefLabel "Plan d’aménagement"@fr ;
  skos:definition "Verfeinert die Vorgaben des Zonenplanes mit zusätzlichen Aussagen über die Nutzung, Erschliessung, Bebauung und Ausstattung"@de ;
  skos:definition "Affine les directives du plan de zones avec des déclarations complémentaires relatives à l’utilisation, la desserte, la construction et l’équipement"@fr ;
  skos:broader :V01  .

:V01005 a skos:Concept ;
  skos:inScheme :scheme ;
  dcterms:identifier "V01005" ;
  skos:notation "V01005" ;
  skos:prefLabel "Entwässerungsplan"@de ;
  skos:prefLabel "Plan de drainage"@fr ;
