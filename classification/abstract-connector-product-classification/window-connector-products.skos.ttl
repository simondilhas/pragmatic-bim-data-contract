:WICP-SPECIAL a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "WICP-SPECIAL" ;
  skos:prefLabel "Special transparent opening"@en ;
  skos:prefLabel "Spezielles lichtdurchlaessiges Bauteil"@de ;
