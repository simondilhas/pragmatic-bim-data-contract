@prefix : <https://example.org/abstract/window-connector-product/> .
@prefix kbobbm: <https://example.org/ch/kbob/ecobilans/baumat/2009-1-2022/> .
@prefix map: <https://example.org/mapping/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

:scheme a skos:ConceptScheme ;
  skos:prefLabel "Abstract window connector products"@en ;
  skos:prefLabel "Abstrakte Fenster-Verbindungsprodukte"@de ;
  dcterms:title "Abstract window connector products"@en ;
  dcterms:identifier "AbstractWindowConnectorProduct" ;
  dcterms:creator "abstract" ;
  dcterms:issued "2026-06-30" ;
  dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
  dcterms:source <https://github.com/simondilhas/pragmatic-bim-data-contract> ;
  dcterms:references map:abstractWindowConnectorProductsToKbobEcobilansMapping, kbobbm:scheme ;
  skos:scopeNote "Embodied carbon: resolve product notation via the referenced KBOB ecobilans mapping bridge (skos:closeMatch on layer narrowers where present; skos:relatedMatch on parent composites). Links KBOB Baumaterialien row notations only; obtain indicator values from the official KBOB ecobilans dataset."@en ;
  skos:scopeNote "Graue Emissionen: Produktnotation ueber referenzierte KBOB-Oekobilanz-Mapping-Bruecke aufloesen (skos:closeMatch auf Schicht-narrower; skos:relatedMatch auf Eltern-Verbundprodukte). Verknuepft nur KBOB-Baumaterialien-Zeilennotationen; Kennwerte aus offiziellem KBOB-Oekobilanzdatensatz beziehen."@de ;
  skos:definition "Product-type classification for window connectors (ConnectionPhysical with functional type visual; IFC physical type window). For catalog, specification, and cost workflows; pair with abstract material classification for frame and glazing substance."@en ;
  skos:definition "Produkttyp-Klassifikation fuer Fenster-Verbindungen (ConnectionPhysical mit funktionalem Typ visual; IFC-physischer Typ window). Fuer Katalog-, Spezifikations- und Kostenworkflows; mit abstrakter Materialklassifikation fuer Rahmen- und Verglasungssubstanz kombinieren."@de ;
  skos:scopeNote "Default PBS entity is ConnectionPhysical. Interior vs exterior position is not encoded here; BKP bridges use closeMatch for Rohbau 221.x (exterior) and relatedMatch for Ausbau 272/273 (interior) where applicable."@en ;
  skos:scopeNote "Standard-PBS-Entitaet ist ConnectionPhysical. Innen- vs Aussenlage ist hier nicht kodiert; BKP-Mappings mit closeMatch fuer Rohbau 221.x (aussen) und relatedMatch fuer Ausbau 272/273 (innen) wo zutreffend."@de ;
  skos:hasTopConcept
    :WICP-WOOD,
    :WICP-WOOD-METAL,
    :WICP-PVC,
    :WICP-STEEL,
    :WICP-ALUMINIUM,
    :WICP-SPECIAL,
    :WICP-SKYLIGHT,
    :WICP-FACADE-UNIT,
    :WICP-OTH .

:WICP-WOOD a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "WICP-WOOD" ;
  skos:prefLabel "Wood window system"@en ;
  skos:prefLabel "Holzfenster"@de ;
  skos:definition "Window with primary wood frame and sash, including traditional timber windows."@en ;
  skos:definition "Fenster mit primaerem Holzrahmen und -fluegel, einschliesslich traditioneller Holzfenster."@de ;
  skos:narrower :WICP-WOOD-FRAME, :WICP-WOOD-GLZ-2P ;
  dcterms:subject "IfcWindow" ;
  dcterms:identifier "wood-window" .

:WICP-WOOD-FRAME a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "WICP-WOOD-FRAME" ;
  skos:prefLabel "Wood window frame layer"@en ;
  skos:prefLabel "Holzfenster Rahmen-Schicht"@de ;
  skos:definition "Wood frame and sash layer of a wood window system."@en ;
  skos:definition "Holzrahmen- und -fluegel-Schicht eines Holzfensters."@de ;
  skos:broader :WICP-WOOD ;
  skos:scopeNote "LCA layer component of WICP-WOOD. Used for ecobilans decomposition and carbon calculation; not a standalone window product classification."@en ;
  skos:scopeNote "LCA-Schichtkomponente von WICP-WOOD. Fuer Oekobilanz-Zerlegung und CO2-Berechnung; keine eigenstaendige Fensterprodukt-Klassifikation."@de ;
  dcterms:subject "IfcWindow" ;
  dcterms:identifier "wood-window-frame-layer" .

:WICP-WOOD-GLZ-2P a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "WICP-WOOD-GLZ-2P" ;
  skos:prefLabel "Wood window 2-pane glazing layer"@en ;
  skos:prefLabel "Holzfenster 2-fach Verglasung-Schicht"@de ;
  skos:definition "Default double-pane insulating glazing layer of a wood window system."@en ;
  skos:definition "Standard-Isolierverglasung (2-fach) eines Holzfensters."@de ;
  skos:broader :WICP-WOOD ;
  skos:scopeNote "LCA layer component of WICP-WOOD. Used for ecobilans decomposition and carbon calculation; not a standalone window product classification."@en ;
  skos:scopeNote "LCA-Schichtkomponente von WICP-WOOD. Fuer Oekobilanz-Zerlegung und CO2-Berechnung; keine eigenstaendige Fensterprodukt-Klassifikation."@de ;
  dcterms:subject "IfcWindow" ;
  dcterms:identifier "wood-window-glazing-layer" .

