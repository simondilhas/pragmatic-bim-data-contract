  skos:definition "Spezielles lichtdurchlaessiges Oeffnungsprodukt ausserhalb ueblicher Fensterrahmentypen."@de ;
  dcterms:subject "IfcWindow" ;
  dcterms:identifier "special-window" .

:WICP-SKYLIGHT a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "WICP-SKYLIGHT" ;
  skos:prefLabel "Roof window / skylight"@en ;
  skos:prefLabel "Dachfenster / Oberlicht"@de ;
  skos:definition "Roof-mounted window, skylight, or rooflight product."@en ;
  skos:definition "Dachmontiertes Fenster, Oberlicht oder Dachflaechenfenster-Produkt."@de ;
  skos:scopeNote "Often costed under BKP 224 (Bedachungsarbeiten) for roof integration; see BKP mapping bridge."@en ;
  skos:scopeNote "Wird oft unter BKP 224 (Bedachungsarbeiten) bei Dachintegration kalkuliert; siehe BKP-Mapping."@de ;
  dcterms:subject "IfcWindow" ;
  dcterms:identifier "skylight" .

:WICP-FACADE-UNIT a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "WICP-FACADE-UNIT" ;
  skos:prefLabel "Facade glazing unit"@en ;
  skos:prefLabel "Fassaden-Verglasungselement"@de ;
  skos:definition "Unitised or stick-system facade glazing panel integrated as a window-type connector opening."@en ;
  skos:definition "Element- oder Pfosten-Riegel-Fassaden-Verglasungspaneel als fensterartige Verbindungs-Oeffnung."@de ;
  skos:scopeNote "Distinct from SWP-CURTAIN-WALL separator product; tags the operable or fixed glazing unit as ConnectionPhysical."@en ;
  skos:scopeNote "Unterscheidet sich vom SWP-CURTAIN-WALL-Trennelementprodukt; kennzeichnet das feste oder oeffnende Verglasungselement als ConnectionPhysical."@de ;
  dcterms:subject "IfcWindow" ;
  dcterms:identifier "facade-glazing-unit" .

:WICP-OTH a skos:Concept ;
