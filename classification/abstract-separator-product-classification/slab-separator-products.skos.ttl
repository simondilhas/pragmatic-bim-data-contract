@prefix : <https://example.org/abstract/slab-separator-product/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

:scheme a skos:ConceptScheme ;
  skos:prefLabel "Abstract slab separator products"@en ;
  skos:prefLabel "Abstrakte Deckenplatten-Trennelementprodukte"@de ;
  dcterms:title "Abstract slab separator products"@en ;
  dcterms:identifier "AbstractSlabSeparatorProduct" ;
  dcterms:creator "abstract" ;
  dcterms:issued "2026-06-30" ;
  dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
  dcterms:source <https://github.com/simondilhas/pragmatic-bim-data-contract> ;
  skos:definition "Product-type classification for slab-based separating elements including floor slabs, base slabs, and roof slabs. For catalog, specification, and cost workflows; pair with abstract material classification for dominant substance and separator slab role classification for topological role."@en ;
  skos:definition "Produkttyp-Klassifikation fuer deckenplattenbasierte Trennelemente einschliesslich Geschossdecken, Bodenplatten und Dachdecken. Fuer Katalog-, Spezifikations- und Kostenworkflows; mit abstrakter Materialklassifikation fuer dominante Substanz und Trenndeckenrollen-Klassifikation fuer topologische Rolle kombinieren."@de ;
  skos:scopeNote "Default PBS entity is SeparatorSlab. Tags construction or system product type, not dominant substance or topological role alone."@en ;
  skos:scopeNote "Standard-PBS-Entitaet ist SeparatorSlab. Kennzeichnet Bau- oder Systemprodukttyp, nicht allein dominante Substanz oder topologische Rolle."@de ;
  skos:hasTopConcept
    :SSP-INSITU,
    :SSP-PREFAB-CONC,
    :SSP-STEEL-COMPOSITE,
    :SSP-TIMBER,
    :SSP-HBV,
    :SSP-HOLZ-LEHM,
    :SSP-LIGHTWEIGHT,
    :SSP-OTH .

:SSP-INSITU a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "SSP-INSITU" ;
  skos:prefLabel "In-situ concrete slab"@en ;
  skos:prefLabel "Ortbeton-Decke / -Platte"@de ;
  skos:definition "Slab cast in place from reinforced or plain concrete."@en ;
  skos:definition "Decke oder Platte in Ortbeton oder Stahlbeton ausgefuehrt."@de ;
  dcterms:subject "IfcSlab" ;
  dcterms:identifier "insitu-slab" .

:SSP-PREFAB-CONC a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "SSP-PREFAB-CONC" ;
  skos:prefLabel "Prefabricated concrete slab"@en ;
  skos:prefLabel "Elementdecke / -platte Beton"@de ;
  skos:definition "Slab from prefabricated concrete elements such as hollow-core, double-tee, or flat slabs."@en ;
  skos:definition "Decke oder Platte aus vorgefertigten Betonelementen wie Hohldiele, Doppel-T-Traeger oder Flachdeckelementen."@de ;
  dcterms:subject "IfcSlab" ;
  dcterms:identifier "prefab-conc-slab" .

:SSP-STEEL-COMPOSITE a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "SSP-STEEL-COMPOSITE" ;
  skos:prefLabel "Steel deck / composite slab"@en ;
  skos:prefLabel "Stahlverbunddecke"@de ;
  skos:definition "Slab with primary steel deck, beams, or composite steel-concrete system."@en ;
  skos:definition "Decke mit primaerer Stahltrapezprofil-, Traeger- oder Stahl-Beton-Verbundkonstruktion."@de ;
  dcterms:subject "IfcSlab" ;
  dcterms:identifier "steel-composite-slab" .

:SSP-TIMBER a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "SSP-TIMBER" ;
  skos:prefLabel "Timber slab / deck"@en ;
  skos:prefLabel "Holzdecke / -platte"@de ;
  skos:definition "Slab or deck with primary timber joists, panels, or engineered-wood structure."@en ;
  skos:definition "Decke oder Platte mit primaerer Holz- oder Holzwerkstoff-Konstruktion."@de ;
  dcterms:subject "IfcSlab" ;
  dcterms:identifier "timber-slab" .

:SSP-HBV a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "SSP-HBV" ;
  skos:prefLabel "Timber–concrete composite slab (HBV)"@en ;
  skos:prefLabel "Holz-Beton-Verbunddecke (HBV)"@de ;
  skos:altLabel "Holbetonverbund"@de ;
  skos:definition "Hybrid slab with timber base (for example block timber, CLT, or rib deck) and a shear-connected concrete topping cast on site or prefabricated as a composite element."@en ;
  skos:definition "Hybride Decke mit Holztragwerk (z. B. Blockholzplatte, Brettsperrholz oder Rippendecke) und schubfest verbundener Ortbeton- oder Fertigbetonauflage."@de ;
  dcterms:subject "IfcSlab" ;
  dcterms:identifier "hbv-slab" .

:SSP-HOLZ-LEHM a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "SSP-HOLZ-LEHM" ;
  skos:prefLabel "Timber–clay slab / deck"@en ;
  skos:prefLabel "Holz-Lehm-Decke"@de ;
  skos:definition "Slab or deck with timber joists or frame and rammed-clay (Stampflehm) infill or topping, including prefabricated timber–clay panel systems."@en ;
  skos:definition "Decke mit Holztraegern oder -rahmen und Stampflehm-Ausfachung oder -auflage, einschliesslich vorgefertigter Holz-Lehm-Deckenelemente."@de ;
  dcterms:subject "IfcSlab" ;
  dcterms:identifier "holz-lehm-slab" .

:SSP-LIGHTWEIGHT a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "SSP-LIGHTWEIGHT" ;
  skos:prefLabel "Lightweight slab system"@en ;
  skos:prefLabel "Leichtbau-Decke / -Platte"@de ;
  skos:definition "Lightweight slab system with non-monolithic primary structure."@en ;
  skos:definition "Leichtbau-Decken- oder Plattensystem mit nicht-monolithischer Primaerkonstruktion."@de ;
  dcterms:subject "IfcSlab" ;
  dcterms:identifier "lightweight-slab" .

:SSP-OTH a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "SSP-OTH" ;
  skos:prefLabel "Other / unknown slab separator"@en ;
  skos:prefLabel "Sonstige / unbekannte Decke / Platte"@de ;
  skos:definition "Slab separator product not classified or not yet known."@en ;
  skos:definition "Deckenplatten-Trennelementprodukt nicht klassifiziert oder noch unbekannt."@de ;
  skos:scopeNote "Fallback for early design stages or missing data."@en ;
  skos:scopeNote "Fallback fuer fruehe Entwurfsstufen oder fehlende Daten."@de ;
  dcterms:subject "IfcSlab" ;
  dcterms:identifier "other" .
