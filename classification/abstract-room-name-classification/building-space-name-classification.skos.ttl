  skos:hasTopConcept :RN_RES, :RN_WRK, :RN_CIR, :RN_HYG, :RN_HLC, :RN_LRN, :RN_COM, :RN_IND, :RN_TEC, :RN_STO, :RN_OUT, :RN_VOI .

