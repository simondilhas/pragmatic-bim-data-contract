@prefix : <https://example.org/abstract/mep-unit-product/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

:scheme a skos:ConceptScheme ;
  skos:prefLabel "Abstract MEP unit products"@en ;
  skos:prefLabel "Abstrakte TGA-Erzeuger-/Wandlerprodukte"@de ;
  dcterms:title "Abstract MEP unit products"@en ;
  dcterms:identifier "AbstractMepUnitProduct" ;
  dcterms:creator "abstract" ;
  dcterms:issued "2026-07-02" ;
  dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
  dcterms:source <https://github.com/simondilhas/pragmatic-bim-data-contract> ;
  skos:definition "Product-type classification for MEP generating or converting units (producer/converter role; aligns with SystemType.unit). For catalog, specification, and cost workflows on Equipment and grouped IfcSystem plant."@en ;
  skos:definition "Produkttyp-Klassifikation fuer TGA-Erzeuger- oder Wandlereinheiten (Erzeuger-/Wandlerrolle; entspricht SystemType.unit). Fuer Katalog-, Spezifikations- und Kostenworkflows auf Equipment und gruppierten IfcSystem-Anlagen."@de ;
  skos:scopeNote "Default PBS entity is Equipment. When the IFC model groups plant as IfcSystem, pair with System.system_type = unit. Discipline token in notation must be compatible with parent system ConnectionFunctionalType via mapping bridge."@en ;
  skos:scopeNote "Standard-PBS-Entitaet ist Equipment. Bei Gruppierung als IfcSystem mit System.system_type = unit kombinieren. Disziplin-Token in der Notation muss ueber Mapping-Bruecke mit ConnectionFunctionalType des Elternsystems kompatibel sein."@de ;
  skos:hasTopConcept
    :MUP-ELEC-TRANSFORMER,
    :MUP-ELEC-MAIN-DIST-BOARD,
    :MUP-ELEC-SUB-DIST-BOARD,
    :MUP-ELEC-UPS,
    :MUP-ELEC-GENERATOR,
    :MUP-DATA-PATCH-PANEL,
    :MUP-DATA-NETWORK-SWITCH,
    :MUP-DATA-SERVER,
    :MUP-VENT-AHU,
    :MUP-VENT-FAN,
    :MUP-HEAT-BOILER,
    :MUP-HEAT-HEAT-PUMP,
    :MUP-HEAT-DISTRICT-HEAT-SUBSTATION,
    :MUP-COOL-CHILLER,
    :MUP-COOL-FREE-COOLER,
    :MUP-FW-PRESSURE-BOOSTER,
    :MUP-FW-WATER-HEATER,
    :MUP-WW-LIFTING-STATION,
    :MUP-WW-GREASE-SEPARATOR,
    :MUP-SM-COMPRESSOR,
    :MUP-SM-GAS-REGULATOR,
    :MUP-SM-FIRE-PUMP .

# --- Electrical (ELEC) ---

:MUP-ELEC-TRANSFORMER a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "MUP-ELEC-TRANSFORMER" ;
  skos:prefLabel "Transformer"@en ;
  skos:prefLabel "Transformator"@de ;
  skos:definition "Power transformer converting voltage for building distribution."@en ;
  skos:definition "Leistungstransformator zur Spannungswandlung fuer die Gebaeudeverteilung."@de ;
  dcterms:subject "IfcTransformer" ;
  dcterms:identifier "transformer" .

:MUP-ELEC-MAIN-DIST-BOARD a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "MUP-ELEC-MAIN-DIST-BOARD" ;
  skos:prefLabel "Main distribution board"@en ;
  skos:prefLabel "Hauptverteilung"@de ;
  skos:definition "Main electrical distribution board (Hauptverteilung) at building or site entry."@en ;
  skos:definition "Hauptverteilung (HV) am Gebaeude- oder Anschlusseingang."@de ;
  dcterms:subject "IfcElectricDistributionBoard" ;
  dcterms:identifier "main-distribution-board" .

:MUP-ELEC-SUB-DIST-BOARD a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "MUP-ELEC-SUB-DIST-BOARD" ;
  skos:prefLabel "Sub-distribution board"@en ;
  skos:prefLabel "Unterverteilung"@de ;
  skos:definition "Sub-distribution board (Unterverteilung) serving a floor, zone, or tenant."@en ;
  skos:definition "Unterverteilung (UV) fuer Etage, Zone oder Mietbereich."@de ;
  dcterms:subject "IfcElectricDistributionBoard" ;
  dcterms:identifier "sub-distribution-board" .

:MUP-ELEC-UPS a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "MUP-ELEC-UPS" ;
  skos:prefLabel "Uninterruptible power supply"@en ;
  skos:prefLabel "USV-Anlage"@de ;
  skos:definition "Uninterruptible power supply (UPS) unit for critical loads."@en ;
  skos:definition "Unterbrechungsfreie Stromversorgung (USV) fuer kritische Verbraucher."@de ;
  dcterms:subject "IfcElectricFlowStorageDevice" ;
  dcterms:identifier "ups" .

:MUP-ELEC-GENERATOR a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "MUP-ELEC-GENERATOR" ;
  skos:prefLabel "Backup generator"@en ;
  skos:prefLabel "Notstromaggregat"@de ;
  skos:definition "Standby or emergency electrical generator set."@en ;
  skos:definition "Reserve- oder Notstromaggregat."@de ;
  dcterms:subject "IfcElectricGenerator" ;
  dcterms:identifier "generator" .

