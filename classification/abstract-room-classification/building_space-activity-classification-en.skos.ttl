  skos:notation "S" ;
  skos:prefLabel "Support Spaces"@en ;
  skos:prefLabel "Unterstuetzungsflaechen"@de ;
  skos:definition "Auxiliary spaces supporting building operations"@en ;
  skos:definition "Kategorie fuer unterstuetzungsflaechen im Klassifikationssystem."@de ;
  dcterms:description "Spaces that enable the functioning of main activity spaces"@en ;
  dcterms:description "Diese Klasse umfasst unterstuetzungsflaechen innerhalb des Klassifikationssystems."@de ;
  skos:narrower :S_CIR, :S_HYG, :S_PRK, :S_STO, :S_TEC, :S_VOI ;
  dcterms:subject "IfcSpace" ;
  dcterms:identifier "S" .

:S_CIR a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "S-CIR" ;
  skos:prefLabel "Support Circulation Spaces"@en ;
  skos:prefLabel "Nebenerschliessungsflaechen"@de ;
  skos:definition "Auxiliary circulation spaces"@en ;
  skos:definition "Kategorie fuer nebenerschliessungsflaechen im Klassifikationssystem."@de ;
  dcterms:description "Main circulation spaces, Corridors, fire exits, and other circulation spaces not part of main activities"@en ;
  dcterms:description "Diese Klasse umfasst nebenerschliessungsflaechen innerhalb des Klassifikationssystems."@de ;
  skos:broader :S ;
  skos:narrower :S_CIR_HOR, :S_CIR_VRT_MAN, :S_CIR_VRT_MEC ;
  dcterms:subject "IfcSpace" ;
  dcterms:identifier "S-CIR" .

:S_CIR_HOR a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "S-CIR-HOR" ;
  skos:prefLabel "Horizontal Circulation"@en ;
  skos:prefLabel "Horizontale Erschliessung"@de ;
