  skos:notation "S-HYG" ;
  skos:prefLabel "Hygiene Spaces"@en ;
  skos:prefLabel "Hygiene- und Sanitaerflaechen"@de ;
  skos:definition "Spaces for personal hygiene and sanitary activities"@en ;
  skos:definition "Kategorie fuer hygiene- und sanitaerflaechen im Klassifikationssystem."@de ;
  dcterms:description "Auxiliary spaces for toilets, washing, and changing not integral to main activities"@en ;
  dcterms:description "Diese Klasse umfasst hygiene- und sanitaerflaechen innerhalb des Klassifikationssystems."@de ;
  skos:broader :S ;
  skos:narrower :S_HYG_GRD, :S_HYG_SHW, :S_HYG_WC ;
  dcterms:subject "IfcSpace" ;
  dcterms:identifier "S-HYG" .

:S_HYG_WC a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "S-HYG-WC" ;
  skos:prefLabel "Toilet Spaces"@en ;
  skos:prefLabel "WC- und Sanitaerraeume"@de ;
