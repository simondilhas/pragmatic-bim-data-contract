  skos:definition "Kategorie fuer wc- und sanitaerraeume im Klassifikationssystem."@de ;
  dcterms:description "Toilet rooms classified by intended user group when known"@en ;
  dcterms:description "WC-Raeume nach vorgesehener Nutzergruppe, sofern bekannt."@de ;
  skos:broader :S_HYG ;
  skos:narrower :S_HYG_WC_F, :S_HYG_WC_IV, :S_HYG_WC_M, :S_HYG_WC_MIX ;
  dcterms:subject "IfcSpace" ;
  dcterms:identifier "S-HYG-WC" .

:S_HYG_WC_M a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "S-HYG-WC-M" ;
  skos:prefLabel "Male Toilet Spaces"@en ;
  skos:prefLabel "Herren-WC"@de ;
