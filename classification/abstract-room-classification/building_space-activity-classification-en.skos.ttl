  dcterms:description "Diese Klasse umfasst treppen- und rampenerschliessung innerhalb des Klassifikationssystems."@de ;
  skos:broader :S_CIR ;
  dcterms:subject "IfcSpace" ;
  dcterms:identifier "S-CIR-VRT-MAN" .

:S_CIR_VRT_MEC a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "S-CIR-VRT-MEC" ;
  skos:prefLabel "Lift and Escalator Circulation"@en ;
  skos:prefLabel "Lift- und Rolltreppenerschliessung"@de ;
