  skos:definition "WC-Raeume fuer Frauen."@de ;
  dcterms:description "Including women's restrooms"@en ;
  dcterms:description "Einschliesslich Damen-WC."@de ;
  skos:broader :S_HYG_WC ;
  dcterms:subject "IfcSpace" ;
  dcterms:identifier "S-HYG-WC-F" .

