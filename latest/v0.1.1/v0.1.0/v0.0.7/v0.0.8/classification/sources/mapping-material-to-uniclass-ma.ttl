@prefix mat: <https://example.org/abstract/material-classification/> .
@prefix ma: <https://example.org/uniclass/2015/ma/v1_1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix map: <https://example.org/mapping/> .

map:abstractMaterialToUniclassMaMapping a dcterms:Dataset ;
  dcterms:title "Abstract material classification to Uniclass Ma mapping"@en ;
  dcterms:title "Mapping abstrakter Materialklassifikation nach Uniclass Ma"@de ;
  dcterms:references mat:scheme, ma:scheme ;
  dcterms:issued "2026-06-02" ;
  dcterms:description "Operational 1:n mapping from abstract dominant-material classes to Uniclass 2015 Ma concepts for rough sustainability workflows. Uses skos:broadMatch because abstract classes subsume multiple Ma leaves."@en ;
  dcterms:description "Operatives 1:n-Mapping von abstrakten dominanten Materialklassen auf Uniclass-2015-Ma-Konzepte fuer grobe Nachhaltigkeitsberechnungen. Verwendet skos:broadMatch, da abstrakte Klassen mehrere Ma-Blattkonzepte umfassen."@de .

mat:MAT-CONC skos:broadMatch ma:Ma_40_19 .

mat:MAT-MET skos:broadMatch ma:Ma_40_52, ma:Ma_40_52_83 .

mat:MAT-WOD skos:broadMatch ma:Ma_60_97 .

mat:MAT-GYP skos:broadMatch ma:Ma_40_15, ma:Ma_40_15_35 .

mat:MAT-GLS skos:broadMatch ma:Ma_40_35 .

mat:MAT-MSN skos:broadMatch ma:Ma_40_84, ma:Ma_20_13 .

mat:MAT-INS skos:broadMatch ma:Ma_40_84_53, ma:Ma_40_35_34, ma:Ma_60_65_85_28, ma:Ma_60_65_85_27 .

mat:MAT-PLA skos:broadMatch ma:Ma_60_65 .

mat:MAT-CMP skos:broadMatch ma:Ma_20 .
