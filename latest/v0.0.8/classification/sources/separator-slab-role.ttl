@prefix : <https://example.org/abstract/separator-slab-role-classification/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

:scheme a skos:ConceptScheme ;
  skos:prefLabel "Building Separator Slab Role Classification"@en ;
  skos:prefLabel "Klassifikation der Trenndeckenrollen"@de ;
  dcterms:title "Building Separator Slab Role Classification"@en ;
  dcterms:identifier "BuildingSeparatorSlabRoleClassification" ;
  dcterms:creator "abstract" ;
  dcterms:issued "2026-06-02" ;
  dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
  skos:definition "Topological role classification for slab-based separating elements (SeparatorSlab), derived from adjacent space and level relationships."@en ;
  skos:definition "Topologische Rollenklassifikation fuer deckenbasierte Trennelemente (SeparatorSlab), abgeleitet aus angrenzenden Raum- und Geschossbeziehungen."@de ;
  skos:hasTopConcept :L_EXT, :L_INT .

:L_EXT a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "L-EXT" ;
  skos:prefLabel "Exterior slab"@en ;
  skos:prefLabel "Aussendeckung"@de ;
  skos:definition "Slab separating occupied or conditioned space from the exterior environment."@en ;
  skos:definition "Decke, die genutzten oder konditionierten Raum von der Aussenumgebung trennt."@de ;
  dcterms:description "Including exposed roof decks, balcony slabs, and other exterior horizontal separations."@en ;
  dcterms:description "Einschliesslich freiliegende Dachflaechen, Balkonplatten und andere horizontale Aussenabgrenzungen."@de ;
  dcterms:subject "IfcSlab" ;
  dcterms:identifier "L-EXT" .

:L_INT a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "L-INT" ;
  skos:prefLabel "Interior slab"@en ;
  skos:prefLabel "Innendeckung"@de ;
  skos:definition "Interior slab whose primary role is defined by adjacent space or level topology."@en ;
  skos:definition "Innendeckung, deren primaere Rolle durch die topologische Lage zu angrenzenden Raeumen oder Geschossen bestimmt wird."@de ;
  skos:narrower :L_INT_UNT, :L_INT_CIR, :L_INT_ROF, :L_INT_GRD, :L_INT_PRT ;
  dcterms:subject "IfcSlab" ;
  dcterms:identifier "L-INT" .

:L_INT_UNT a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "L-UNT" ;
  skos:prefLabel "Unit boundary slab"@en ;
  skos:prefLabel "Geschossdecke zwischen Nutzungseinheiten"@de ;
  skos:definition "Slab separating independent occupancy or fire-compartment units vertically."@en ;
  skos:definition "Decke, die selbstaendige Nutzungs- oder Brandabschnittseinheiten vertikal voneinander trennt."@de ;
  dcterms:description "Including floor slabs between dwellings or between tenant units where the unit boundary drives requirements."@en ;
  dcterms:description "Einschliesslich Geschossdecken zwischen Wohnungen oder Mieteinheiten, wenn die Einheitstrennung die Anforderungen bestimmt."@de ;
  skos:broader :L_INT ;
  dcterms:subject "IfcSlab" ;
  dcterms:identifier "L-UNT" .

:L_INT_CIR a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "L-CIR" ;
  skos:prefLabel "Circulation slab"@en ;
  skos:prefLabel "Erschliessungsdecke"@de ;
  skos:definition "Slab associated primarily with circulation spaces."@en ;
  skos:definition "Decke mit primaerem Bezug zu Erschliessungsraeumen."@de ;
  dcterms:description "Including corridor floors, stair landings, and other horizontal circulation surfaces."@en ;
  dcterms:description "Einschliesslich Korridorboeden, Treppenpodeste und andere horizontale Erschliessungsflaechen."@de ;
  skos:broader :L_INT ;
  dcterms:subject "IfcSlab" ;
  dcterms:identifier "L-CIR" .

:L_INT_ROF a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "L-ROF" ;
  skos:prefLabel "Roof separation slab"@en ;
  skos:prefLabel "Dachabgrenzungsdecke"@de ;
  skos:definition "Slab forming the primary separation at roof level between conditioned and unconditioned zones."@en ;
  skos:definition "Decke als primaere Abgrenzung auf Dachniveau zwischen konditionierten und unkonditionierten Zonen."@de ;
  dcterms:description "Including top-floor ceiling/roof build-up slabs where roof separation drives requirements."@en ;
  dcterms:description "Einschliesslich oberste Geschossdecken im Dachaufbau, wenn die Dachabgrenzung die Anforderungen bestimmt."@de ;
  skos:broader :L_INT ;
  dcterms:subject "IfcSlab" ;
  dcterms:identifier "L-ROF" .

:L_INT_GRD a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "L-GRD" ;
  skos:prefLabel "Ground or cellar slab"@en ;
  skos:prefLabel "Boden- oder Kellerdecke"@de ;
  skos:definition "Slab at ground level or below grade separating interior from earth or exterior below-grade conditions."@en ;
  skos:definition "Decke auf Erdgeschossniveau oder unterhalb, die Innenraum von Erdreich oder aussenseitigen Untergeschossbedingungen trennt."@de ;
  dcterms:description "Including ground floor slabs, cellar floors, and basement deck separations."@en ;
  dcterms:description "Einschliesslich Bodenplatten, Kellerdecken und Untergeschossabgrenzungen."@de ;
  skos:broader :L_INT ;
  dcterms:subject "IfcSlab" ;
  dcterms:identifier "L-GRD" .

:L_INT_PRT a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "L-PRT" ;
  skos:prefLabel "Internal partition slab"@en ;
  skos:prefLabel "Innere Trennplatte"@de ;
  skos:definition "Slab separating spaces within the same occupancy unit without a special boundary role."@en ;
  skos:definition "Decke, die Raeume innerhalb derselben Nutzungseinheit ohne besondere Grenzrollenfunktion trennt."@de ;
  dcterms:description "Including mezzanine floors and internal level changes within a single unit."@en ;
  dcterms:description "Einschliesslich Zwischengeschosse und innere Niveauwechsel innerhalb einer Einheit."@de ;
  skos:broader :L_INT ;
  dcterms:subject "IfcSlab" ;
  dcterms:identifier "L-PRT" .
