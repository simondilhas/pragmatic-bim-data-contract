@prefix wall: <https://example.org/abstract/separator-wall-role-classification/> .
@prefix slab: <https://example.org/abstract/separator-slab-role-classification/> .
@prefix space: <https://example.org/abstract/building-space-activity-classification/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix map: <https://example.org/mapping/> .

map:separatorRoleToSpaceActivityMapping a dcterms:Dataset ;
  dcterms:title "Separator role to Building Space Activity Classification mapping"@en ;
  dcterms:title "Mapping von Trennelementrollen zur Gebaeude-Raum-Aktivitaetsklassifikation"@de ;
  dcterms:references wall:scheme, slab:scheme, space:scheme ;
  dcterms:description "Starter relatedMatch links from topological separator wall and slab roles to adjacent space activity concepts. Inference priority when multiple space types meet (for example M-RES plus S-CIR-HOR assigning W-UNT) belongs in PBS rules, not in this mapping."@en ;
  dcterms:description "Start-relatedMatch-Verknuepfungen von topologischen Trennwand- und Trenndeckenrollen zu angrenzenden Raumaktivitaetskonzepten. Prioritaetsregeln bei mehreren Raumtypen (z. B. M-RES plus S-CIR-HOR ergibt W-UNT) gehoeren in PBS-Regeln, nicht in dieses Mapping."@de .

# Wall roles to adjacent space activity hints
wall:W_INT_CIR_VRT skos:relatedMatch space:S_CIR_VRT .
wall:W_INT_CIR_HOR skos:relatedMatch space:S_CIR_HOR .
wall:W_INT_SVC skos:relatedMatch space:S_TEC, space:S_VOI, space:S_VOI_VRT, space:S_VOI_PLN, space:S_VOI_STR, space:S_VOI_MLT .
wall:W_INT_UNT skos:relatedMatch space:M .
wall:W_EXT skos:relatedMatch space:O .
wall:W_INT_GRD skos:relatedMatch space:S_PRK_INT .

# Slab roles to adjacent space activity hints
slab:L_INT_UNT skos:relatedMatch space:M .
slab:L_INT_CIR skos:relatedMatch space:S_CIR_HOR, space:S_CIR_VRT .
slab:L_EXT skos:relatedMatch space:O .
slab:L_INT_GRD skos:relatedMatch space:S_PRK_INT .
