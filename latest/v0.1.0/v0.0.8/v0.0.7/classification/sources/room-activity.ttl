  skos:definition "Kategorie fuer innenparkierungsflaechen im Klassifikationssystem."@de ;
  dcterms:description "Including underground and enclosed structured parking facilities"@en ;
  dcterms:description "Diese Klasse umfasst innenparkierungsflaechen innerhalb des Klassifikationssystems."@de ;
  skos:broader :S_PRK ;
  dcterms:subject "IfcSpace" ;
  dcterms:identifier "S-PRK-INT" .

:S_PRK_SVC a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "S-PRK-SVC" ;
