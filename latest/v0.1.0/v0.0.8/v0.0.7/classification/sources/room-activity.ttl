  dcterms:identifier "O-CIR" .

:O_CIR_PED a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "O-CIR-PED" ;
  skos:prefLabel "Pedestrian Circulation"@en ;
  skos:prefLabel "Fussgaengererschliessung"@de ;
  skos:definition "Pedestrian movement spaces"@en ;
  skos:definition "Kategorie fuer fussgaengererschliessung im Klassifikationssystem."@de ;
  dcterms:description "Including walkways, paths, and outdoor corridors"@en ;
  dcterms:description "Diese Klasse umfasst fussgaengererschliessung innerhalb des Klassifikationssystems."@de ;
  skos:broader :O_CIR ;
  dcterms:subject "IfcSpace" ;
  dcterms:identifier "O-CIR-PED" .

:O_CIR_RD a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "O-CIR-RD" ;
  skos:prefLabel "Roads"@en ;
  skos:prefLabel "Fahrwege"@de ;
  skos:definition "Vehicular circulation routes"@en ;
  skos:definition "Kategorie fuer fahrwege im Klassifikationssystem."@de ;
  dcterms:description "Including access roads, driveways, and service roads"@en ;
  dcterms:description "Diese Klasse umfasst fahrwege innerhalb des Klassifikationssystems."@de ;
  skos:broader :O_CIR ;
  dcterms:subject "IfcSpace" ;
  dcterms:identifier "O-CIR-RD" .

:O_GRN a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "O-GRN" ;
  skos:prefLabel "Green Spaces"@en ;
  skos:prefLabel "Gruenflaechen"@de ;
  skos:definition "Landscaped and natural area spaces"@en ;
  skos:definition "Kategorie fuer gruenflaechen im Klassifikationssystem."@de ;
