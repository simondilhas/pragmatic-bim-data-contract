  dcterms:description "Diese Klasse umfasst vertikale erschliessung innerhalb des Klassifikationssystems."@de ;
  skos:broader :S_CIR ;
  dcterms:subject "IfcSpace" ;
  dcterms:identifier "S-CIR-VRT" .

