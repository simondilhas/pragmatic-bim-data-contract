  dcterms:description "Diese Klasse umfasst aussenparkierungsflaechen innerhalb des Klassifikationssystems."@de ;
  skos:broader :S_PRK ;
  dcterms:subject "IfcSpace" ;
  dcterms:identifier "S-PRK-EXT" .

:S_PRK_INT a skos:Concept ;
