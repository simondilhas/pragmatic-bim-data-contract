  dcterms:identifier "S-VOI-STR" .

:S_VOI_VRT a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "S-VOI-VRT" ;
  skos:prefLabel "Vertical Void Spaces"@en ;
  skos:prefLabel "Vertikale Hohlraeume"@de ;
