@prefix : <https://example.org/abstract/building-space-activity-classification/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

:scheme a skos:ConceptScheme ;
  skos:prefLabel "Building Space and Activity Classification System"@en ;
  skos:prefLabel "Klassifikationssystem fuer Gebaeude-, Raum- und Aktivitaetsflaechen"@de ;
  dcterms:title "Building Space and Activity Classification System"@en ;
  dcterms:identifier "BuildingSpaceActivityClassification" ;
  dcterms:creator "abstract" ;
  dcterms:issued "2024-11-04" ;
  dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
  dcterms:source <https://github.com/simondilhas/pragmatic-bim-public-rules> ;
  skos:definition "Building Space and Activity Classification System (BuildingSpaceActivityClassification), version 1.0.3."@en ;
  skos:definition "Klassifikationssystem fuer Gebaeude-, Raum- und Aktivitaetsflaechen mit hierarchischer Einteilung von Nutzungs-, Unterstuetzungs- und Aussenbereichen."@de ;
  skos:hasTopConcept :M, :O, :S .

:M a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "M" ;
  skos:prefLabel "Main Activity Spaces"@en ;
  skos:prefLabel "Hauptnutzungsflaechen"@de ;
  skos:definition "Primary spaces for building occupants' activities"@en ;
  skos:definition "Kategorie fuer hauptnutzungsflaechen im Klassifikationssystem."@de ;
  dcterms:description "Core functional spaces that serve the building's primary purpose"@en ;
  dcterms:description "Diese Klasse umfasst hauptnutzungsflaechen innerhalb des Klassifikationssystems."@de ;
  skos:narrower :M_CIR, :M_COM, :M_HEL, :M_LRN, :M_RES, :M_WRK ;
  dcterms:subject "IfcSpace" ;
  dcterms:identifier "M" .

:M_CIR a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "M-CIR" ;
  skos:prefLabel "Main Activity Circulation"@en ;
  skos:prefLabel "Hauptnutzungserschliessung"@de ;
  skos:definition "Circulation spaces integral to main activities"@en ;
  skos:definition "Kategorie fuer hauptnutzungserschliessung im Klassifikationssystem."@de ;
  dcterms:description "Circulation spaces that are part of the primary function, such as museum galleries, shopping mall concourses, or hospital corridors"@en ;
  dcterms:description "Diese Klasse umfasst hauptnutzungserschliessung innerhalb des Klassifikationssystems."@de ;
  skos:broader :M ;
  dcterms:subject "IfcSpace" ;
  dcterms:identifier "M-CIR" .

:M_COM a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "M-COM" ;
  skos:prefLabel "Commercial Spaces"@en ;
  skos:prefLabel "Gewerbeflaechen"@de ;
  skos:definition "Spaces for trading and business activities"@en ;
  skos:definition "Kategorie fuer gewerbeflaechen im Klassifikationssystem."@de ;
  dcterms:description "Spaces designed for buying, selling, displaying merchandise, storage, and customer service"@en ;
  dcterms:description "Diese Klasse umfasst gewerbeflaechen innerhalb des Klassifikationssystems."@de ;
  skos:broader :M ;
  dcterms:subject "IfcSpace" ;
  dcterms:identifier "M-COM" .

:M_HEL a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "M-HEL" ;
  skos:prefLabel "Healthcare Spaces"@en ;
  skos:prefLabel "Gesundheitsflaechen"@de ;
  skos:definition "Spaces for medical and wellness activities"@en ;
  skos:definition "Kategorie fuer gesundheitsflaechen im Klassifikationssystem."@de ;
  dcterms:description "Spaces designed for diagnosis, treatment, recovery, therapy, and preventive care"@en ;
  dcterms:description "Diese Klasse umfasst gesundheitsflaechen innerhalb des Klassifikationssystems."@de ;
  skos:broader :M ;
  dcterms:subject "IfcSpace" ;
  dcterms:identifier "M-HEL" .

:M_LRN a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "M-LRN" ;
  skos:prefLabel "Learning Spaces"@en ;
  skos:prefLabel "Lernflaechen"@de ;
  skos:definition "Spaces for educational and knowledge acquisition"@en ;
  skos:definition "Kategorie fuer lernflaechen im Klassifikationssystem."@de ;
  dcterms:description "Spaces designed for teaching, studying, training, research, and skill development"@en ;
  dcterms:description "Diese Klasse umfasst lernflaechen innerhalb des Klassifikationssystems."@de ;
  skos:broader :M ;
  dcterms:subject "IfcSpace" ;
  dcterms:identifier "M-LRN" .

:M_RES a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "M-RES" ;
  skos:prefLabel "Residential Spaces"@en ;
  skos:prefLabel "Wohnflaechen"@de ;
  skos:definition "Spaces for daily living and personal life activities"@en ;
  skos:definition "Kategorie fuer wohnflaechen im Klassifikationssystem."@de ;
  dcterms:description "Spaces designed for sleeping, eating, personal care, relaxation, and domestic activities"@en ;
  dcterms:description "Diese Klasse umfasst wohnflaechen innerhalb des Klassifikationssystems."@de ;
  skos:broader :M ;
  dcterms:subject "IfcSpace" ;
  dcterms:identifier "M-RES" .

:M_WRK a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "M-WRK" ;
  skos:prefLabel "Work Spaces"@en ;
  skos:prefLabel "Arbeitsflaechen"@de ;
  skos:definition "Spaces for professional and productive activities"@en ;
  skos:definition "Kategorie fuer arbeitsflaechen im Klassifikationssystem."@de ;
  dcterms:description "Spaces designed for desk work, meetings, creative work, manufacturing, and service provision"@en ;
  dcterms:description "Diese Klasse umfasst arbeitsflaechen innerhalb des Klassifikationssystems."@de ;
  skos:broader :M ;
  skos:narrower :M_WRK_KNW, :M_WRK_PRD ;
  dcterms:subject "IfcSpace" ;
  dcterms:identifier "M-WRK" .

:M_WRK_KNW a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "M-WRK-KNW" ;
  skos:prefLabel "Knowledge Work Spaces"@en ;
  skos:prefLabel "Wissensarbeitsflaechen"@de ;
  skos:definition "Spaces for intellectual and information-based work"@en ;
  skos:definition "Kategorie fuer wissensarbeitsflaechen im Klassifikationssystem."@de ;
  dcterms:description "Spaces designed for cognitive tasks, analysis, design, research, and collaborative intellectual work, including offices, meeting rooms, and creative studios"@en ;
  dcterms:description "Diese Klasse umfasst wissensarbeitsflaechen innerhalb des Klassifikationssystems."@de ;
  skos:broader :M_WRK ;
  dcterms:subject "IfcSpace" ;
  dcterms:identifier "M-WRK-KNW" .

:M_WRK_PRD a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "M-WRK-PRD" ;
  skos:prefLabel "Production Work Spaces"@en ;
  skos:prefLabel "Produktionsarbeitsflaechen"@de ;
  skos:definition "Spaces for physical production and manufacturing activities"@en ;
  skos:definition "Kategorie fuer produktionsarbeitsflaechen im Klassifikationssystem."@de ;
  dcterms:description "Spaces designed for manufacturing, assembly, fabrication, maintenance, and other hands-on work activities"@en ;
  dcterms:description "Diese Klasse umfasst produktionsarbeitsflaechen innerhalb des Klassifikationssystems."@de ;
  skos:broader :M_WRK ;
  dcterms:subject "IfcSpace" ;
  dcterms:identifier "M-WRK-PRD" .

:O a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "O" ;
  skos:prefLabel "Outdoor Spaces"@en ;
  skos:prefLabel "Aussenflaechen"@de ;
  skos:definition "External spaces associated with the building"@en ;
  skos:definition "Kategorie fuer aussenflaechen im Klassifikationssystem."@de ;
  dcterms:description "Open-air spaces that complement building functions"@en ;
  dcterms:description "Diese Klasse umfasst aussenflaechen innerhalb des Klassifikationssystems."@de ;
  skos:narrower :O_CIR, :O_GRN ;
  dcterms:subject "IfcSpace" ;
  dcterms:identifier "O" .

:O_CIR a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "O-CIR" ;
  skos:prefLabel "Outdoor Circulation"@en ;
  skos:prefLabel "Aussenerschliessung"@de ;
  skos:definition "External movement spaces"@en ;
  skos:definition "Kategorie fuer aussenerschliessung im Klassifikationssystem."@de ;
  dcterms:description "Including roads, paths, and other outdoor circulation routes"@en ;
  dcterms:description "Diese Klasse umfasst aussenerschliessung innerhalb des Klassifikationssystems."@de ;
  skos:broader :O ;
  skos:narrower :O_CIR_PED, :O_CIR_RD ;
