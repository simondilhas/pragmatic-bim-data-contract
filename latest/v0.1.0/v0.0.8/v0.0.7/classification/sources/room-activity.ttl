:S_CIR_HOR a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "S-CIR-HOR" ;
  skos:prefLabel "Horizontal Circulation"@en ;
  skos:prefLabel "Horizontale Erschliessung"@de ;
