:O_GRN_GDN a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "O-GRN-GDN" ;
  skos:prefLabel "Garden Spaces"@en ;
  skos:prefLabel "Gartenflaechen"@de ;
  skos:definition "Cultivated green spaces"@en ;
  skos:definition "Kategorie fuer gartenflaechen im Klassifikationssystem."@de ;
  dcterms:description "Areas for community gardens, landscaping, and urban farming"@en ;
  dcterms:description "Diese Klasse umfasst gartenflaechen innerhalb des Klassifikationssystems."@de ;
  skos:broader :O_GRN ;
  dcterms:subject "IfcSpace" ;
  dcterms:identifier "O-GRN-GDN" .

:O_GRN_REC a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "O-GRN-REC" ;
  skos:prefLabel "Recreational Green Spaces"@en ;
  skos:prefLabel "Erholungsgruenflaechen"@de ;
  skos:definition "Spaces for leisure activities"@en ;
  skos:definition "Kategorie fuer erholungsgruenflaechen im Klassifikationssystem."@de ;
