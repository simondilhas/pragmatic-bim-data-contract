  dcterms:description "Diese Klasse umfasst erholungsgruenflaechen innerhalb des Klassifikationssystems."@de ;
  skos:broader :O_GRN ;
  dcterms:subject "IfcSpace" ;
  dcterms:identifier "O-GRN-REC" .

:O_GRN_SPT a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "O-GRN-SPT" ;
  skos:prefLabel "Sports Spaces"@en ;
  skos:prefLabel "Sportflaechen"@de ;
  skos:definition "Formal athletic spaces"@en ;
  skos:definition "Kategorie fuer sportflaechen im Klassifikationssystem."@de ;
  dcterms:description "Designated fields and courts for organized sports and games"@en ;
  dcterms:description "Diese Klasse umfasst sportflaechen innerhalb des Klassifikationssystems."@de ;
  skos:broader :O_GRN ;
  dcterms:subject "IfcSpace" ;
  dcterms:identifier "O-GRN-SPT" .

:S a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "S" ;
  skos:prefLabel "Support Spaces"@en ;
  skos:prefLabel "Unterstuetzungsflaechen"@de ;
