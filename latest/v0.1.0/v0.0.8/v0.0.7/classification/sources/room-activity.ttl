  skos:broader :S_PRK ;
  dcterms:subject "IfcSpace" ;
  dcterms:identifier "S-PRK-SVC" .

:S_TEC a skos:Concept ;
  skos:inScheme :scheme ;
  skos:notation "S-TEC" ;
  skos:prefLabel "Technical Spaces"@en ;
  skos:prefLabel "Technikflaechen"@de ;
  skos:definition "Spaces for building systems and equipment"@en ;
  skos:definition "Kategorie fuer technikflaechen im Klassifikationssystem."@de ;
  dcterms:description "Including mechanical rooms, electrical rooms, and equipment spaces"@en ;
  dcterms:description "Diese Klasse umfasst technikflaechen innerhalb des Klassifikationssystems."@de ;
  skos:broader :S ;
  dcterms:subject "IfcSpace" ;
  dcterms:identifier "S-TEC" .

:S_VOI a skos:Concept ;
