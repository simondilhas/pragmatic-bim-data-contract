@prefix : <https://example.org/ch/document-function/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

:scheme a skos:ConceptScheme ;
  skos:prefLabel "Document Function Classification"@en ;
  skos:prefLabel "Klassifikation der Dokumentfunktion"@de ;
  skos:prefLabel "Classification de la fonction du document"@fr ;
  skos:prefLabel "Classificazione della funzione del documento"@it ;
  dcterms:title "Document Function Classification"@en ;
  dcterms:identifier "DocumentFunctionClassification" ;
  dcterms:creator "pragmatic-bim-public-rules" ;
  dcterms:issued "2026-03-22" ;
  skos:definition "Functional classification for business, corporate, and legal documents."@en ;
  skos:definition "Funktionale Klassifikation fuer Geschaefts-, Unternehmens- und Rechtsdokumente."@de ;
  skos:definition "Classification fonctionnelle pour les documents d'entreprise, administratifs et juridiques."@fr ;
  skos:definition "Classificazione funzionale per documenti aziendali, amministrativi e legali."@it ;
  skos:hasTopConcept :financial, :legal_regulatory, :administrative, :marketing_sales, :technical .

:financial a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "FIN" ;
  skos:prefLabel "Financial"@en ;
  skos:prefLabel "Finanzen"@de ;
  skos:prefLabel "Financier"@fr ;
  skos:prefLabel "Finanziario"@it ;
  skos:definition "Documents used for accounting, reporting, payments, and financial control."@en ;
  skos:definition "Dokumente fuer Buchhaltung, Berichterstattung, Zahlungen und finanzielle Steuerung."@de ;
  skos:definition "Documents utilises pour la comptabilite, le reporting, les paiements et le controle financier."@fr ;
  skos:definition "Documenti usati per contabilita, reporting, pagamenti e controllo finanziario."@it ;
  skos:scopeNote "Examples: invoices, receipts, balance sheets, payroll records."@en ;
  skos:scopeNote "Beispiele: Rechnungen, Quittungen, Bilanzen, Lohndokumente."@de ;
  skos:scopeNote "Exemples: factures, recus, bilans, documents de paie."@fr ;
  skos:scopeNote "Esempi: fatture, ricevute, bilanci, documenti salariali."@it .

:legal_regulatory a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "LEG" ;
  skos:prefLabel "Legal and Regulatory"@en ;
  skos:prefLabel "Recht und Regulierung"@de ;
  skos:prefLabel "Juridique et conformite"@fr ;
  skos:prefLabel "Legale e conformita"@it ;
  skos:definition "Documents used for legal obligations, compliance, intellectual property, and formal agreements."@en ;
  skos:definition "Dokumente fuer rechtliche Verpflichtungen, Compliance, geistiges Eigentum und formelle Vereinbarungen."@de ;
  skos:definition "Documents utilises pour les obligations juridiques, la conformite, la propriete intellectuelle et les accords formels."@fr ;
  skos:definition "Documenti usati per obblighi legali, conformita, proprieta intellettuale e accordi formali."@it ;
  skos:scopeNote "Examples: contracts, NDAs, compliance reports, patents."@en ;
  skos:scopeNote "Beispiele: Vertraege, Geheimhaltungsvereinbarungen, Compliance-Berichte, Patente."@de ;
  skos:scopeNote "Exemples: contrats, accords de confidentialite, rapports de conformite, brevets."@fr ;
  skos:scopeNote "Esempi: contratti, accordi di riservatezza, rapporti di conformita, brevetti."@it .

:administrative a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "ADM" ;
  skos:prefLabel "Administrative"@en ;
  skos:prefLabel "Administrativ"@de ;
  skos:prefLabel "Administratif"@fr ;
  skos:prefLabel "Amministrativo"@it ;
  skos:definition "Documents supporting internal administration, coordination, and organizational governance."@en ;
  skos:definition "Dokumente zur internen Administration, Koordination und organisatorischen Steuerung."@de ;
  skos:definition "Documents soutenant l'administration interne, la coordination et la gouvernance organisationnelle."@fr ;
  skos:definition "Documenti di supporto all'amministrazione interna, al coordinamento e alla governance organizzativa."@it ;
  skos:scopeNote "Examples: meeting minutes, memos, internal policies."@en ;
  skos:scopeNote "Beispiele: Sitzungsprotokolle, Memos, interne Richtlinien."@de ;
  skos:scopeNote "Exemples: proces-verbaux, notes internes, politiques internes."@fr ;
  skos:scopeNote "Esempi: verbali di riunione, promemoria, politiche interne."@it .

:marketing_sales a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "MKS" ;
  skos:prefLabel "Marketing and Sales"@en ;
  skos:prefLabel "Marketing und Vertrieb"@de ;
  skos:prefLabel "Marketing et ventes"@fr ;
  skos:prefLabel "Marketing e vendite"@it ;
  skos:definition "Documents used for market communication, promotion, customer acquisition, and sales support."@en ;
  skos:definition "Dokumente fuer Marktkommunikation, Promotion, Kundengewinnung und Vertriebsunterstuetzung."@de ;
  skos:definition "Documents utilises pour la communication de marche, la promotion, l'acquisition de clients et le support commercial."@fr ;
  skos:definition "Documenti usati per comunicazione di mercato, promozione, acquisizione clienti e supporto alle vendite."@it ;
  skos:scopeNote "Examples: case studies, brochures, white papers, lead lists."@en ;
  skos:scopeNote "Beispiele: Fallstudien, Broschueren, White Papers, Lead-Listen."@de ;
  skos:scopeNote "Exemples: etudes de cas, brochures, livres blancs, listes de prospects."@fr ;
  skos:scopeNote "Esempi: casi studio, brochure, white paper, liste di lead."@it .

:technical a skos:Concept ;
  skos:inScheme :scheme ;
  skos:topConceptOf :scheme ;
  skos:notation "TEC" ;
  skos:prefLabel "Technical"@en ;
  skos:prefLabel "Technisch"@de ;
  skos:prefLabel "Technique"@fr ;
  skos:prefLabel "Tecnico"@it ;
  skos:definition "Documents used for technical instruction, implementation, operation, and engineering communication."@en ;
  skos:definition "Dokumente fuer technische Anleitung, Umsetzung, Betrieb und ingenieurbezogene Kommunikation."@de ;
  skos:definition "Documents utilises pour l'instruction technique, la mise en oeuvre, l'exploitation et la communication d'ingenierie."@fr ;
  skos:definition "Documenti usati per istruzioni tecniche, implementazione, esercizio e comunicazione ingegneristica."@it ;
  skos:scopeNote "Examples: user manuals, API documentation, schematics."@en ;
  skos:scopeNote "Beispiele: Benutzerhandbuecher, API-Dokumentation, Schemata."@de ;
  skos:scopeNote "Exemples: manuels utilisateur, documentation API, schemas."@fr ;
  skos:scopeNote "Esempi: manuali utente, documentazione API, schemi."@it .
