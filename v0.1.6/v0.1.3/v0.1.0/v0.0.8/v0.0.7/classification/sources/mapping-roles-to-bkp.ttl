@prefix role: <https://example.org/ch/abstract-roles/> .
@prefix bkp: <https://example.org/ch/bkp/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix map: <https://example.org/mapping/> .

map:abstractRolesToBkpMapping a dcterms:Dataset ;
  dcterms:title "Abstract workflow roles to BKP mapping"@en ;
  dcterms:title "Mapping abstrakter Workflow-Rollen nach BKP"@de ;
  dcterms:references role:scheme, bkp:scheme ;
  dcterms:issued "2026-03-31" ;
  dcterms:description "Maps leaf concepts in abstract-roles (SKOS: owner / tenant / planner / contractor groups) to BKP cost lines. Discipline Honorare repeat per phase (091/191/…); architect lists every Architekt IRI in this BKP file. Site manager is under planner (construction supervision); BKP links it to Buero Bauleitung (133), i.e. the Bauleitung office under Gemeinsame Baustelleneinrichtung. Project management and BIM coordination often appear as Spezialisten-Honorar (096 …) in tenders; those links are relatedMatch, not equivalence."@en ;
  dcterms:description "Ordnet Blattkonzepte der abstract-roles (SKOS: Gruppen Eigentümer / Mieter / Planer / Unternehmer) BKP-Kostenpositionen zu. Disziplin-Honorare wiederholen sich pro Phase (091/191/…); Architekt listet alle Architekt-IRIs dieser BKP-Datei. Site-Manager liegt unter Planer (Bauüberwachung); BKP verknüpft mit Büro Bauleitung (133) unter Gemeinsame Baustelleneinrichtung. Projektleitung und BIM-Koordination werden in Ausschreibungen oft als Spezialisten-Honorar (096 …) geführt; Verknüpfungen sind relatedMatch."@de .

# --- Honorare: design disciplines (closeMatch where BKP names the discipline) ---

role:aec.architect skos:closeMatch
  bkp:091, bkp:191, bkp:291, bkp:391, bkp:491, bkp:591, bkp:991 .

role:aec.structural_engineer skos:closeMatch
  bkp:092, bkp:192, bkp:292, bkp:392, bkp:492, bkp:592 .

role:aec.electrical_engineer skos:closeMatch
  bkp:093, bkp:193, bkp:293, bkp:393, bkp:493, bkp:593, bkp:993 .

role:aec.plumbing_engineer skos:closeMatch
  bkp:095, bkp:195, bkp:295, bkp:395, bkp:495, bkp:595 .

# HLKK-Ingenieur (094 …): shared umbrella for heating and ventilation planning.
role:aec.heating_engineer skos:relatedMatch
  bkp:094, bkp:194, bkp:294, bkp:394, bkp:494, bkp:594 .
role:aec.ventilation_engineer skos:relatedMatch
  bkp:094, bkp:194, bkp:294, bkp:394, bkp:494, bkp:594 .

# --- Honorare: specialists (096 …); BIM / PM / sustainability often booked here ---

role:aec.sustainability_consultant skos:relatedMatch
  bkp:096, bkp:196, bkp:296, bkp:396, bkp:496, bkp:596, bkp:996 .

role:aec.bim_coordinator skos:relatedMatch
  bkp:096, bkp:196, bkp:296, bkp:396, bkp:496, bkp:596, bkp:996 .

role:aec.bim_manager skos:relatedMatch
  bkp:096, bkp:196, bkp:296, bkp:396, bkp:496, bkp:596, bkp:996 .

role:aec.project_lead skos:relatedMatch
  bkp:096, bkp:196, bkp:296, bkp:396, bkp:496, bkp:596, bkp:996 .

role:aec.project_manager skos:relatedMatch
  bkp:096, bkp:196, bkp:296, bkp:396, bkp:496, bkp:596, bkp:996 .

# --- Planner-side site supervision: Buero Bauleitung (133), Kategorie 13 under Vorbereitung / Baustelleneinrichtung ---
# Only notation 133 exists in this BKP extract (no 233/333 … parallel for this label).
role:aec.site_manager skos:relatedMatch bkp:133 .

# --- Owner-side economic bucket (not Honorar discipline lines) ---

role:aec.client skos:relatedMatch bkp:55 .
role:aec.owner skos:relatedMatch bkp:55 .
role:aec.developer skos:relatedMatch bkp:55 .

# Not mapped: role:group.*, role:aec.contractor, role:aec.supplier, role:aec.facility_manager,
# role:group.tenant (no leaf roles). Phase-99 Honorare subset: no 992/994/995 in this file.
